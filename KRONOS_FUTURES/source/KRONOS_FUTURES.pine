// KR-252.30 PUBLIC INTERFACE
//==================================================================

bool outRelationshipReady = relationshipReady
string outRelationshipStatus = relationshipStatus
string outRelationshipReason = relationshipReason
string outRelationshipCashSymbol = relationshipCashSymbol
string outRelationshipPrimaryReferenceSymbol = relationshipPrimaryReferenceSymbol
string outRelationshipSecondaryReferenceSymbol = relationshipSecondaryReferenceSymbol
string outRelationshipSectorIndexSymbol = relationshipSectorIndexSymbol
string outRelationshipParentIndexSymbol = relationshipParentIndexSymbol
bool outRelationshipHasSectorContext = relationshipHasSectorContext
bool outRelationshipHasParentIndexContext = relationshipHasParentIndexContext
bool outRelationshipHasGlobalReference = relationshipHasGlobalReference
string outSectorIndexSymbol = outRelationshipSectorIndexSymbol
string outParentIndexSymbol = outRelationshipParentIndexSymbol
outPrimaryReferenceSymbol := outRelationshipPrimaryReferenceSymbol
outSecondaryReferenceSymbol := outRelationshipSecondaryReferenceSymbol

