// END OF KR-252
//==================================================================

//==================================================================
// KR-260A : Market Data Routing Engine
// Version : 0.1.0
// Status  : FOUNDATION
//
// Purpose:
// Answers: "What symbols should KRONOS use?"
// Translates KR-251/KR-252 configuration outputs into a standardized
// market-data routing contract. KR-260A performs symbol routing only.
//
// Contract:
// - Consumes only public outputs from KR-251 and KR-252.
// - No request.security calls.
// - No OHLCV retrieval or normalization.
// - No indicators, relative strength, decisions, alerts, entries,
//   exits, stops, targets or trade management.
// - KR-260 integration is pending.
//==================================================================

//==================================================================
// KR-260A.10 ROUTE CONSTANTS
//==================================================================

const string KR260A_STATUS_READY = "READY"
const string KR260A_STATUS_REVIEW = "REVIEW"
const string KR260A_STATUS_UNSUPPORTED = "UNSUPPORTED"
const string KR260A_STATUS_INVALID_CONFIG = "INVALID CONFIG"

//==================================================================
// KR-260A.20 ROUTE INPUT CLASSIFICATION
//==================================================================

marketDataRouteSymbolValid(string symbol) =>
    symbol != "" and symbol != "UNKNOWN"

bool marketDataRouteIsMCXMetals = outModelName == "MCX Metals Swing"
bool marketDataRouteIsMCXEnergy = outModelName == "MCX Energy Swing"
bool marketDataRouteIsNSEEquity = outModelName == "NSE Equity Swing"
bool marketDataRouteIsNSEIndex = outModelName == "NSE Index Swing"
bool marketDataRouteIsSupportedModel = marketDataRouteIsMCXMetals or marketDataRouteIsMCXEnergy or marketDataRouteIsNSEEquity or marketDataRouteIsNSEIndex

//==================================================================
// KR-260A.30 ROUTE SYMBOLS
//==================================================================

string marketDataRouteAnalysisSymbol = outAnalysisSymbol
string marketDataRouteExecutionInstrumentText = outExecutionInstrumentText
string marketDataRoutePrimaryReferenceSymbol = ""
string marketDataRouteSecondaryReferenceSymbol = ""
string marketDataRouteSectorSymbol = ""
string marketDataRouteParentIndexSymbol = ""
bool marketDataRouteUsesCashAnalysis = false
bool marketDataRouteUsesIndexAnalysis = false
bool marketDataRouteUsesFuturesAnalysis = false

if marketDataRouteIsMCXMetals or marketDataRouteIsMCXEnergy
    marketDataRoutePrimaryReferenceSymbol := outRelationshipPrimaryReferenceSymbol
    marketDataRouteUsesFuturesAnalysis := true
else if marketDataRouteIsNSEEquity
    marketDataRoutePrimaryReferenceSymbol := outRelationshipPrimaryReferenceSymbol
    marketDataRouteSecondaryReferenceSymbol := outRelationshipSecondaryReferenceSymbol
    marketDataRouteSectorSymbol := outRelationshipSectorIndexSymbol
    marketDataRouteParentIndexSymbol := outRelationshipParentIndexSymbol
    marketDataRouteUsesCashAnalysis := true
else if marketDataRouteIsNSEIndex
    marketDataRouteUsesIndexAnalysis := true

bool marketDataRouteHasPrimaryReference = marketDataRouteSymbolValid(marketDataRoutePrimaryReferenceSymbol)
bool marketDataRouteHasSecondaryReference = marketDataRouteSymbolValid(marketDataRouteSecondaryReferenceSymbol)
bool marketDataRouteHasSectorContext = marketDataRouteSymbolValid(marketDataRouteSectorSymbol) and outRelationshipHasSectorContext
bool marketDataRouteHasParentIndexContext = marketDataRouteSymbolValid(marketDataRouteParentIndexSymbol) and outRelationshipHasParentIndexContext
bool marketDataRouteAnalysisValid = marketDataRouteSymbolValid(marketDataRouteAnalysisSymbol)
bool marketDataRouteExecutionInstrumentValid = marketDataRouteExecutionInstrumentText != ""

//==================================================================
// KR-260A.40 ROUTE READINESS
//==================================================================

string marketDataRouteStatus = KR260A_STATUS_UNSUPPORTED
string marketDataRouteReason = "Unsupported Market Data Route"
bool marketDataRouteReady = false

if not outSupportedInstrument or not marketDataRouteIsSupportedModel
    marketDataRouteReady := false
    marketDataRouteStatus := KR260A_STATUS_UNSUPPORTED
    marketDataRouteReason := "Unsupported Market Data Route"
else if marketDataRouteIsMCXMetals or marketDataRouteIsMCXEnergy
    if not marketDataRouteAnalysisValid
        marketDataRouteStatus := KR260A_STATUS_INVALID_CONFIG
        marketDataRouteReason := "Missing Analysis Symbol"
    else if outRelationshipStatus == KR260A_STATUS_REVIEW
        marketDataRouteStatus := KR260A_STATUS_REVIEW
        marketDataRouteReason := outRelationshipReason
    else if not outRelationshipReady or not marketDataRouteHasPrimaryReference
        marketDataRouteStatus := KR260A_STATUS_INVALID_CONFIG
        marketDataRouteReason := "Missing Primary Reference"
    else
        marketDataRouteReady := true
        marketDataRouteStatus := KR260A_STATUS_READY
        marketDataRouteReason := "Market Data Route Ready"
else if marketDataRouteIsNSEEquity
    if outRelationshipStatus == KR260A_STATUS_REVIEW
        marketDataRouteStatus := KR260A_STATUS_REVIEW
        marketDataRouteReason := "NSE Relationship Review Required - " + outRelationshipReason
    else if not marketDataRouteAnalysisValid
        marketDataRouteStatus := KR260A_STATUS_INVALID_CONFIG
        marketDataRouteReason := "Missing Analysis Symbol"
    else if not marketDataRouteExecutionInstrumentValid
        marketDataRouteStatus := KR260A_STATUS_INVALID_CONFIG
        marketDataRouteReason := "Missing Execution Instrument"
    else if not outRelationshipReady
        marketDataRouteStatus := KR260A_STATUS_INVALID_CONFIG
        marketDataRouteReason := outRelationshipReason
    else if not marketDataRouteHasSectorContext
        marketDataRouteStatus := KR260A_STATUS_INVALID_CONFIG
        marketDataRouteReason := "Missing Sector Context"
    else if not marketDataRouteHasParentIndexContext
        marketDataRouteStatus := KR260A_STATUS_INVALID_CONFIG
        marketDataRouteReason := "Missing Parent Index Context"
    else
        marketDataRouteReady := true
        marketDataRouteStatus := KR260A_STATUS_READY
        marketDataRouteReason := "Market Data Route Ready"
else if marketDataRouteIsNSEIndex
    if not marketDataRouteAnalysisValid
        marketDataRouteStatus := KR260A_STATUS_INVALID_CONFIG
        marketDataRouteReason := "Missing Analysis Symbol"
    else if not marketDataRouteExecutionInstrumentValid
        marketDataRouteStatus := KR260A_STATUS_INVALID_CONFIG
        marketDataRouteReason := "Missing Execution Instrument"
    else if not outRelationshipReady
        marketDataRouteStatus := KR260A_STATUS_INVALID_CONFIG
        marketDataRouteReason := outRelationshipReason
    else
        marketDataRouteReady := true
        marketDataRouteStatus := KR260A_STATUS_READY
        marketDataRouteReason := "Market Data Route Ready"

//==================================================================
// KR-260A.50 PUBLIC INTERFACE
//==================================================================

bool outMarketDataRouteReady = marketDataRouteReady
string outMarketDataRouteStatus = marketDataRouteStatus
string outMarketDataRouteReason = marketDataRouteReason
string outMarketDataAnalysisSymbol = marketDataRouteAnalysisSymbol
string outMarketDataExecutionInstrumentText = marketDataRouteExecutionInstrumentText
string outMarketDataPrimaryReferenceSymbol = marketDataRoutePrimaryReferenceSymbol
string outMarketDataSecondaryReferenceSymbol = marketDataRouteSecondaryReferenceSymbol
string outMarketDataSectorSymbol = marketDataRouteSectorSymbol
string outMarketDataParentIndexSymbol = marketDataRouteParentIndexSymbol
bool outMarketDataHasPrimaryReference = marketDataRouteHasPrimaryReference
bool outMarketDataHasSecondaryReference = marketDataRouteHasSecondaryReference
bool outMarketDataHasSectorContext = marketDataRouteHasSectorContext
bool outMarketDataHasParentIndexContext = marketDataRouteHasParentIndexContext
bool outMarketDataUsesCashAnalysis = marketDataRouteUsesCashAnalysis
bool outMarketDataUsesIndexAnalysis = marketDataRouteUsesIndexAnalysis
bool outMarketDataUsesFuturesAnalysis = marketDataRouteUsesFuturesAnalysis

//==================================================================
// END OF KR-260A
//==================================================================

//==================================================================
// KR-260B : Market Data Retrieval Engine
// Version : 1.0.0
// Status  : Implemented
//
// Purpose:
// Answers: "Retrieve market data from those symbols."
// Retrieves current-chart-timeframe OHLCV for valid symbols selected
// by the public KR-260A routing interface.
//
// Ownership:
// - Consumes only public routing outputs from KR-260A.
// - Owns guarded request.security calls and raw OHLCV retrieval.
// - Exposes raw datasets and per-context data-readiness flags.
// - Does not own routing, calculations, normalization, indicators,
//   intelligence, decisions, rendering, alerts, or trade management.
//==================================================================

//==================================================================
// KR-260B.10 REQUEST READINESS
//==================================================================

bool marketDataAnalysisRequestReady = outMarketDataRouteReady and outMarketDataAnalysisSymbol != "" and outMarketDataAnalysisSymbol != "UNKNOWN"
bool marketDataPrimaryRequestReady = outMarketDataRouteReady and outMarketDataHasPrimaryReference and outMarketDataPrimaryReferenceSymbol != "" and outMarketDataPrimaryReferenceSymbol != "UNKNOWN"
bool marketDataSecondaryRequestReady = outMarketDataRouteReady and outMarketDataHasSecondaryReference and outMarketDataSecondaryReferenceSymbol != "" and outMarketDataSecondaryReferenceSymbol != "UNKNOWN"
bool marketDataSectorRequestReady = outMarketDataRouteReady and outMarketDataHasSectorContext and outMarketDataSectorSymbol != "" and outMarketDataSectorSymbol != "UNKNOWN"
bool marketDataParentRequestReady = outMarketDataRouteReady and outMarketDataHasParentIndexContext and outMarketDataParentIndexSymbol != "" and outMarketDataParentIndexSymbol != "UNKNOWN"

//==================================================================
// KR-260B.20 ANALYSIS RETRIEVAL
//==================================================================

float marketDataAnalysisOpen = na
float marketDataAnalysisHigh = na
float marketDataAnalysisLow = na
float marketDataAnalysisClose = na
float marketDataAnalysisVolume = na

if marketDataAnalysisRequestReady
    [requestedAnalysisOpen, requestedAnalysisHigh, requestedAnalysisLow, requestedAnalysisClose, requestedAnalysisVolume] = request.security(outMarketDataAnalysisSymbol, timeframe.period, [open, high, low, close, volume], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
    marketDataAnalysisOpen := requestedAnalysisOpen
    marketDataAnalysisHigh := requestedAnalysisHigh
    marketDataAnalysisLow := requestedAnalysisLow
    marketDataAnalysisClose := requestedAnalysisClose
    marketDataAnalysisVolume := requestedAnalysisVolume

//==================================================================
// KR-260B.30 PRIMARY REFERENCE RETRIEVAL
//==================================================================

float marketDataPrimaryOpen = na
float marketDataPrimaryHigh = na
float marketDataPrimaryLow = na
float marketDataPrimaryClose = na
float marketDataPrimaryVolume = na

if marketDataPrimaryRequestReady
    [requestedPrimaryOpen, requestedPrimaryHigh, requestedPrimaryLow, requestedPrimaryClose, requestedPrimaryVolume] = request.security(outMarketDataPrimaryReferenceSymbol, timeframe.period, [open, high, low, close, volume], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
    marketDataPrimaryOpen := requestedPrimaryOpen
    marketDataPrimaryHigh := requestedPrimaryHigh
    marketDataPrimaryLow := requestedPrimaryLow
    marketDataPrimaryClose := requestedPrimaryClose
    marketDataPrimaryVolume := requestedPrimaryVolume

//==================================================================
// KR-260B.40 SECONDARY REFERENCE RETRIEVAL
//==================================================================

float marketDataSecondaryOpen = na
float marketDataSecondaryHigh = na
float marketDataSecondaryLow = na
float marketDataSecondaryClose = na
float marketDataSecondaryVolume = na

if marketDataSecondaryRequestReady
    [requestedSecondaryOpen, requestedSecondaryHigh, requestedSecondaryLow, requestedSecondaryClose, requestedSecondaryVolume] = request.security(outMarketDataSecondaryReferenceSymbol, timeframe.period, [open, high, low, close, volume], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
    marketDataSecondaryOpen := requestedSecondaryOpen
    marketDataSecondaryHigh := requestedSecondaryHigh
    marketDataSecondaryLow := requestedSecondaryLow
    marketDataSecondaryClose := requestedSecondaryClose
    marketDataSecondaryVolume := requestedSecondaryVolume

//==================================================================
// KR-260B.50 SECTOR RETRIEVAL
//==================================================================

float marketDataSectorOpen = na
float marketDataSectorHigh = na
float marketDataSectorLow = na
float marketDataSectorClose = na
float marketDataSectorVolume = na

if marketDataSectorRequestReady
    [requestedSectorOpen, requestedSectorHigh, requestedSectorLow, requestedSectorClose, requestedSectorVolume] = request.security(outMarketDataSectorSymbol, timeframe.period, [open, high, low, close, volume], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
    marketDataSectorOpen := requestedSectorOpen
    marketDataSectorHigh := requestedSectorHigh
    marketDataSectorLow := requestedSectorLow
    marketDataSectorClose := requestedSectorClose
    marketDataSectorVolume := requestedSectorVolume

//==================================================================
// KR-260B.60 PARENT INDEX RETRIEVAL
//==================================================================

float marketDataParentOpen = na
float marketDataParentHigh = na
float marketDataParentLow = na
float marketDataParentClose = na
float marketDataParentVolume = na

if marketDataParentRequestReady
    [requestedParentOpen, requestedParentHigh, requestedParentLow, requestedParentClose, requestedParentVolume] = request.security(outMarketDataParentIndexSymbol, timeframe.period, [open, high, low, close, volume], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
    marketDataParentOpen := requestedParentOpen
    marketDataParentHigh := requestedParentHigh
    marketDataParentLow := requestedParentLow
    marketDataParentClose := requestedParentClose
    marketDataParentVolume := requestedParentVolume

//==================================================================
// KR-260B.70 PUBLIC INTERFACE
//==================================================================

float outAnalysisOpen = marketDataAnalysisOpen
float outAnalysisHigh = marketDataAnalysisHigh
float outAnalysisLow = marketDataAnalysisLow
float outAnalysisClose = marketDataAnalysisClose
float outAnalysisVolume = marketDataAnalysisVolume
float outPrimaryOpen = marketDataPrimaryOpen
float outPrimaryHigh = marketDataPrimaryHigh
float outPrimaryLow = marketDataPrimaryLow
float outPrimaryClose = marketDataPrimaryClose
float outPrimaryVolume = marketDataPrimaryVolume
float outSecondaryOpen = marketDataSecondaryOpen
float outSecondaryHigh = marketDataSecondaryHigh
float outSecondaryLow = marketDataSecondaryLow
float outSecondaryClose = marketDataSecondaryClose
float outSecondaryVolume = marketDataSecondaryVolume
float outSectorOpen = marketDataSectorOpen
float outSectorHigh = marketDataSectorHigh
float outSectorLow = marketDataSectorLow
float outSectorClose = marketDataSectorClose
float outSectorVolume = marketDataSectorVolume
float outParentOpen = marketDataParentOpen
float outParentHigh = marketDataParentHigh
float outParentLow = marketDataParentLow
float outParentClose = marketDataParentClose
float outParentVolume = marketDataParentVolume

bool outAnalysisDataReady = marketDataAnalysisRequestReady and not na(outAnalysisClose)
bool outPrimaryDataReady = marketDataPrimaryRequestReady and not na(outPrimaryClose)
bool outSecondaryDataReady = marketDataSecondaryRequestReady and not na(outSecondaryClose)
bool outSectorDataReady = marketDataSectorRequestReady and not na(outSectorClose)
bool outParentDataReady = marketDataParentRequestReady and not na(outParentClose)

//==================================================================
// END OF KR-260B
//==================================================================

//==================================================================
// KRONOS SHARED HELPERS
//==================================================================

//--------------------------------------------------
// KR-001
// Returns OHLCV dataset for any symbol/timeframe
//--------------------------------------------------

getOHLCV(string symbol, string timeframe) =>
    request.security(
         symbol,
         timeframe,
         [open, high, low, close, volume],
         gaps = barmerge.gaps_off,
         lookahead = barmerge.lookahead_off
     )

//==================================================================
// KR-260 : MARKET DATA NORMALIZATION ENGINE
// Version : 0.5.0-alpha
// Build   : 0006
//
// Purpose:
// Answers: "Normalize retrieved market data for the Intelligence Layer."
// Owns the normalized market-data interface consumed by downstream
// KRONOS engines.
//
// Inputs
// - Future KR-260B Retrieval Interface
// - Current legacy KR-100/KR-250 data path pending migration
//
// Outputs
// - Normalized Market Data Interface
// - Status Interface
//
// Target Ownership:
// - Consumes retrieved market data from KR-260B.
// - Does not own symbol routing.
// - Does not own TradingView request.security calls.
//
// Migration Note:
// Existing executable market-data logic remains unchanged in this
// architecture-only pass. KR-260B retrieval wiring is not implemented.
//==================================================================

//==================================================================
// KR-260.10 CONFIGURATION INTERFACE
//==================================================================

// Timeframes supplied by KR-100.
// Temporary placeholders until KR-100 is profile-driven.

string mdStrategicTF = "W"
string mdTrendTF     = "D"
string mdStructureTF = "240"
string mdExecutionTF = "60"

//==================================================================
// KR-260.20 ASSET INTERFACE
//==================================================================

// Public interface received from KR-250

string mdPrimarySymbol     = assetPrimarySymbol
string mdReferenceSymbol   = assetReferenceSymbol
string mdDependencyProfile = assetDependencyProfile
bool mdReferenceSymbolValid = mdReferenceSymbol != "" and mdReferenceSymbol != "UNKNOWN"
bool mdReferenceChart = assetMarket == "COMEX" or assetMarket == "NYMEX"
bool mdReferenceRequestEnabled = mdReferenceSymbolValid or mdReferenceChart
string mdReferenceRequestSymbol = mdReferenceSymbolValid ? mdReferenceSymbol : syminfo.tickerid

if mdReferenceChart
    mdReferenceRequestSymbol := syminfo.tickerid

//==================================================================
// KR-260.30 ENGINE STATUS
//==================================================================

bool mdPrimaryAvailable   = false
bool mdReferenceAvailable = false

string mdStatus       = "INITIALIZING"
string mdErrorMessage = ""

//==================================================================
// KR-260.40 PUBLIC MARKET DATA INTERFACE
//==================================================================

// Strategic
float mdPrimaryStrategicClose   = na
float mdReferenceStrategicClose = na

// Trend
float mdPrimaryTrendClose       = na
float mdReferenceTrendClose     = na

// Structure
float mdPrimaryStructureClose   = na
float mdReferenceStructureClose = na

// Execution
float mdPrimaryExecutionClose   = na
float mdReferenceExecutionClose = na

//==================================================================
// KR-260.31 PRIMARY - STRATEGIC DATASET
//==================================================================

[mdPrimaryStrategicO, mdPrimaryStrategicH, mdPrimaryStrategicL, mdPrimaryStrategicC, mdPrimaryStrategicV] = getOHLCV(mdPrimarySymbol, mdStrategicTF)

//==================================================================
// KR-260.32 PRIMARY - TREND DATASET
//==================================================================

[mdPrimaryTrendO, mdPrimaryTrendH, mdPrimaryTrendL, mdPrimaryTrendC, mdPrimaryTrendV] = getOHLCV(mdPrimarySymbol, mdTrendTF)

//==================================================================
// KR-260.33 PRIMARY - STRUCTURE DATASET
//==================================================================

[mdPrimaryStructureO, mdPrimaryStructureH, mdPrimaryStructureL, mdPrimaryStructureC, mdPrimaryStructureV] = getOHLCV(mdPrimarySymbol, mdStructureTF)

//==================================================================
// KR-260.34 PRIMARY - EXECUTION DATASET
//==================================================================

[mdPrimaryExecutionO, mdPrimaryExecutionH, mdPrimaryExecutionL, mdPrimaryExecutionC, mdPrimaryExecutionV] = getOHLCV(mdPrimarySymbol, mdExecutionTF)


//==================================================================
// KR-260.35 PRIMARY DATA VALIDATION
//==================================================================

bool mdStrategicAvailable = not na(mdPrimaryStrategicC)
bool mdTrendAvailable     = not na(mdPrimaryTrendC)
bool mdStructureAvailable = not na(mdPrimaryStructureC)
bool mdExecutionAvailable = not na(mdPrimaryExecutionC)

mdPrimaryAvailable := mdStrategicAvailable and
                      mdTrendAvailable and
                      mdStructureAvailable and
                      mdExecutionAvailable

//==================================================================
// KR-260.35 PRIMARY DATA STATUS
//==================================================================

mdPrimaryAvailable := not na(mdPrimaryExecutionC)

if mdPrimaryAvailable
    mdStatus := "PRIMARY DATA READY"
else
    mdStatus := "PRIMARY DATA UNAVAILABLE"


//==================================================================
// KR-260.41 REFERENCE - STRATEGIC DATASET
//==================================================================

[mdReferenceStrategicRawO, mdReferenceStrategicRawH, mdReferenceStrategicRawL, mdReferenceStrategicRawC, mdReferenceStrategicRawV] = getOHLCV(mdReferenceRequestSymbol, mdStrategicTF)

float mdReferenceStrategicO = mdReferenceRequestEnabled ? mdReferenceStrategicRawO : na
float mdReferenceStrategicH = mdReferenceRequestEnabled ? mdReferenceStrategicRawH : na
float mdReferenceStrategicL = mdReferenceRequestEnabled ? mdReferenceStrategicRawL : na
float mdReferenceStrategicC = mdReferenceRequestEnabled ? mdReferenceStrategicRawC : na
float mdReferenceStrategicV = mdReferenceRequestEnabled ? mdReferenceStrategicRawV : na

//==================================================================
// KR-260.42 REFERENCE - TREND DATASET
//==================================================================

[mdReferenceTrendRawO, mdReferenceTrendRawH, mdReferenceTrendRawL, mdReferenceTrendRawC, mdReferenceTrendRawV] = getOHLCV(mdReferenceRequestSymbol, mdTrendTF)

float mdReferenceTrendO = mdReferenceRequestEnabled ? mdReferenceTrendRawO : na
float mdReferenceTrendH = mdReferenceRequestEnabled ? mdReferenceTrendRawH : na
float mdReferenceTrendL = mdReferenceRequestEnabled ? mdReferenceTrendRawL : na
float mdReferenceTrendC = mdReferenceRequestEnabled ? mdReferenceTrendRawC : na
float mdReferenceTrendV = mdReferenceRequestEnabled ? mdReferenceTrendRawV : na

//==================================================================
// KR-260.43 REFERENCE - STRUCTURE DATASET
//==================================================================

[mdReferenceStructureRawO, mdReferenceStructureRawH, mdReferenceStructureRawL, mdReferenceStructureRawC, mdReferenceStructureRawV] = getOHLCV(mdReferenceRequestSymbol, mdStructureTF)

float mdReferenceStructureO = mdReferenceRequestEnabled ? mdReferenceStructureRawO : na
float mdReferenceStructureH = mdReferenceRequestEnabled ? mdReferenceStructureRawH : na
float mdReferenceStructureL = mdReferenceRequestEnabled ? mdReferenceStructureRawL : na
float mdReferenceStructureC = mdReferenceRequestEnabled ? mdReferenceStructureRawC : na
float mdReferenceStructureV = mdReferenceRequestEnabled ? mdReferenceStructureRawV : na

//==================================================================
// KR-260.44 REFERENCE - EXECUTION DATASET
//==================================================================

[mdReferenceExecutionRawO, mdReferenceExecutionRawH, mdReferenceExecutionRawL, mdReferenceExecutionRawC, mdReferenceExecutionRawV] = getOHLCV(mdReferenceRequestSymbol, mdExecutionTF)

float mdReferenceExecutionO = mdReferenceRequestEnabled ? mdReferenceExecutionRawO : na
float mdReferenceExecutionH = mdReferenceRequestEnabled ? mdReferenceExecutionRawH : na
float mdReferenceExecutionL = mdReferenceRequestEnabled ? mdReferenceExecutionRawL : na
float mdReferenceExecutionC = mdReferenceRequestEnabled ? mdReferenceExecutionRawC : na
float mdReferenceExecutionV = mdReferenceRequestEnabled ? mdReferenceExecutionRawV : na

bool mdReferenceStrategicAvailable = mdReferenceRequestEnabled and not na(mdReferenceStrategicC)
bool mdReferenceTrendAvailable     = mdReferenceRequestEnabled and not na(mdReferenceTrendC)
bool mdReferenceStructureAvailable = mdReferenceRequestEnabled and not na(mdReferenceStructureC)
bool mdReferenceExecutionAvailable = mdReferenceRequestEnabled and not na(mdReferenceExecutionC)

mdReferenceAvailable := mdReferenceStrategicAvailable and mdReferenceTrendAvailable and mdReferenceStructureAvailable and mdReferenceExecutionAvailable

if not mdReferenceRequestEnabled
    mdStatus := "Reference Data Unavailable"
    mdErrorMessage := "Reference Data Unavailable"


//==================================================================
// KR-270 : MARKET INDICATOR ENGINE
// Version : 0.5.0-alpha
// Build   : 0007
//
// Purpose:
// Calculates all derived technical indicators from KR-260 market
// data.
//
// NOTE:
// KR-270 never retrieves market data directly.
//==================================================================
//==================================================================
// KR-270.01 INDICATOR PARAMETERS
//==================================================================

const int SMA_FAST   = 20
const int SMA_SLOW   = 50
const int SMA_LONG   = 200

const int RSI_PERIOD = 14


//------------------------------
// Primary Trend
//------------------------------

float indPrimaryTrendSMA20  = ta.sma(mdPrimaryTrendC, SMA_FAST)
float indPrimaryTrendSMA50  = ta.sma(mdPrimaryTrendC, SMA_SLOW)
float indPrimaryTrendSMA200 = ta.sma(mdPrimaryTrendC, SMA_LONG)

//------------------------------
// Reference Trend
//------------------------------

float indReferenceTrendSMA20  = ta.sma(mdReferenceTrendC, SMA_FAST)
float indReferenceTrendSMA50  = ta.sma(mdReferenceTrendC, SMA_SLOW)
float indReferenceTrendSMA200 = ta.sma(mdReferenceTrendC, SMA_LONG)

//==================================================================
// KR-270.20 MOMENTUM
//==================================================================

// Primary
float indPrimaryTrendRSI = ta.rsi(mdPrimaryTrendC, RSI_PERIOD)

// Reference
float indReferenceTrendRSI = ta.rsi(mdReferenceTrendC, RSI_PERIOD)

//==================================================================
// KR-271 : MATHEMATICAL LIBRARY
//==================================================================
//
// Purpose:
// Provides reusable mathematical functions for KRONOS.
//
// NOTE:
// No trading logic is permitted here.
//==================================================================

//==================================================================
// KR-271.10 TRUE RANGE
//==================================================================

calcTrueRange(float highPrice, float lowPrice, float previousClose) =>
    math.max(
        highPrice - lowPrice,
        math.max(
            math.abs(highPrice - previousClose),
            math.abs(lowPrice - previousClose)
        )
    )

//==================================================================
// KR-271.20 AVERAGE TRUE RANGE
//==================================================================

const int ATR_PERIOD = 14

//==================================================================
// KR-271.21 TRUE RANGE SERIES
//==================================================================

// Primary
float indPrimaryTrueRange = calcTrueRange(mdPrimaryTrendH, mdPrimaryTrendL, mdPrimaryTrendC[1])

// Reference
float indReferenceTrueRange = calcTrueRange(mdReferenceTrendH, mdReferenceTrendL, mdReferenceTrendC[1])

//==================================================================
// KR-271.22 ATR SERIES
//==================================================================

// Primary
float indPrimaryTrendATR = ta.rma(indPrimaryTrueRange, ATR_PERIOD)

// Reference
float indReferenceTrendATR = ta.rma(indReferenceTrueRange, ATR_PERIOD)

//==================================================================
// KR-271.30 DIRECTIONAL MOVEMENT
//==================================================================

calcPlusDM(float currentHigh, float previousHigh, float currentLow, float previousLow) =>
    float upMove = currentHigh - previousHigh
    float downMove = previousLow - currentLow
    (upMove > downMove and upMove > 0.0) ? upMove : 0.0

calcMinusDM(float currentHigh, float previousHigh, float currentLow, float previousLow) =>
    float upMove = currentHigh - previousHigh
    float downMove = previousLow - currentLow
    (downMove > upMove and downMove > 0.0) ? downMove : 0.0

//==================================================================
// KR-271.31 DIRECTIONAL MOVEMENT SERIES
//==================================================================

// Primary
float indPrimaryTrendPlusDM = calcPlusDM(mdPrimaryTrendH, mdPrimaryTrendH[1], mdPrimaryTrendL, mdPrimaryTrendL[1])
float indPrimaryTrendMinusDM = calcMinusDM(mdPrimaryTrendH, mdPrimaryTrendH[1], mdPrimaryTrendL, mdPrimaryTrendL[1])

// Reference
float indReferenceTrendPlusDM = calcPlusDM(mdReferenceTrendH, mdReferenceTrendH[1], mdReferenceTrendL, mdReferenceTrendL[1])
float indReferenceTrendMinusDM = calcMinusDM(mdReferenceTrendH, mdReferenceTrendH[1], mdReferenceTrendL, mdReferenceTrendL[1])

//==================================================================
// KR-271.40 DIRECTIONAL INDEX
//==================================================================

calcPlusDI(series float smoothedPlusDM, series float atr) =>
    atr <= 0.0 ? 0.0 : 100.0 * smoothedPlusDM / atr

calcMinusDI(series float smoothedMinusDM, series float atr) =>
    atr <= 0.0 ? 0.0 : 100.0 * smoothedMinusDM / atr

float indPrimaryTrendPlusDMSmoothed = ta.rma(indPrimaryTrendPlusDM, ATR_PERIOD)
float indPrimaryTrendMinusDMSmoothed = ta.rma(indPrimaryTrendMinusDM, ATR_PERIOD)
float indReferenceTrendPlusDMSmoothed = ta.rma(indReferenceTrendPlusDM, ATR_PERIOD)
float indReferenceTrendMinusDMSmoothed = ta.rma(indReferenceTrendMinusDM, ATR_PERIOD)

// Primary
float indPrimaryTrendPlusDI = calcPlusDI(indPrimaryTrendPlusDMSmoothed, indPrimaryTrendATR)
float indPrimaryTrendMinusDI = calcMinusDI(indPrimaryTrendMinusDMSmoothed, indPrimaryTrendATR)

// Reference
float indReferenceTrendPlusDI = calcPlusDI(indReferenceTrendPlusDMSmoothed, indReferenceTrendATR)
float indReferenceTrendMinusDI = calcMinusDI(indReferenceTrendMinusDMSmoothed, indReferenceTrendATR)

//==================================================================
// KR-271.50 TREND STRENGTH
//==================================================================

calcDX(series float plusDI, series float minusDI) =>
    float diSum = plusDI + minusDI
    diSum == 0.0 ? 0.0 : 100.0 * math.abs(plusDI - minusDI) / diSum

// Primary
float indPrimaryTrendDX = calcDX(indPrimaryTrendPlusDI, indPrimaryTrendMinusDI)
float indPrimaryTrendADX = ta.rma(indPrimaryTrendDX, ATR_PERIOD)

// Reference
float indReferenceTrendDX = calcDX(indReferenceTrendPlusDI, indReferenceTrendMinusDI)
float indReferenceTrendADX = ta.rma(indReferenceTrendDX, ATR_PERIOD)

//==================================================================
// KR-275 : MARKET STRUCTURE INTELLIGENCE ENGINE
//==================================================================
//
// Version : 1.0.0
// Build   : 0009
// Status  : Release
//
// Purpose
// -------
// Detect, classify and maintain market structure.
//
// Dependencies
// ------------
// KR-260 Market Data Engine
// KR-271 Mathematical Library
//
// Consumes
// --------
// Primary Trend OHLC
//
// Produces
// --------
// Swing High
// Swing Low
//
// Higher High
// Higher Low
//
// Lower High
// Lower Low
//
// Bullish Structure
// Bearish Structure
//
// Bullish BOS
// Bearish BOS
//
// Bullish CHoCH
// Bearish CHoCH
//
// NOTE
// ----
// KR-275 performs no trading decisions.
//==================================================================

//==================================================================
// KR-275.10 CONFIGURATION
//==================================================================

const string GRP_STRUCTURE = "Market Structure"

inpStructureLeftBars = input.int(2, "Pivot Left", minval=1, maxval=10, group=GRP_STRUCTURE)

inpStructureRightBars = input.int(2, "Pivot Right", minval=1, maxval=10, group=GRP_STRUCTURE)

//==================================================================
// KR-275.20 PIVOT DETECTION
//==================================================================

float strPivotHigh = ta.pivothigh(mdPrimaryTrendH, inpStructureLeftBars, inpStructureRightBars)

float strPivotLow = ta.pivotlow(mdPrimaryTrendL, inpStructureLeftBars, inpStructureRightBars)

//==================================================================
// KR-275.30 SWING MEMORY
//==================================================================

var float strPreviousSwingHigh = na
var float strCurrentSwingHigh = na

var float strPreviousSwingLow = na
var float strCurrentSwingLow = na

if not na(strPivotHigh)
    strPreviousSwingHigh := strCurrentSwingHigh
    strCurrentSwingHigh := strPivotHigh

if not na(strPivotLow)
    strPreviousSwingLow := strCurrentSwingLow
    strCurrentSwingLow := strPivotLow

//==================================================================
// KR-275.40 SWING CLASSIFICATION
//==================================================================

//--------------------------------------------------
// Higher High / Lower High
//--------------------------------------------------

bool strHigherHigh = false
bool strLowerHigh  = false

if not na(strCurrentSwingHigh) and not na(strPreviousSwingHigh)
    strHigherHigh := strCurrentSwingHigh > strPreviousSwingHigh
    strLowerHigh  := strCurrentSwingHigh < strPreviousSwingHigh


//--------------------------------------------------
// Higher Low / Lower Low
//--------------------------------------------------

bool strHigherLow = false
bool strLowerLow  = false

if not na(strCurrentSwingLow) and not na(strPreviousSwingLow)
    strHigherLow := strCurrentSwingLow > strPreviousSwingLow
    strLowerLow  := strCurrentSwingLow < strPreviousSwingLow

//==================================================================
// KR-275.50 STRUCTURE CLASSIFICATION
//==================================================================

//--------------------------------------------------
// Structure States
//--------------------------------------------------

const int STR_BEARISH = -1
const int STR_NEUTRAL = 0
const int STR_BULLISH = 1

//--------------------------------------------------
// Persistent Structure State
//--------------------------------------------------

var int strStructureState = STR_NEUTRAL

if strHigherHigh and strHigherLow
    strStructureState := STR_BULLISH

if strLowerHigh and strLowerLow
    strStructureState := STR_BEARISH

//--------------------------------------------------
// Public Structure
//--------------------------------------------------

bool strBullishStructure = strStructureState == STR_BULLISH
bool strBearishStructure = strStructureState == STR_BEARISH
bool strNeutralStructure = strStructureState == STR_NEUTRAL

//==================================================================
// KR-275.60 BREAK OF STRUCTURE
//==================================================================

bool strBullishBOS = false
bool strBearishBOS = false

var bool strLastBullishBOS = false
var bool strLastBearishBOS = false

if not na(strCurrentSwingHigh)
    strBullishBOS := ta.crossover(mdPrimaryTrendC, strCurrentSwingHigh)

if strBullishBOS
    strLastBullishBOS := true
    strLastBearishBOS := false

if not na(strCurrentSwingLow)
    strBearishBOS := ta.crossunder(mdPrimaryTrendC, strCurrentSwingLow)

if strBearishBOS
    strLastBearishBOS := true
    strLastBullishBOS := false

//==================================================================
// KR-275.70 CHANGE OF CHARACTER
//==================================================================

bool strBullishCHoCH = false
bool strBearishCHoCH = false

strBullishCHoCH := strBearishStructure and strBullishBOS
strBearishCHoCH := strBullishStructure and strBearishBOS

//==================================================================
// KR-275.80 PUBLIC INTERFACE
//==================================================================

//--------------------------------------------------
// Structure
//--------------------------------------------------

int outStructureState = strStructureState

bool outBullishStructure = strBullishStructure
bool outBearishStructure = strBearishStructure
bool outNeutralStructure = strNeutralStructure

//--------------------------------------------------
// Swing Classification
//--------------------------------------------------

bool outHigherHigh = strHigherHigh
bool outHigherLow = strHigherLow

bool outLowerHigh = strLowerHigh
bool outLowerLow = strLowerLow

//--------------------------------------------------
// BOS
//--------------------------------------------------

bool outBullishBOS = strBullishBOS
bool outBearishBOS = strBearishBOS

//--------------------------------------------------
// CHoCH
//--------------------------------------------------

bool outBullishCHoCH = strBullishCHoCH
bool outBearishCHoCH = strBearishCHoCH

//--------------------------------------------------
// Persistent BOS
//--------------------------------------------------

bool outLastBullishBOS = strLastBullishBOS
bool outLastBearishBOS = strLastBearishBOS

//==================================================================
// KR-280 : CPR Intelligence Engine
// Version : 1.1.0
// Status  : FROZEN
// Last Updated : 2026-07-10
//
// Frozen Contract:
// - Core behavior is validated and should not be changed casually.
// - Future changes must be additive, compatibility-safe, or bug fixes.
// - No trading decisions/signals should be added inside this engine
//   unless that is the engine's explicit responsibility.
// - CPR reference behavior is validated against the preserved
//   legacy Auto mode.
//
// Validation Scope:
// - Legacy Auto-mode CPR reference behavior.
// - Previous completed reference OHLC feeds CPR, pivots, and
//   reference high/low/close outputs.
//==================================================================
//
// Purpose
// -------
// Calculate Central Pivot Range (CPR),
// Support/Resistance Levels,
// and CPR Intelligence.
//
// Dependencies
// ------------
// KR-260 Market Data Engine
//
// Consumes
// --------
// Previous Day OHLC
//
// Produces
// --------
// CPR
// Support
// Resistance
// CPR Intelligence
//
// NOTE
// ----
// KR-280 performs no trading decisions.
//==================================================================

//==================================================================
// KR-280.10 CONFIGURATION
//==================================================================

const string GRP_CPR = "CPR"

inpShowCPR          = input.bool(true, "Show CPR", group = GRP_CPR)
inpShowResistance   = input.bool(true, "Show Resistance", group = GRP_CPR)
inpShowSupport      = input.bool(true, "Show Support", group = GRP_CPR)
inpShowPreviousDay  = input.bool(true, "Show PDH / PDL", group = GRP_CPR)

// The preserved legacy Auto mode is the validated CPR reference standard.
// Manual modes remain available for comparison and diagnostics.
inpCPRReferenceMode = input.string("Auto KGS", "CPR Reference Mode", options = ["Auto KRONOS", "Auto KGS", "Daily", "Weekly", "Monthly"], group = GRP_CPR)

//==================================================================
// KR-280.15 REFERENCE PERIOD RESOLUTION
//==================================================================

string cprSourceTF = "D"
string cprReferencePeriod = "Daily"

if inpCPRReferenceMode == "Daily"
    cprSourceTF := "D"
    cprReferencePeriod := "Daily"
else if inpCPRReferenceMode == "Weekly"
    cprSourceTF := "W"
    cprReferencePeriod := "Weekly"
else if inpCPRReferenceMode == "Monthly"
    cprSourceTF := "M"
    cprReferencePeriod := "Monthly"
else if inpCPRReferenceMode == "Auto KGS"
    // Validated legacy Auto-mode CPR reference routing.
    if timeframe.isintraday
        if timeframe.multiplier <= 15
            cprSourceTF := "D"
            cprReferencePeriod := "Daily"
        else if timeframe.multiplier <= 75
            cprSourceTF := "W"
            cprReferencePeriod := "Weekly"
        else
            cprSourceTF := "M"
            cprReferencePeriod := "Monthly"
    else
        cprSourceTF := "M"
        cprReferencePeriod := "Monthly"
else
    if timeframe.isintraday
        if timeframe.multiplier <= 60
            cprSourceTF := "D"
            cprReferencePeriod := "Daily"
        else
            cprSourceTF := "W"
            cprReferencePeriod := "Weekly"
    else if timeframe.isdaily
        cprSourceTF := "D"
        cprReferencePeriod := "Daily"
    else if timeframe.isweekly
        cprSourceTF := "W"
        cprReferencePeriod := "Weekly"
    else
        cprSourceTF := "M"
        cprReferencePeriod := "Monthly"

//==================================================================
// KR-280.20 REFERENCE MARKET DATA
//==================================================================

float cprReferenceHigh = request.security(
    mdPrimarySymbol,
    cprSourceTF,
    high[1],
    gaps = barmerge.gaps_off,
    lookahead = barmerge.lookahead_on)

float cprReferenceLow = request.security(
    mdPrimarySymbol,
    cprSourceTF,
    low[1],
    gaps = barmerge.gaps_off,
    lookahead = barmerge.lookahead_on)

float cprReferenceClose = request.security(
    mdPrimarySymbol,
    cprSourceTF,
    close[1],
    gaps = barmerge.gaps_off,
    lookahead = barmerge.lookahead_on)

// Temporary compatibility aliases.
// KR-280.30+ continues to work unchanged.

float cprPreviousDayHigh  = cprReferenceHigh
float cprPreviousDayLow   = cprReferenceLow
float cprPreviousDayClose = cprReferenceClose

string outReferencePeriod = cprReferencePeriod

//==================================================================
// KR-280.30 CPR CALCULATION
//==================================================================

//--------------------------------------------------
// Central Pivot
//--------------------------------------------------

float cprCentralPivot = (cprReferenceHigh + cprReferenceLow + cprReferenceClose) / 3.0

//--------------------------------------------------
// Bottom Central
//--------------------------------------------------

float cprBottomCentral = (cprReferenceHigh + cprReferenceLow) / 2.0

//--------------------------------------------------
// Top Central
//--------------------------------------------------

float cprTopCentral = (2.0 * cprCentralPivot) - cprBottomCentral

//--------------------------------------------------
// Safety Normalization
//--------------------------------------------------

if cprTopCentral < cprBottomCentral
    float temp = cprTopCentral
    cprTopCentral := cprBottomCentral
    cprBottomCentral := temp


//==================================================================
// KR-280.40 SUPPORT & RESISTANCE
//==================================================================

//--------------------------------------------------
// Resistance Levels
//--------------------------------------------------

float cprResistance1 = (2.0 * cprCentralPivot) - cprReferenceLow

float cprResistance2 = cprCentralPivot + (cprReferenceHigh - cprReferenceLow)

float cprResistance3 = cprReferenceHigh + 2.0 * (cprCentralPivot - cprReferenceLow)

float cprResistance4 = cprResistance3 + (cprResistance2 - cprResistance1)

//--------------------------------------------------
// Support Levels
//--------------------------------------------------

float cprSupport1 = (2.0 * cprCentralPivot) - cprReferenceHigh

float cprSupport2 = cprCentralPivot - (cprReferenceHigh - cprReferenceLow)

float cprSupport3 = cprReferenceLow - 2.0 * (cprReferenceHigh - cprCentralPivot)

float cprSupport4 = cprSupport3 - (cprResistance1 - cprSupport1)


//==================================================================
// KR-280.50 PROFESSIONAL CHART RENDERER
//==================================================================
//
// Rendering only.
// No trading logic or calculations are performed here.
//
// All plots consume values produced by KR-280.30 and KR-280.60.
//
//==================================================================

//--------------------------------------------------
// Resistance
//--------------------------------------------------

plot(inpShowResistance ? cprResistance1 : na, title="R1", color=color.red, linewidth=2)

plot(inpShowResistance ? cprResistance2 : na, title="R2", color=color.red, linewidth=1, display=display.none)

plot(inpShowResistance ? cprResistance3 : na, title="R3", color=color.red, linewidth=1, display=display.none)

plot(inpShowResistance ? cprResistance4 : na, title="R4", color=color.red, linewidth=1, display=display.none)


//--------------------------------------------------
// CPR Zone
//--------------------------------------------------

plotTC = plot(
    inpShowCPR ? cprTopCentral : na,
    title="TC",
    color=color.blue,
    linewidth=1)

plotCP = plot(
    inpShowCPR ? cprCentralPivot : na,
    title="CP",
    color=color.blue,
    linewidth=3)

plotBC = plot(
    inpShowCPR ? cprBottomCentral : na,
    title="BC",
    color=color.blue,
    linewidth=1)

fill(
    plotTC,
    plotBC,
    color=color.new(color.blue, 93),
    title="CPR Zone")


//--------------------------------------------------
// Support
//--------------------------------------------------

plot(inpShowSupport ? cprSupport1 : na, title="S1", color=color.green, linewidth=2)

plot(inpShowSupport ? cprSupport2 : na, title="S2", color=color.green, linewidth=1, display=display.none)

plot(inpShowSupport ? cprSupport3 : na, title="S3", color=color.green, linewidth=1, display=display.none)

plot(inpShowSupport ? cprSupport4 : na, title="S4", color=color.green, linewidth=1, display=display.none)


//--------------------------------------------------
// Reference High / Low Levels
//--------------------------------------------------

plot(
    inpShowPreviousDay ? cprReferenceHigh : na,
    title="Reference High",
    color=color.white,
    linewidth=2)

plot(
    inpShowPreviousDay ? cprReferenceLow : na,
    title="Reference Low",
    color=color.white,
    linewidth=2)

//==================================================================
// KR-280.60 CPR INTELLIGENCE
//==================================================================
//
// This section derives contextual intelligence from the calculated
// CPR values. No rendering is performed here.
//
// Processing Order
// 1. CPR Width
// 2. Width Classification
// 3. Previous Reference CPR
// 4. CPR Relationship
// 5. Price Position
// 6. Virgin CPR
//

//==================================================================

//--------------------------------------------------
// CPR Width
//--------------------------------------------------

float cprWidth = math.abs(cprTopCentral - cprBottomCentral)

float cprWidthPercent = cprCentralPivot != 0.0 ? (cprWidth / cprCentralPivot) * 100.0 : 0.0

//--------------------------------------------------
// CPR Width Classification
//--------------------------------------------------

const int CPR_WIDTH_VERY_NARROW = 1
const int CPR_WIDTH_NARROW = 2
const int CPR_WIDTH_NORMAL = 3
const int CPR_WIDTH_WIDE = 4
const int CPR_WIDTH_VERY_WIDE = 5

var int cprWidthState = CPR_WIDTH_NORMAL

if cprWidthPercent < 0.15
    cprWidthState := CPR_WIDTH_VERY_NARROW
else if cprWidthPercent < 0.30
    cprWidthState := CPR_WIDTH_NARROW
else if cprWidthPercent < 0.60
    cprWidthState := CPR_WIDTH_NORMAL
else if cprWidthPercent < 1.00
    cprWidthState := CPR_WIDTH_WIDE
else
    cprWidthState := CPR_WIDTH_VERY_WIDE

//--------------------------------------------------
// Width Description
//--------------------------------------------------

string cprWidthText = ""

switch cprWidthState
    CPR_WIDTH_VERY_NARROW => cprWidthText := "Very Narrow"
    CPR_WIDTH_NARROW      => cprWidthText := "Narrow"
    CPR_WIDTH_NORMAL      => cprWidthText := "Normal"
    CPR_WIDTH_WIDE        => cprWidthText := "Wide"
    CPR_WIDTH_VERY_WIDE   => cprWidthText := "Very Wide"


//--------------------------------------------------
// Previous CPR
//--------------------------------------------------

float cprPreviousCentralPivot = request.security(mdPrimarySymbol, cprSourceTF, (high + low + close) / 3.0, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)[2]

float cprPreviousBottomCentral = request.security(mdPrimarySymbol, cprSourceTF, (high + low) / 2.0, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)[2]

float cprPreviousTopCentral = (2.0 * cprPreviousCentralPivot) - cprPreviousBottomCentral

if cprPreviousTopCentral < cprPreviousBottomCentral
    float tmp = cprPreviousTopCentral
    cprPreviousTopCentral := cprPreviousBottomCentral
    cprPreviousBottomCentral := tmp

//--------------------------------------------------
// CPR Relationship States
//--------------------------------------------------

const int CPR_REL_UNKNOWN = 0
const int CPR_REL_INSIDE = 1
const int CPR_REL_OUTSIDE = 2
const int CPR_REL_OVERLAP_HIGHER = 3
const int CPR_REL_OVERLAP_LOWER = 4
const int CPR_REL_UNCHANGED = 5

var int cprRelationshipState = CPR_REL_UNKNOWN

//--------------------------------------------------
// CPR Relationship Detection
//--------------------------------------------------

float cprTolerance = cprCentralPivot * 0.0001

bool cprUnchanged = math.abs(cprCentralPivot - cprPreviousCentralPivot) <= cprTolerance

bool cprInside = cprTopCentral <= cprPreviousTopCentral and cprBottomCentral >= cprPreviousBottomCentral

bool cprOutside = cprTopCentral >= cprPreviousTopCentral and cprBottomCentral <= cprPreviousBottomCentral

if cprUnchanged
    cprRelationshipState := CPR_REL_UNCHANGED
else if cprInside
    cprRelationshipState := CPR_REL_INSIDE
else if cprOutside
    cprRelationshipState := CPR_REL_OUTSIDE
else if cprCentralPivot > cprPreviousCentralPivot
    cprRelationshipState := CPR_REL_OVERLAP_HIGHER
else
    cprRelationshipState := CPR_REL_OVERLAP_LOWER

//--------------------------------------------------
// CPR Relationship Text
//--------------------------------------------------

string cprRelationshipText = ""

switch cprRelationshipState
    CPR_REL_INSIDE           => cprRelationshipText := "Inside CPR"
    CPR_REL_OUTSIDE          => cprRelationshipText := "Outside CPR"
    CPR_REL_OVERLAP_HIGHER   => cprRelationshipText := "Overlapping Higher"
    CPR_REL_OVERLAP_LOWER    => cprRelationshipText := "Overlapping Lower"
    CPR_REL_UNCHANGED        => cprRelationshipText := "Unchanged"
    => cprRelationshipText := "Unknown"

//--------------------------------------------------
// Price Position
//--------------------------------------------------

const int CPR_PRICE_BELOW = 1
const int CPR_PRICE_INSIDE = 2
const int CPR_PRICE_ABOVE = 3

var int cprPriceState = CPR_PRICE_INSIDE

if close > cprTopCentral
    cprPriceState := CPR_PRICE_ABOVE
else if close < cprBottomCentral
    cprPriceState := CPR_PRICE_BELOW
else
    cprPriceState := CPR_PRICE_INSIDE

bool cprPriceAbove = cprPriceState == CPR_PRICE_ABOVE
bool cprPriceInside = cprPriceState == CPR_PRICE_INSIDE
bool cprPriceBelow = cprPriceState == CPR_PRICE_BELOW

string cprPriceText = ""

switch cprPriceState
    CPR_PRICE_ABOVE => cprPriceText := "Above CPR"
    CPR_PRICE_INSIDE => cprPriceText := "Inside CPR"
    CPR_PRICE_BELOW => cprPriceText := "Below CPR"


//--------------------------------------------------
// Virgin CPR
//--------------------------------------------------

bool cprVirgin = low > cprTopCentral or high < cprBottomCentral


//==================================================================
// KR-280.70 PUBLIC INTERFACE
//==================================================================

//--------------------------------------------------
// CPR Values
//--------------------------------------------------

float outCentralPivot = cprCentralPivot
float outTopCentral = cprTopCentral
float outBottomCentral = cprBottomCentral

//--------------------------------------------------
// Resistance
//--------------------------------------------------

float outResistance1 = cprResistance1
float outResistance2 = cprResistance2
float outResistance3 = cprResistance3
float outResistance4 = cprResistance4

//--------------------------------------------------
// Support
//--------------------------------------------------

float outSupport1 = cprSupport1
float outSupport2 = cprSupport2
float outSupport3 = cprSupport3
float outSupport4 = cprSupport4

//--------------------------------------------------
// Previous Day
//--------------------------------------------------

float outPreviousDayHigh = cprReferenceHigh
float outPreviousDayLow = cprReferenceLow
float outPreviousDayClose = cprReferenceClose

//--------------------------------------------------
// CPR Width
//--------------------------------------------------

float outCPRWidth = cprWidth
float outCPRWidthPercent = cprWidthPercent

int outCPRWidthState = cprWidthState

string outCPRWidthText = cprWidthText

//--------------------------------------------------
// CPR Relationship
//--------------------------------------------------

int outCPRRelationshipState = cprRelationshipState

string outCPRRelationshipText = cprRelationshipText

bool outInsideCPR = cprRelationshipState == CPR_REL_INSIDE
bool outOutsideCPR = cprRelationshipState == CPR_REL_OUTSIDE
bool outOverlappingHigherCPR = cprRelationshipState == CPR_REL_OVERLAP_HIGHER
bool outOverlappingLowerCPR = cprRelationshipState == CPR_REL_OVERLAP_LOWER
bool outUnchangedCPR = cprRelationshipState == CPR_REL_UNCHANGED

//--------------------------------------------------
// Price Position
//--------------------------------------------------

int outPriceState = cprPriceState

string outPriceText = cprPriceText

bool outPriceAboveCPR = cprPriceAbove
bool outPriceInsideCPR = cprPriceInside
bool outPriceBelowCPR = cprPriceBelow

//--------------------------------------------------
// Virgin CPR
//--------------------------------------------------

bool outVirginCPR = cprVirgin



//==================================================================
// KR-280 Closing Metadata
//==================================================================
//
// Canonical module version/status is declared in the KR-280 banner.
// Historical duplicate version comments were removed during source
// metadata reconciliation. KR-280 v1.1.0 remains the production
// freeze baseline with legacy Auto-mode CPR reference behavior.
//
//==================================================================

//==================================================================
// END OF KR-280
//==================================================================



//==================================================================
// KR-300 : Trend Foundation Engine
// Version : 1.1.0
// Status  : FROZEN
// Last Updated : 2026-07-10
//
// Validation Scope:
// - Intelligence core freeze validation on Copper, Gold, and Silver.
//
// Frozen Contract:
// - Owns trend direction and stage only.
// - Uses existing market-data and SMA interfaces.
// - No trend quality, acceptance, execution timing, alerts, or
//   trade-management logic.
//==================================================================
//
// Purpose
// -------
// Classify the local trend foundation using staged moving average
// alignment and price position.
//
// Dependencies
// ------------
// KR-260 Market Data Engine
// KR-270 Market Indicator Engine
//
// Consumes
// --------
// Primary Trend Close
// Primary Trend SMA 20
// Primary Trend SMA 50
// Primary Trend SMA 200
//
// Produces
// --------
// Local Trend State
// Trend Stage
// SMA Alignment
// Price Position
//
// NOTE
// ----
// KR-300 performs no trading decisions.
//==================================================================

//==================================================================
// KR-300.10 TREND STATE CONSTANTS
//==================================================================

const int TREND_BEARISH = -1
const int TREND_NEUTRAL = 0
const int TREND_BULLISH = 1

const int TREND_ALIGNMENT_BEARISH = -1
const int TREND_ALIGNMENT_MIXED = 0
const int TREND_ALIGNMENT_BULLISH = 1

const int TREND_PRICE_BELOW = -1
const int TREND_PRICE_INSIDE = 0
const int TREND_PRICE_ABOVE = 1

const int TREND_STAGE_CONFIRMED_BEARISH = -2
const int TREND_STAGE_DEVELOPING_BEARISH = -1
const int TREND_STAGE_NEUTRAL = 0
const int TREND_STAGE_DEVELOPING_BULLISH = 1
const int TREND_STAGE_CONFIRMED_BULLISH = 2

//==================================================================
// KR-300.20 SMA ALIGNMENT ENGINE
//==================================================================

bool trendDataReady = not na(mdPrimaryTrendC) and not na(indPrimaryTrendSMA20) and not na(indPrimaryTrendSMA50) and not na(indPrimaryTrendSMA200)

bool trendBullishSMAAlignment = trendDataReady and indPrimaryTrendSMA20 > indPrimaryTrendSMA50 and indPrimaryTrendSMA50 > indPrimaryTrendSMA200

bool trendBearishSMAAlignment = trendDataReady and indPrimaryTrendSMA20 < indPrimaryTrendSMA50 and indPrimaryTrendSMA50 < indPrimaryTrendSMA200

bool trendMixedSMAAlignment = trendDataReady and not trendBullishSMAAlignment and not trendBearishSMAAlignment

int trendSMAAlignmentState = TREND_ALIGNMENT_MIXED

if trendBullishSMAAlignment
    trendSMAAlignmentState := TREND_ALIGNMENT_BULLISH
else if trendBearishSMAAlignment
    trendSMAAlignmentState := TREND_ALIGNMENT_BEARISH
else
    trendSMAAlignmentState := TREND_ALIGNMENT_MIXED

string trendSMAAlignmentText = ""

switch trendSMAAlignmentState
    TREND_ALIGNMENT_BULLISH => trendSMAAlignmentText := "Bullish SMA Alignment"
    TREND_ALIGNMENT_BEARISH => trendSMAAlignmentText := "Bearish SMA Alignment"
    => trendSMAAlignmentText := "Mixed SMA Alignment"

//==================================================================
// KR-300.30 PRICE POSITION ENGINE
//==================================================================

bool trendPriceAboveSMA20 = trendDataReady and mdPrimaryTrendC > indPrimaryTrendSMA20
bool trendPriceAboveSMA50 = trendDataReady and mdPrimaryTrendC > indPrimaryTrendSMA50
bool trendPriceAboveSMA200 = trendDataReady and mdPrimaryTrendC > indPrimaryTrendSMA200

bool trendPriceBelowSMA20 = trendDataReady and mdPrimaryTrendC < indPrimaryTrendSMA20
bool trendPriceBelowSMA50 = trendDataReady and mdPrimaryTrendC < indPrimaryTrendSMA50
bool trendPriceBelowSMA200 = trendDataReady and mdPrimaryTrendC < indPrimaryTrendSMA200

bool trendPriceAboveSMAStack = trendPriceAboveSMA20 and trendPriceAboveSMA50 and trendPriceAboveSMA200

bool trendPriceBelowSMAStack = trendPriceBelowSMA20 and trendPriceBelowSMA50 and trendPriceBelowSMA200

bool trendPriceInsideSMAStack = trendDataReady and not trendPriceAboveSMAStack and not trendPriceBelowSMAStack

int trendPricePositionState = TREND_PRICE_INSIDE

if trendPriceAboveSMAStack
    trendPricePositionState := TREND_PRICE_ABOVE
else if trendPriceBelowSMAStack
    trendPricePositionState := TREND_PRICE_BELOW
else
    trendPricePositionState := TREND_PRICE_INSIDE

string trendPricePositionText = ""

switch trendPricePositionState
    TREND_PRICE_ABOVE => trendPricePositionText := "Above SMA Stack"
    TREND_PRICE_BELOW => trendPricePositionText := "Below SMA Stack"
    => trendPricePositionText := "Inside SMA Stack"

//==================================================================
// KR-300.40 STAGED TREND CLASSIFICATION
//==================================================================

bool trendConfirmedBullishFoundation = trendBullishSMAAlignment and trendPriceAboveSMAStack
bool trendConfirmedBearishFoundation = trendBearishSMAAlignment and trendPriceBelowSMAStack

bool trendBullishSMA20SMA50Pressure = trendDataReady and indPrimaryTrendSMA20 > indPrimaryTrendSMA50
bool trendBearishSMA20SMA50Pressure = trendDataReady and indPrimaryTrendSMA20 < indPrimaryTrendSMA50

bool trendBullishPricePressure = trendPriceAboveSMA20 and trendPriceAboveSMA50
bool trendBearishPricePressure = trendPriceBelowSMA20 and trendPriceBelowSMA50

bool trendDevelopingBullishFoundation = trendDataReady and not trendConfirmedBullishFoundation and trendBullishSMA20SMA50Pressure and (trendBullishPricePressure or trendPriceAboveSMAStack or trendBullishSMAAlignment)
bool trendDevelopingBearishFoundation = trendDataReady and not trendConfirmedBearishFoundation and trendBearishSMA20SMA50Pressure and (trendBearishPricePressure or trendPriceBelowSMAStack or trendBearishSMAAlignment)

int trendStageState = TREND_STAGE_NEUTRAL

if trendConfirmedBullishFoundation
    trendStageState := TREND_STAGE_CONFIRMED_BULLISH
else if trendConfirmedBearishFoundation
    trendStageState := TREND_STAGE_CONFIRMED_BEARISH
else if trendDevelopingBullishFoundation
    trendStageState := TREND_STAGE_DEVELOPING_BULLISH
else if trendDevelopingBearishFoundation
    trendStageState := TREND_STAGE_DEVELOPING_BEARISH
else
    trendStageState := TREND_STAGE_NEUTRAL

string trendStageText = ""

switch trendStageState
    TREND_STAGE_CONFIRMED_BULLISH => trendStageText := "Confirmed Bullish"
    TREND_STAGE_DEVELOPING_BULLISH => trendStageText := "Developing Bullish"
    TREND_STAGE_DEVELOPING_BEARISH => trendStageText := "Developing Bearish"
    TREND_STAGE_CONFIRMED_BEARISH => trendStageText := "Confirmed Bearish"
    => trendStageText := "Neutral"

//==================================================================
// KR-300.50 LOCAL TREND CLASSIFICATION
//==================================================================

bool trendBullishFoundation = trendStageState == TREND_STAGE_CONFIRMED_BULLISH or trendStageState == TREND_STAGE_DEVELOPING_BULLISH
bool trendBearishFoundation = trendStageState == TREND_STAGE_CONFIRMED_BEARISH or trendStageState == TREND_STAGE_DEVELOPING_BEARISH
bool trendNeutralFoundation = trendDataReady and not trendBullishFoundation and not trendBearishFoundation

int trendLocalState = TREND_NEUTRAL

if trendBullishFoundation
    trendLocalState := TREND_BULLISH
else if trendBearishFoundation
    trendLocalState := TREND_BEARISH
else
    trendLocalState := TREND_NEUTRAL

string trendLocalText = ""

switch trendLocalState
    TREND_BULLISH => trendLocalText := trendStageText
    TREND_BEARISH => trendLocalText := trendStageText
    => trendLocalText := "Neutral Trend Foundation"

//==================================================================
// KR-300.60 PUBLIC INTERFACE
//==================================================================

//--------------------------------------------------
// Availability
//--------------------------------------------------

bool outTrendDataReady = trendDataReady

//--------------------------------------------------
// Local Trend
//--------------------------------------------------

int outLocalTrendState = trendLocalState

string outLocalTrendText = trendLocalText

bool outBullishTrend = trendLocalState == TREND_BULLISH
bool outBearishTrend = trendLocalState == TREND_BEARISH
bool outNeutralTrend = trendLocalState == TREND_NEUTRAL

//--------------------------------------------------
// Trend Stage
//--------------------------------------------------

string outTrendStageText = trendStageText

bool outDevelopingBullishTrend = trendStageState == TREND_STAGE_DEVELOPING_BULLISH
bool outConfirmedBullishTrend = trendStageState == TREND_STAGE_CONFIRMED_BULLISH
bool outDevelopingBearishTrend = trendStageState == TREND_STAGE_DEVELOPING_BEARISH
bool outConfirmedBearishTrend = trendStageState == TREND_STAGE_CONFIRMED_BEARISH

//--------------------------------------------------
// SMA Alignment
//--------------------------------------------------

int outTrendSMAAlignmentState = trendSMAAlignmentState

string outTrendSMAAlignmentText = trendSMAAlignmentText

bool outBullishSMAAlignment = trendBullishSMAAlignment
bool outBearishSMAAlignment = trendBearishSMAAlignment
bool outMixedSMAAlignment = trendMixedSMAAlignment

//--------------------------------------------------
// Price Position
//--------------------------------------------------

int outTrendPricePositionState = trendPricePositionState

string outTrendPricePositionText = trendPricePositionText

bool outTrendPriceAboveSMA20 = trendPriceAboveSMA20
bool outTrendPriceAboveSMA50 = trendPriceAboveSMA50
bool outTrendPriceAboveSMA200 = trendPriceAboveSMA200

bool outTrendPriceBelowSMA20 = trendPriceBelowSMA20
bool outTrendPriceBelowSMA50 = trendPriceBelowSMA50
bool outTrendPriceBelowSMA200 = trendPriceBelowSMA200

bool outTrendPriceAboveSMAStack = trendPriceAboveSMAStack
bool outTrendPriceInsideSMAStack = trendPriceInsideSMAStack
bool outTrendPriceBelowSMAStack = trendPriceBelowSMAStack

//==================================================================
// END OF KR-300
//==================================================================



//==================================================================
// KR-310 : Trend Quality Engine
// Version : 1.0.0
// Status  : FROZEN
// Last Updated : 2026-07-10
//
// Validation Scope:
// - Intelligence core freeze validation on Copper, Gold, and Silver.
//
// Frozen Contract:
// - Owns trend quality and extension only.
// - Consumes KR-300 direction without reversing it.
// - No opportunity, execution timing, alerts, or trade-management
//   logic.
//==================================================================
//
// Purpose
// -------
// Evaluate the quality of the KR-300 trend foundation without
// changing or reversing the trend direction.
//
// Dependencies
// ------------
// KR-300 Trend Foundation Engine
// KR-270 Market Indicator Engine
// KR-271 Mathematical Library
//
// Consumes
// --------
// KR-300 Trend Direction
// Primary Trend SMA20
// Primary Trend SMA50
// Primary Trend RSI
// Primary Trend ATR
//
// Produces
// --------
// Trend Quality State
// Trend Quality Score
//
// NOTE
// ----
// KR-310 performs no rendering, alerts, signals or trading decisions.
// KR-310 never changes trend direction produced by KR-300.
//==================================================================

//==================================================================
// KR-310.10 TREND QUALITY STATE CONSTANTS
//==================================================================

const int KR310_TREND_QUALITY_EXTENDED  = -1
const int KR310_TREND_QUALITY_NEUTRAL   = 0
const int KR310_TREND_QUALITY_WEAK      = 1
const int KR310_TREND_QUALITY_HEALTHY   = 2
const int KR310_TREND_QUALITY_EXCELLENT = 3

//==================================================================
// KR-310.20 INPUT READINESS
//==================================================================

bool trendQualityInputReady = outTrendDataReady and not outNeutralTrend and not na(mdPrimaryTrendC) and not na(mdPrimaryTrendH) and not na(mdPrimaryTrendL) and not na(indPrimaryTrendSMA20) and not na(indPrimaryTrendSMA50) and not na(indPrimaryTrendRSI) and not na(indPrimaryTrendATR)

bool trendQualityBullishDirection = trendQualityInputReady and outBullishTrend
bool trendQualityBearishDirection = trendQualityInputReady and outBearishTrend

//==================================================================
// KR-310.30 SMA SLOPE QUALITY
//==================================================================

bool trendQualitySMA20SlopeUp = trendQualityInputReady and indPrimaryTrendSMA20 > indPrimaryTrendSMA20[1]
bool trendQualitySMA50SlopeUp = trendQualityInputReady and indPrimaryTrendSMA50 > indPrimaryTrendSMA50[1]
bool trendQualitySMA20SlopeDown = trendQualityInputReady and indPrimaryTrendSMA20 < indPrimaryTrendSMA20[1]
bool trendQualitySMA50SlopeDown = trendQualityInputReady and indPrimaryTrendSMA50 < indPrimaryTrendSMA50[1]

bool trendQualitySlopeAligned = (trendQualityBullishDirection and trendQualitySMA20SlopeUp and trendQualitySMA50SlopeUp) or (trendQualityBearishDirection and trendQualitySMA20SlopeDown and trendQualitySMA50SlopeDown)

//==================================================================
// KR-310.40 RAILWAY TRACK QUALITY
//==================================================================

float trendQualitySMA20SMA50Spread = math.abs(indPrimaryTrendSMA20 - indPrimaryTrendSMA50)
float trendQualityPreviousSMA20SMA50Spread = math.abs(indPrimaryTrendSMA20[1] - indPrimaryTrendSMA50[1])
float trendQualityRailwayDrift = math.abs(trendQualitySMA20SMA50Spread - trendQualityPreviousSMA20SMA50Spread)

bool trendQualityRailwayOrdered = (trendQualityBullishDirection and indPrimaryTrendSMA20 > indPrimaryTrendSMA50) or (trendQualityBearishDirection and indPrimaryTrendSMA20 < indPrimaryTrendSMA50)
bool trendQualityRailwaySeparated = trendQualityInputReady and trendQualitySMA20SMA50Spread >= indPrimaryTrendATR * 0.10
bool trendQualityRailwayStable = trendQualityInputReady and trendQualityRailwayDrift <= indPrimaryTrendATR * 0.35
bool trendQualityRailwayTrack = trendQualityRailwayOrdered and trendQualityRailwaySeparated and trendQualityRailwayStable

//==================================================================
// KR-310.50 EXTENSION QUALITY
//==================================================================

float trendQualityDistanceFromSMA20 = math.abs(mdPrimaryTrendC - indPrimaryTrendSMA20)

bool trendQualityPriceExtended = trendQualityInputReady and trendQualityDistanceFromSMA20 > indPrimaryTrendATR * 2.00
bool trendQualityRSIExtended = (trendQualityBullishDirection and indPrimaryTrendRSI >= 70.0) or (trendQualityBearishDirection and indPrimaryTrendRSI <= 30.0)
bool trendQualityExtended = trendQualityPriceExtended or trendQualityRSIExtended

//==================================================================
// KR-310.60 PULLBACK RESPECT
//==================================================================

float trendQualityPullbackTolerance = indPrimaryTrendATR * 0.25

bool trendQualityBullishSMA20Respect = trendQualityBullishDirection and mdPrimaryTrendL <= indPrimaryTrendSMA20 + trendQualityPullbackTolerance and mdPrimaryTrendC > indPrimaryTrendSMA20
bool trendQualityBullishSMA50Respect = trendQualityBullishDirection and mdPrimaryTrendL <= indPrimaryTrendSMA50 + trendQualityPullbackTolerance and mdPrimaryTrendC > indPrimaryTrendSMA50
bool trendQualityBearishSMA20Respect = trendQualityBearishDirection and mdPrimaryTrendH >= indPrimaryTrendSMA20 - trendQualityPullbackTolerance and mdPrimaryTrendC < indPrimaryTrendSMA20
bool trendQualityBearishSMA50Respect = trendQualityBearishDirection and mdPrimaryTrendH >= indPrimaryTrendSMA50 - trendQualityPullbackTolerance and mdPrimaryTrendC < indPrimaryTrendSMA50
bool trendQualityPullbackRespect = trendQualityBullishSMA20Respect or trendQualityBullishSMA50Respect or trendQualityBearishSMA20Respect or trendQualityBearishSMA50Respect

//==================================================================
// KR-310.70 TREND QUALITY SCORE
//==================================================================

int trendQualityScore = 0

if trendQualityInputReady and trendQualitySlopeAligned
    trendQualityScore += 1

if trendQualityInputReady and trendQualityRailwayTrack
    trendQualityScore += 1

if trendQualityInputReady and trendQualityPullbackRespect
    trendQualityScore += 1

//==================================================================
// KR-310.80 TREND QUALITY CLASSIFICATION
//==================================================================

int trendQualityState = KR310_TREND_QUALITY_NEUTRAL

if not trendQualityInputReady
    trendQualityState := KR310_TREND_QUALITY_NEUTRAL
else if trendQualityExtended
    trendQualityState := KR310_TREND_QUALITY_EXTENDED
else if trendQualityScore >= 3
    trendQualityState := KR310_TREND_QUALITY_EXCELLENT
else if trendQualityScore == 2
    trendQualityState := KR310_TREND_QUALITY_HEALTHY
else
    trendQualityState := KR310_TREND_QUALITY_WEAK

string trendQualityText = ""

switch trendQualityState
    KR310_TREND_QUALITY_EXCELLENT => trendQualityText := "Excellent Trend Quality"
    KR310_TREND_QUALITY_HEALTHY => trendQualityText := "Healthy Trend Quality"
    KR310_TREND_QUALITY_WEAK => trendQualityText := "Weak Trend Quality"
    KR310_TREND_QUALITY_EXTENDED => trendQualityText := "Extended / Wait for Pullback"
    => trendQualityText := "Neutral / Not Applicable"

//==================================================================
// KR-310.90 PUBLIC INTERFACE
//==================================================================

int outTrendQualityState = trendQualityState

string outTrendQualityText = trendQualityText

int outTrendQualityScore = trendQualityScore

bool outTrendQualityExcellent = trendQualityState == KR310_TREND_QUALITY_EXCELLENT
bool outTrendQualityHealthy = trendQualityState == KR310_TREND_QUALITY_HEALTHY
bool outTrendQualityWeak = trendQualityState == KR310_TREND_QUALITY_WEAK
bool outTrendQualityExtended = trendQualityState == KR310_TREND_QUALITY_EXTENDED

//--------------------------------------------------
// Compatibility Interface
//--------------------------------------------------

bool outEvidenceReady = trendQualityInputReady

int outEvidenceState = trendQualityState > KR310_TREND_QUALITY_NEUTRAL ? outLocalTrendState : TREND_NEUTRAL

string outEvidenceText = trendQualityText

bool outBullishEvidence = trendQualityInputReady and outBullishTrend and trendQualityState > KR310_TREND_QUALITY_NEUTRAL
bool outBearishEvidence = trendQualityInputReady and outBearishTrend and trendQualityState > KR310_TREND_QUALITY_NEUTRAL
bool outNeutralEvidence = not outBullishEvidence and not outBearishEvidence

//==================================================================
// END OF KR-310
//==================================================================



//==================================================================
// KR-315 : Compression Intelligence Engine
// Version : 1.0.0
// Status  : FROZEN
// Last Updated : 2026-07-09
//
// Frozen Contract:
// - Core behavior is validated and should not be changed casually.
// - Future changes must be additive, compatibility-safe, or bug fixes.
// - No trading decisions/signals should be added inside this engine
//   unless that is the engine's explicit responsibility.
// - Detects compression and expansion release only; does not predict direction.
//
// Validation Scope:
// - Compression core freeze validation on Copper, Gold, and Silver.
// - Non-repainting confirmed-bar expansion memory.
//==================================================================
//
// Purpose
// -------
// Detect whether the market is storing energy before a breakout or
// breakdown.
//
// Dependencies
// ------------
// KR-270 Market Indicator Engine
// KR-280 CPR Intelligence Engine
// KR-310 Trend Quality Engine
//
// Produces
// --------
// Compression State
// Compression Score
// Compression Reason
//
// NOTE
// ----
// KR-315 detects compression and expansion release only.
// It does not predict direction or generate trade signals.
// It performs no request.security calls and consumes only existing
// KRONOS current-symbol data interfaces.
//==================================================================

//==================================================================
// KR-315.10 COMPRESSION STATE CONSTANTS
//==================================================================

const int KR315_COMPRESSION_NONE = 0
const int KR315_COMPRESSION_BUILDING = 1
const int KR315_COMPRESSION_STRONG = 2
const int KR315_COMPRESSION_CRITICAL = 3
const int KR315_EXPANSION_STARTED = 4

//==================================================================
// KR-315.20 INPUT READINESS
//==================================================================

float compressionATRAverage = ta.sma(indPrimaryTrendATR, 20)
float compressionVolumeAverage = ta.sma(mdPrimaryTrendV, 20)
float compressionRecentHigh = ta.highest(mdPrimaryTrendH[1], 10)
float compressionRecentLow = ta.lowest(mdPrimaryTrendL[1], 10)
float compressionCurrentRangeHigh = ta.highest(mdPrimaryTrendH, 10)
float compressionCurrentRangeLow = ta.lowest(mdPrimaryTrendL, 10)
float compressionPriorRangeHigh = ta.highest(mdPrimaryTrendH[10], 10)
float compressionPriorRangeLow = ta.lowest(mdPrimaryTrendL[10], 10)

bool compressionInputReady = not na(mdPrimaryTrendO) and not na(mdPrimaryTrendH) and not na(mdPrimaryTrendL) and not na(mdPrimaryTrendC) and not na(indPrimaryTrendATR) and not na(compressionATRAverage) and not na(indPrimaryTrendSMA20) and not na(indPrimaryTrendSMA50) and not na(indPrimaryTrendSMA200) and not na(indPrimaryTrendRSI) and not na(outCPRWidthPercent) and not na(outCPRWidthState) and indPrimaryTrendATR > 0.0
bool compressionVolumeReady = compressionInputReady and not na(mdPrimaryTrendV) and not na(compressionVolumeAverage) and compressionVolumeAverage > 0.0
bool compressionStructureReady = compressionInputReady and not na(compressionRecentHigh) and not na(compressionRecentLow) and not na(compressionCurrentRangeHigh) and not na(compressionCurrentRangeLow) and not na(compressionPriorRangeHigh) and not na(compressionPriorRangeLow)

//==================================================================
// KR-315.30 EVIDENCE SCORES
//==================================================================

int compressionCPRScore = 0

if compressionInputReady and outCPRWidthState == CPR_WIDTH_VERY_NARROW
    compressionCPRScore := 25
else if compressionInputReady and outCPRWidthState == CPR_WIDTH_NARROW
    compressionCPRScore := 18
else if compressionInputReady and outCPRWidthState == CPR_WIDTH_NORMAL
    compressionCPRScore := 8
else
    compressionCPRScore := 0

int compressionATRScore = 0

if compressionInputReady and indPrimaryTrendATR <= compressionATRAverage * 0.80
    compressionATRScore := 20
else if compressionInputReady and indPrimaryTrendATR < compressionATRAverage
    compressionATRScore := 12
else
    compressionATRScore := 0

float compressionSMAMax = math.max(indPrimaryTrendSMA20, math.max(indPrimaryTrendSMA50, indPrimaryTrendSMA200))
float compressionSMAMin = math.min(indPrimaryTrendSMA20, math.min(indPrimaryTrendSMA50, indPrimaryTrendSMA200))
float compressionSMASpread = compressionSMAMax - compressionSMAMin

int compressionSMAScore = 0

if compressionInputReady and compressionSMASpread < indPrimaryTrendATR * 1.50
    compressionSMAScore := 20
else if compressionInputReady and compressionSMASpread < indPrimaryTrendATR * 2.50
    compressionSMAScore := 12
else
    compressionSMAScore := 0

int compressionVolumeScore = 0

if compressionVolumeReady and mdPrimaryTrendV <= compressionVolumeAverage * 0.80
    compressionVolumeScore := 15
else if compressionVolumeReady and mdPrimaryTrendV < compressionVolumeAverage
    compressionVolumeScore := 8
else
    compressionVolumeScore := 0

float compressionCurrentStructureRange = compressionCurrentRangeHigh - compressionCurrentRangeLow
float compressionPriorStructureRange = compressionPriorRangeHigh - compressionPriorRangeLow

int compressionStructureScore = 0

if compressionStructureReady and compressionCurrentStructureRange < compressionPriorStructureRange
    compressionStructureScore := 10
else
    compressionStructureScore := 0

int compressionRSIScore = 0

if compressionInputReady and indPrimaryTrendRSI >= 45.0 and indPrimaryTrendRSI <= 55.0
    compressionRSIScore := 10
else if compressionInputReady and indPrimaryTrendRSI >= 40.0 and indPrimaryTrendRSI <= 60.0
    compressionRSIScore := 5
else
    compressionRSIScore := 0

//==================================================================
// KR-315.40 SCORE AND EXPANSION RELEASE
//==================================================================

int compressionRawScore = compressionCPRScore + compressionATRScore + compressionSMAScore + compressionVolumeScore + compressionStructureScore + compressionRSIScore
int compressionScore = math.max(0, math.min(100, compressionRawScore))

float compressionCandleRange = mdPrimaryTrendH - mdPrimaryTrendL
float compressionCandleBody = math.abs(mdPrimaryTrendC - mdPrimaryTrendO)
float compressionBodyRatio = compressionCandleRange > 0.0 ? compressionCandleBody / compressionCandleRange : 0.0

bool compressionPriorStrong = compressionInputReady and not na(compressionScore[1]) and compressionScore[1] >= 55
bool compressionRangeExpansion = compressionInputReady and compressionCandleRange > indPrimaryTrendATR * 1.25
bool compressionBreakout = compressionStructureReady and (mdPrimaryTrendC > compressionRecentHigh or mdPrimaryTrendC < compressionRecentLow)
bool compressionVolumeExpansion = compressionVolumeReady and mdPrimaryTrendV > compressionVolumeAverage * 1.20
bool compressionStrongCandle = compressionInputReady and compressionBodyRatio >= 0.50
bool compressionExpansionSupport = compressionVolumeReady ? compressionVolumeExpansion or compressionStrongCandle : compressionStrongCandle
bool compressionExpansionTrigger = barstate.isconfirmed and compressionPriorStrong and compressionRangeExpansion and compressionBreakout and compressionExpansionSupport

// Keep expansion release visible for exactly three confirmed bars.
var int compressionExpansionMemoryBars = 0

if compressionExpansionTrigger
    compressionExpansionMemoryBars := 3
else if barstate.isconfirmed and compressionExpansionMemoryBars > 0
    compressionExpansionMemoryBars -= 1

bool compressionExpansionMemoryActive = compressionExpansionMemoryBars > 0

//==================================================================
// KR-315.50 COMPRESSION CLASSIFICATION
//==================================================================

int compressionState = KR315_COMPRESSION_NONE

if not compressionInputReady
    compressionState := KR315_COMPRESSION_NONE
else if compressionExpansionMemoryActive
    compressionState := KR315_EXPANSION_STARTED
else if compressionScore >= 75
    compressionState := KR315_COMPRESSION_CRITICAL
else if compressionScore >= 55
    compressionState := KR315_COMPRESSION_STRONG
else if compressionScore >= 35
    compressionState := KR315_COMPRESSION_BUILDING
else
    compressionState := KR315_COMPRESSION_NONE

string compressionText = ""

switch compressionState
    KR315_EXPANSION_STARTED => compressionText := "Expansion Started"
    KR315_COMPRESSION_CRITICAL => compressionText := "Critical"
    KR315_COMPRESSION_STRONG => compressionText := "Strong"
    KR315_COMPRESSION_BUILDING => compressionText := "Building"
    => compressionText := "No Compression"

string compressionReasonText = ""

if compressionExpansionMemoryActive
    compressionReasonText := "Expansion Started"
else if compressionScore >= 75
    compressionReasonText := "Critical Compression"
else if compressionScore >= 55
    compressionReasonText := "Strong Compression"
else if compressionScore >= 35
    compressionReasonText := "Building Energy"
else
    compressionReasonText := "No Compression"

//==================================================================
// KR-315.60 PUBLIC INTERFACE
//==================================================================
//
// Public outputs are intentionally stable and additive. Downstream
// engines must consume these values instead of KR-315 internals.
//
// outCompressionReady         : KR-315 has enough data to score.
// outCompressionScore         : Clamped 0-100 compression score.
// outCompressionState         : Numeric compression state.
// outCompressionText          : Short display state.
// outCompressionReasonText    : Explainable reason label.
// outCompressionBuilding      : Building compression flag.
// outCompressionStrong        : Strong compression flag.
// outCompressionCritical      : Critical compression flag.
// outExpansionStarted         : Three-bar expansion release memory.
// outCompressionNoCompression : No compression flag.
//==================================================================

bool outCompressionReady = compressionInputReady

int outCompressionScore = compressionScore
int outCompressionState = compressionState

string outCompressionText = compressionText
string outCompressionReasonText = compressionReasonText

bool outCompressionBuilding = compressionState == KR315_COMPRESSION_BUILDING
bool outCompressionStrong = compressionState == KR315_COMPRESSION_STRONG
bool outCompressionCritical = compressionState == KR315_COMPRESSION_CRITICAL
bool outExpansionStarted = compressionExpansionMemoryActive
bool outCompressionNoCompression = compressionState == KR315_COMPRESSION_NONE

//==================================================================
// END OF KR-315
//==================================================================



//==================================================================
// KR-320 : Market Acceptance Engine
// Version : 1.0.0
// Status  : FROZEN
// Last Updated : 2026-07-10
//
// Validation Scope:
// - Intelligence core freeze validation on Copper, Gold, and Silver.
//
// Frozen Contract:
// - Owns CPR acceptance/rejection context only.
// - Consumes KR-280 CPR and KR-300 trend direction.
// - No trend decision, execution timing, alerts, or trade-management
//   logic.
//==================================================================
//
// Purpose
// -------
// Evaluate whether the market is accepting price beyond the CPR
// area in the direction of the KR-300 trend foundation.
//
// Dependencies
// ------------
// KR-280 CPR Intelligence Engine
// KR-300 Trend Foundation Engine
//
// Consumes
// --------
// KR-300 Trend Direction
// CPR Levels
// Previous Reference High / Low
// Primary Trend OHLC
// Primary Trend ATR
//
// Produces
// --------
// Market Acceptance State
// Market Acceptance Score
//
// NOTE
// ----
// KR-320 performs no rendering, alerts, signals or trading decisions.
//==================================================================

//==================================================================
// KR-320.10 ACCEPTANCE STATE CONSTANTS
//==================================================================

const int KR320_ACCEPTANCE_REJECTED = -1
const int KR320_ACCEPTANCE_NEUTRAL = 0
const int KR320_ACCEPTANCE_TESTING = 1
const int KR320_ACCEPTANCE_ACCEPTED = 2
const int KR320_ACCEPTANCE_STRONG = 3

const int KR320_BARRIER_BELOW = -1
const int KR320_BARRIER_INSIDE = 0
const int KR320_BARRIER_ABOVE = 1

//==================================================================
// KR-320.20 INPUT READINESS
//==================================================================

bool acceptanceInputReady = outTrendDataReady and not na(outCentralPivot) and not na(outTopCentral) and not na(outBottomCentral) and not na(outPreviousDayHigh) and not na(outPreviousDayLow) and not na(mdPrimaryTrendO) and not na(mdPrimaryTrendH) and not na(mdPrimaryTrendL) and not na(mdPrimaryTrendC) and not na(indPrimaryTrendATR)

bool acceptanceBullishDirection = acceptanceInputReady and outBullishTrend
bool acceptanceBearishDirection = acceptanceInputReady and outBearishTrend
bool acceptanceDirectional = acceptanceBullishDirection or acceptanceBearishDirection

//==================================================================
// KR-320.30 CPR ACCEPTANCE
//==================================================================

bool acceptanceAboveCPR = acceptanceInputReady and outPriceAboveCPR
bool acceptanceInsideCPR = acceptanceInputReady and outPriceInsideCPR
bool acceptanceBelowCPR = acceptanceInputReady and outPriceBelowCPR

bool acceptanceCPRBullish = acceptanceBullishDirection and acceptanceAboveCPR
bool acceptanceCPRBearish = acceptanceBearishDirection and acceptanceBelowCPR
bool acceptanceCPRAccepted = acceptanceCPRBullish or acceptanceCPRBearish
bool acceptanceCPRTesting = acceptanceInputReady and acceptanceDirectional and acceptanceInsideCPR
bool acceptanceCPRRejected = (acceptanceBullishDirection and acceptanceBelowCPR) or (acceptanceBearishDirection and acceptanceAboveCPR)

//==================================================================
// KR-320.40 BREAKOUT ACCEPTANCE
//==================================================================

bool acceptanceBullishBreakout = acceptanceBullishDirection and mdPrimaryTrendC > outPreviousDayHigh
bool acceptanceBearishBreakout = acceptanceBearishDirection and mdPrimaryTrendC < outPreviousDayLow
bool acceptanceBreakoutAccepted = acceptanceBullishBreakout or acceptanceBearishBreakout

//==================================================================
// KR-320.50 PULLBACK RESPECT
//==================================================================

float acceptancePullbackTolerance = indPrimaryTrendATR * 0.25

bool acceptanceBullishCPRRespect = acceptanceBullishDirection and mdPrimaryTrendL <= outTopCentral + acceptancePullbackTolerance and mdPrimaryTrendC > outTopCentral
bool acceptanceBullishSMA20Respect = acceptanceBullishDirection and mdPrimaryTrendL <= indPrimaryTrendSMA20 + acceptancePullbackTolerance and mdPrimaryTrendC > indPrimaryTrendSMA20
bool acceptanceBearishCPRRespect = acceptanceBearishDirection and mdPrimaryTrendH >= outBottomCentral - acceptancePullbackTolerance and mdPrimaryTrendC < outBottomCentral
bool acceptanceBearishSMA20Respect = acceptanceBearishDirection and mdPrimaryTrendH >= indPrimaryTrendSMA20 - acceptancePullbackTolerance and mdPrimaryTrendC < indPrimaryTrendSMA20
bool acceptancePullbackRespect = acceptanceBullishCPRRespect or acceptanceBullishSMA20Respect or acceptanceBearishCPRRespect or acceptanceBearishSMA20Respect

//==================================================================
// KR-320.60 CANDLE CLOSING STRENGTH
//==================================================================

float acceptanceCandleRange = mdPrimaryTrendH - mdPrimaryTrendL
float acceptanceClosePosition = acceptanceCandleRange > 0.0 ? (mdPrimaryTrendC - mdPrimaryTrendL) / acceptanceCandleRange : 0.50

bool acceptanceBullishCloseStrength = acceptanceBullishDirection and acceptanceClosePosition >= 0.65
bool acceptanceBearishCloseStrength = acceptanceBearishDirection and acceptanceClosePosition <= 0.35
bool acceptanceCandleCloseStrong = acceptanceBullishCloseStrength or acceptanceBearishCloseStrength

//==================================================================
// KR-320.70 ACCEPTANCE SCORE
//==================================================================

int acceptanceScore = 0

if acceptanceInputReady and acceptanceCPRAccepted
    acceptanceScore += 1

if acceptanceInputReady and acceptanceBreakoutAccepted
    acceptanceScore += 1

if acceptanceInputReady and acceptancePullbackRespect
    acceptanceScore += 1

if acceptanceInputReady and acceptanceCandleCloseStrong
    acceptanceScore += 1

//==================================================================
// KR-320.80 ACCEPTANCE CLASSIFICATION
//==================================================================

int acceptanceState = KR320_ACCEPTANCE_NEUTRAL

if not acceptanceInputReady or not acceptanceDirectional
    acceptanceState := KR320_ACCEPTANCE_NEUTRAL
else if acceptanceCPRRejected
    acceptanceState := KR320_ACCEPTANCE_REJECTED
else if acceptanceCPRTesting
    acceptanceState := KR320_ACCEPTANCE_TESTING
else if acceptanceScore >= 3
    acceptanceState := KR320_ACCEPTANCE_STRONG
else if acceptanceScore >= 2
    acceptanceState := KR320_ACCEPTANCE_ACCEPTED
else
    acceptanceState := KR320_ACCEPTANCE_NEUTRAL

string acceptanceText = ""

switch acceptanceState
    KR320_ACCEPTANCE_STRONG => acceptanceText := "Strong Acceptance"
    KR320_ACCEPTANCE_ACCEPTED => acceptanceText := "Accepted"
    KR320_ACCEPTANCE_TESTING => acceptanceText := "Testing"
    KR320_ACCEPTANCE_REJECTED => acceptanceText := "Rejected"
    => acceptanceText := "Neutral"

//==================================================================
// KR-320.90 PUBLIC INTERFACE
//==================================================================

int outAcceptanceState = acceptanceState

string outAcceptanceText = acceptanceText

int outAcceptanceScore = acceptanceScore

bool outAcceptanceStrong = acceptanceState == KR320_ACCEPTANCE_STRONG
bool outAcceptanceAccepted = acceptanceState == KR320_ACCEPTANCE_ACCEPTED
bool outAcceptanceTesting = acceptanceState == KR320_ACCEPTANCE_TESTING
bool outAcceptanceNeutral = acceptanceState == KR320_ACCEPTANCE_NEUTRAL
bool outAcceptanceRejected = acceptanceState == KR320_ACCEPTANCE_REJECTED

//--------------------------------------------------
// Compatibility Interface
//--------------------------------------------------

bool outBarrierReady = acceptanceInputReady

int outBarrierState = acceptanceAboveCPR ? KR320_BARRIER_ABOVE : acceptanceBelowCPR ? KR320_BARRIER_BELOW : KR320_BARRIER_INSIDE

string outBarrierText = acceptanceText

bool outBarrierAboveCPR = acceptanceAboveCPR
bool outBarrierInsideCPR = acceptanceInsideCPR
bool outBarrierBelowCPR = acceptanceBelowCPR

bool outBarrierInteraction = acceptanceCPRTesting

//==================================================================
// END OF KR-320
//==================================================================



//==================================================================
// KR-330 : Momentum Confirmation Engine
// Version : 1.0.0
// Status  : FROZEN
// Last Updated : 2026-07-10
//
// Validation Scope:
// - Intelligence core freeze validation on Copper, Gold, and Silver.
//
// Frozen Contract:
// - Owns momentum energy and persistence only.
// - Consumes public trend, quality, and acceptance outputs.
// - No direction decision, execution timing, alerts, or
//   trade-management logic.
//==================================================================
//
// Purpose
// -------
// Confirm whether momentum is building, stable, weakening or
// exhausted in the direction of the KR-300 trend foundation.
//
// Dependencies
// ------------
// KR-300 Trend Foundation Engine
// KR-310 Trend Quality Engine
// KR-320 Market Acceptance Engine
//
// Consumes
// --------
// KR-300 Public Trend Outputs
// KR-310 Public Trend Quality Outputs
// KR-320 Public Acceptance Outputs
//
// Produces
// --------
// Momentum State
// Momentum Text
// Momentum Ready
// Momentum Score
//
// NOTE
// ----
// KR-330 performs no rendering, alerts, signals or trading decisions.
//==================================================================

//==================================================================
// KR-330.10 MOMENTUM STATE CONSTANTS
//==================================================================

const int KR330_MOMENTUM_EXHAUSTED = 0
const int KR330_MOMENTUM_WEAKENING = 1
const int KR330_MOMENTUM_NORMAL = 2
const int KR330_MOMENTUM_STRONG = 3
const int KR330_MOMENTUM_BUILDING = 4

const int KR330_CONTEXT_BEARISH = -1
const int KR330_CONTEXT_NEUTRAL = 0
const int KR330_CONTEXT_BULLISH = 1

//==================================================================
// KR-330.20 INPUT READINESS
//==================================================================

bool momentumPublicInputReady = outTrendDataReady and outEvidenceReady and outBarrierReady
bool momentumDataReady = momentumPublicInputReady and not na(mdPrimaryTrendO) and not na(mdPrimaryTrendH) and not na(mdPrimaryTrendL) and not na(mdPrimaryTrendC) and not na(mdPrimaryTrendC[1]) and not na(mdPrimaryTrendC[2]) and not na(indPrimaryTrendRSI) and not na(indPrimaryTrendRSI[1]) and not na(indPrimaryTrendADX) and not na(indPrimaryTrendADX[1]) and not na(indPrimaryTrendATR)
bool momentumBullishDirection = momentumDataReady and outBullishTrend
bool momentumBearishDirection = momentumDataReady and outBearishTrend
bool momentumDirectional = momentumBullishDirection or momentumBearishDirection
bool momentumReady = momentumDataReady and momentumDirectional

//==================================================================
// KR-330.30 MOMENTUM PERSISTENCE
//==================================================================

float momentumCurrentImpulse = momentumBullishDirection ? mdPrimaryTrendC - mdPrimaryTrendC[1] : momentumBearishDirection ? mdPrimaryTrendC[1] - mdPrimaryTrendC : 0.0
float momentumPreviousImpulse = momentumBullishDirection ? mdPrimaryTrendC[1] - mdPrimaryTrendC[2] : momentumBearishDirection ? mdPrimaryTrendC[2] - mdPrimaryTrendC[1] : 0.0
float momentumImpulseThreshold = indPrimaryTrendATR * 0.10

bool momentumPositiveImpulse = momentumReady and momentumCurrentImpulse > momentumImpulseThreshold
bool momentumExpandingImpulse = momentumReady and momentumCurrentImpulse > momentumPreviousImpulse and momentumCurrentImpulse > momentumImpulseThreshold
bool momentumShrinkingImpulse = momentumReady and momentumCurrentImpulse > 0.0 and momentumCurrentImpulse < momentumPreviousImpulse
bool momentumAdverseImpulse = momentumReady and momentumCurrentImpulse <= 0.0

//==================================================================
// KR-330.40 RSI BEHAVIOUR
//==================================================================

float momentumRSIChange = indPrimaryTrendRSI - indPrimaryTrendRSI[1]

bool momentumRSIRising = momentumReady and momentumRSIChange > 0.50
bool momentumRSIFalling = momentumReady and momentumRSIChange < -0.50
bool momentumRSIFlattening = momentumReady and math.abs(momentumRSIChange) <= 0.50
bool momentumRSIAligned = (momentumBullishDirection and momentumRSIRising) or (momentumBearishDirection and momentumRSIFalling)
bool momentumRSIDiverging = (momentumBullishDirection and mdPrimaryTrendC > mdPrimaryTrendC[1] and indPrimaryTrendRSI < indPrimaryTrendRSI[1]) or (momentumBearishDirection and mdPrimaryTrendC < mdPrimaryTrendC[1] and indPrimaryTrendRSI > indPrimaryTrendRSI[1])

//==================================================================
// KR-330.50 ADX TREND
//==================================================================

float momentumADXChange = indPrimaryTrendADX - indPrimaryTrendADX[1]

bool momentumADXRising = momentumReady and momentumADXChange > 0.25
bool momentumADXStable = momentumReady and math.abs(momentumADXChange) <= 0.25
bool momentumADXFalling = momentumReady and momentumADXChange < -0.25
bool momentumADXSupportive = momentumADXRising or momentumADXStable

//==================================================================
// KR-330.60 VOLUME PARTICIPATION
//==================================================================

float momentumAverageVolume = ta.sma(mdPrimaryTrendV, 20)

bool momentumVolumeAvailable = momentumReady and not na(momentumAverageVolume) and momentumAverageVolume > 0.0
bool momentumDirectionalCandle = (momentumBullishDirection and mdPrimaryTrendC > mdPrimaryTrendO) or (momentumBearishDirection and mdPrimaryTrendC < mdPrimaryTrendO)
bool momentumVolumeParticipating = momentumVolumeAvailable and momentumDirectionalCandle and mdPrimaryTrendV >= momentumAverageVolume

//==================================================================
// KR-330.70 CANDLE STRENGTH
//==================================================================

float momentumCandleRange = mdPrimaryTrendH - mdPrimaryTrendL
float momentumCandleBody = math.abs(mdPrimaryTrendC - mdPrimaryTrendO)
float momentumBodyRatio = momentumCandleRange > 0.0 ? momentumCandleBody / momentumCandleRange : 0.0
float momentumClosePosition = momentumCandleRange > 0.0 ? (mdPrimaryTrendC - mdPrimaryTrendL) / momentumCandleRange : 0.50
float momentumUpperWick = mdPrimaryTrendH - math.max(mdPrimaryTrendO, mdPrimaryTrendC)
float momentumLowerWick = math.min(mdPrimaryTrendO, mdPrimaryTrendC) - mdPrimaryTrendL

bool momentumBullishStrongClose = momentumBullishDirection and momentumClosePosition >= 0.65 and momentumBodyRatio >= 0.45 and momentumUpperWick <= momentumCandleRange * 0.35
bool momentumBearishStrongClose = momentumBearishDirection and momentumClosePosition <= 0.35 and momentumBodyRatio >= 0.45 and momentumLowerWick <= momentumCandleRange * 0.35
bool momentumStrongCandle = momentumBullishStrongClose or momentumBearishStrongClose
bool momentumWeakCandle = momentumReady and momentumBodyRatio <= 0.25

//==================================================================
// KR-330.80 MOMENTUM SCORE
//==================================================================

int momentumScore = 0

if momentumReady and momentumExpandingImpulse
    momentumScore += 2

if momentumReady and momentumPositiveImpulse and not momentumExpandingImpulse
    momentumScore += 1

if momentumReady and momentumRSIAligned
    momentumScore += 1

if momentumReady and momentumADXSupportive
    momentumScore += 1

if momentumReady and momentumVolumeParticipating
    momentumScore += 1

if momentumReady and momentumStrongCandle
    momentumScore += 1

if momentumReady and momentumShrinkingImpulse
    momentumScore -= 1

if momentumReady and momentumADXFalling
    momentumScore -= 1

if momentumReady and momentumWeakCandle
    momentumScore -= 1

if momentumReady and momentumRSIDiverging
    momentumScore -= 2

momentumScore := math.max(0, math.min(momentumScore, 6))

//==================================================================
// KR-330.90 MOMENTUM CLASSIFICATION
//==================================================================

int momentumState = KR330_MOMENTUM_EXHAUSTED

if not momentumReady
    momentumState := KR330_MOMENTUM_EXHAUSTED
else if momentumAdverseImpulse or momentumRSIDiverging or momentumScore <= 1
    momentumState := KR330_MOMENTUM_EXHAUSTED
else if momentumShrinkingImpulse or momentumScore == 2
    momentumState := KR330_MOMENTUM_WEAKENING
else if momentumExpandingImpulse and momentumScore >= 5
    momentumState := KR330_MOMENTUM_BUILDING
else if momentumScore >= 4
    momentumState := KR330_MOMENTUM_STRONG
else
    momentumState := KR330_MOMENTUM_NORMAL

string momentumText = ""

switch momentumState
    KR330_MOMENTUM_BUILDING => momentumText := "Building Momentum"
    KR330_MOMENTUM_STRONG => momentumText := "Strong Momentum"
    KR330_MOMENTUM_NORMAL => momentumText := "Normal Momentum"
    KR330_MOMENTUM_WEAKENING => momentumText := "Weakening Momentum"
    => momentumText := "Exhausted Momentum"

//==================================================================
// KR-330.100 PUBLIC INTERFACE
//==================================================================

bool outMomentumReady = momentumReady

int outMomentumState = momentumState

string outMomentumText = momentumText

int outMomentumScore = momentumScore

bool outMomentumBuilding = momentumState == KR330_MOMENTUM_BUILDING
bool outMomentumStrong = momentumState == KR330_MOMENTUM_STRONG
bool outMomentumNormal = momentumState == KR330_MOMENTUM_NORMAL
bool outMomentumWeakening = momentumState == KR330_MOMENTUM_WEAKENING
bool outMomentumExhausted = momentumState == KR330_MOMENTUM_EXHAUSTED

//--------------------------------------------------
// Compatibility Interface
//--------------------------------------------------

bool contextReady = outMomentumReady

bool contextBullish = contextReady and outBullishTrend and (outMomentumBuilding or outMomentumStrong or outMomentumNormal) and (outAcceptanceStrong or outAcceptanceAccepted)
bool contextBearish = contextReady and outBearishTrend and (outMomentumBuilding or outMomentumStrong or outMomentumNormal) and (outAcceptanceStrong or outAcceptanceAccepted)
bool contextNeutral = contextReady and not contextBullish and not contextBearish

int contextState = KR330_CONTEXT_NEUTRAL

if contextBullish
    contextState := KR330_CONTEXT_BULLISH
else if contextBearish
    contextState := KR330_CONTEXT_BEARISH
else
    contextState := KR330_CONTEXT_NEUTRAL

string contextText = ""

switch contextState
    KR330_CONTEXT_BULLISH => contextText := "Bullish Momentum Context"
    KR330_CONTEXT_BEARISH => contextText := "Bearish Momentum Context"
    => contextText := "Neutral Momentum Context"

bool outContextReady = contextReady

int outContextState = contextState

string outContextText = contextText

bool outBullishContext = contextBullish
bool outBearishContext = contextBearish
bool outNeutralContext = contextNeutral

//==================================================================
// END OF KR-330
//==================================================================



//==================================================================
// KR-335 : Price Action Evidence Engine
// Version : 1.0.0
// Status  : FOUNDATION
// Category: Evidence Engine
// Last Updated : 2026-07-12
//
// Purpose
// -------
// Converts objective price action into standardized evidence.
//
// Ownership
// ---------
// - Objective candle quality
// - Closing pressure
// - Expansion / contraction
// - Public evidence outputs
//
// Boundaries
// ----------
// - No trend, structure, momentum, relative, confidence, decision,
//   execution, trade-management, alert, or presentation ownership.
// - No request.security() calls.
// - No routing or configuration.
//==================================================================

//==================================================================
// KR-335.10 STATE CONSTANTS
//==================================================================

const int KR335_PRESSURE_STRONG_BEARISH = -2
const int KR335_PRESSURE_BEARISH = -1
const int KR335_PRESSURE_NEUTRAL = 0
const int KR335_PRESSURE_BULLISH = 1
const int KR335_PRESSURE_STRONG_BULLISH = 2

const int KR335_EXPANSION_CONTRACTION = -1
const int KR335_EXPANSION_NORMAL = 0
const int KR335_EXPANSION_EXPANSION = 1

const int KR335_PRICE_ACTION_UNAVAILABLE = 0
const int KR335_PRICE_ACTION_CONTRACTION = 1
const int KR335_PRICE_ACTION_NORMAL = 2
const int KR335_PRICE_ACTION_EXPANSION = 3
const int KR335_PRICE_ACTION_HIGH_QUALITY = 4

const int KR335_ATR_NORMALIZATION_PERIOD = 14

//==================================================================
// KR-335.20 INPUT READINESS
//==================================================================

bool priceActionPublicInputReady = outTrendDataReady and outEvidenceReady and outBarrierReady and outMomentumReady
bool priceActionDataReady = priceActionPublicInputReady and not na(mdPrimaryTrendO) and not na(mdPrimaryTrendH) and not na(mdPrimaryTrendL) and not na(mdPrimaryTrendC) and not na(mdPrimaryTrendC[1])

//==================================================================
// KR-335.30 CANDLE QUALITY
//==================================================================

float priceActionRange = priceActionDataReady ? mdPrimaryTrendH - mdPrimaryTrendL : na
float priceActionBody = priceActionDataReady ? math.abs(mdPrimaryTrendC - mdPrimaryTrendO) : na
float priceActionUpperWick = priceActionDataReady ? mdPrimaryTrendH - math.max(mdPrimaryTrendO, mdPrimaryTrendC) : na
float priceActionLowerWick = priceActionDataReady ? math.min(mdPrimaryTrendO, mdPrimaryTrendC) - mdPrimaryTrendL : na

bool priceActionValidRange = priceActionDataReady and not na(priceActionRange) and priceActionRange > 0.0

float priceActionBodyRatio = priceActionValidRange ? priceActionBody / priceActionRange : na
float priceActionUpperWickRatio = priceActionValidRange ? priceActionUpperWick / priceActionRange : na
float priceActionLowerWickRatio = priceActionValidRange ? priceActionLowerWick / priceActionRange : na
float priceActionCloseLocation = priceActionValidRange ? (mdPrimaryTrendC - mdPrimaryTrendL) / priceActionRange : na

//==================================================================
// KR-335.40 CLOSING PRESSURE
//==================================================================

int priceActionClosingPressureState = KR335_PRESSURE_NEUTRAL

if priceActionValidRange and priceActionCloseLocation >= 0.80
    priceActionClosingPressureState := KR335_PRESSURE_STRONG_BULLISH
else if priceActionValidRange and priceActionCloseLocation >= 0.60
    priceActionClosingPressureState := KR335_PRESSURE_BULLISH
else if priceActionValidRange and priceActionCloseLocation <= 0.20
    priceActionClosingPressureState := KR335_PRESSURE_STRONG_BEARISH
else if priceActionValidRange and priceActionCloseLocation <= 0.40
    priceActionClosingPressureState := KR335_PRESSURE_BEARISH
else
    priceActionClosingPressureState := KR335_PRESSURE_NEUTRAL

string priceActionClosingPressureText = ""

switch priceActionClosingPressureState
    KR335_PRESSURE_STRONG_BULLISH => priceActionClosingPressureText := "Strong Bullish Close"
    KR335_PRESSURE_BULLISH => priceActionClosingPressureText := "Bullish Close"
    KR335_PRESSURE_BEARISH => priceActionClosingPressureText := "Bearish Close"
    KR335_PRESSURE_STRONG_BEARISH => priceActionClosingPressureText := "Strong Bearish Close"
    => priceActionClosingPressureText := "Neutral"

//==================================================================
// KR-335.50 EXPANSION / CONTRACTION
//==================================================================

float priceActionTrueRange = priceActionDataReady ? math.max(priceActionRange, math.max(math.abs(mdPrimaryTrendH - mdPrimaryTrendC[1]), math.abs(mdPrimaryTrendL - mdPrimaryTrendC[1]))) : na
float priceActionATR = ta.rma(priceActionTrueRange, KR335_ATR_NORMALIZATION_PERIOD)
float priceActionNormalizedRange = priceActionDataReady and not na(priceActionATR) and priceActionATR > 0.0 ? priceActionRange / priceActionATR : na
bool priceActionReady = priceActionValidRange and not na(priceActionNormalizedRange)

int priceActionExpansionState = KR335_EXPANSION_NORMAL

if not priceActionReady
    priceActionExpansionState := KR335_EXPANSION_NORMAL
else if priceActionNormalizedRange >= 1.25
    priceActionExpansionState := KR335_EXPANSION_EXPANSION
else if priceActionNormalizedRange <= 0.75
    priceActionExpansionState := KR335_EXPANSION_CONTRACTION
else
    priceActionExpansionState := KR335_EXPANSION_NORMAL

string priceActionExpansionText = ""

switch priceActionExpansionState
    KR335_EXPANSION_EXPANSION => priceActionExpansionText := "Expansion"
    KR335_EXPANSION_CONTRACTION => priceActionExpansionText := "Contraction"
    => priceActionExpansionText := "Normal"

//==================================================================
// KR-335.60 SCORE AND CLASSIFICATION
//==================================================================

int priceActionBodyScore = not priceActionValidRange ? 0 : priceActionBodyRatio >= 0.60 ? 40 : priceActionBodyRatio >= 0.45 ? 30 : priceActionBodyRatio >= 0.25 ? 15 : 5
int priceActionCloseScore = not priceActionValidRange ? 0 : int(math.round(math.abs(priceActionCloseLocation - 0.50) * 70.0))
int priceActionExpansionScore = priceActionExpansionState == KR335_EXPANSION_EXPANSION ? 25 : priceActionExpansionState == KR335_EXPANSION_NORMAL ? 15 : 5
int priceActionRawScore = priceActionBodyScore + priceActionCloseScore + priceActionExpansionScore
int priceActionScore = priceActionReady ? math.max(0, math.min(100, priceActionRawScore)) : 0

int priceActionState = KR335_PRICE_ACTION_UNAVAILABLE

if not priceActionReady
    priceActionState := KR335_PRICE_ACTION_UNAVAILABLE
else if priceActionExpansionState == KR335_EXPANSION_CONTRACTION
    priceActionState := KR335_PRICE_ACTION_CONTRACTION
else if priceActionScore >= 75
    priceActionState := KR335_PRICE_ACTION_HIGH_QUALITY
else if priceActionExpansionState == KR335_EXPANSION_EXPANSION
    priceActionState := KR335_PRICE_ACTION_EXPANSION
else
    priceActionState := KR335_PRICE_ACTION_NORMAL

string priceActionStatus = priceActionReady ? "READY" : "WAITING"
string priceActionReason = not priceActionPublicInputReady ? "Waiting for public evidence inputs" : not priceActionValidRange ? "Waiting for valid candle range" : not priceActionReady ? "Waiting for normalized range" : priceActionExpansionText + " / " + priceActionClosingPressureText
string priceActionSummary = priceActionReady ? priceActionExpansionText + " / " + priceActionClosingPressureText : "Price Action Waiting"

//==================================================================
// KR-335.70 PUBLIC INTERFACE
//==================================================================

bool outPriceActionReady = priceActionReady
string outPriceActionStatus = priceActionStatus
string outPriceActionReason = priceActionReason
int outPriceActionScore = priceActionScore
int outPriceActionState = priceActionState
string outPriceActionSummary = priceActionSummary

float outPriceActionBodyRatio = priceActionBodyRatio
float outPriceActionUpperWickRatio = priceActionUpperWickRatio
float outPriceActionLowerWickRatio = priceActionLowerWickRatio
float outPriceActionCloseLocation = priceActionCloseLocation
float outPriceActionNormalizedRange = priceActionNormalizedRange
int outPriceActionClosingPressureState = priceActionClosingPressureState
int outPriceActionExpansionState = priceActionExpansionState
string outPriceActionClosingPressureText = priceActionClosingPressureText
string outPriceActionExpansionText = priceActionExpansionText

bool outPriceActionStrongBullishClose = priceActionClosingPressureState == KR335_PRESSURE_STRONG_BULLISH
bool outPriceActionBullishClose = priceActionClosingPressureState == KR335_PRESSURE_BULLISH
bool outPriceActionNeutralClose = priceActionClosingPressureState == KR335_PRESSURE_NEUTRAL
bool outPriceActionBearishClose = priceActionClosingPressureState == KR335_PRESSURE_BEARISH
bool outPriceActionStrongBearishClose = priceActionClosingPressureState == KR335_PRESSURE_STRONG_BEARISH
bool outPriceActionExpansion = priceActionExpansionState == KR335_EXPANSION_EXPANSION
bool outPriceActionNormalRange = priceActionExpansionState == KR335_EXPANSION_NORMAL
bool outPriceActionContraction = priceActionExpansionState == KR335_EXPANSION_CONTRACTION

//==================================================================
// KR-335.80 RESERVED PLACEHOLDERS
//==================================================================
// Impulse vs Correction : Placeholder only.
// Market Regime         : Placeholder only.
// Anti-Chase            : Placeholder only.
// State Machines        : Placeholder only.

//==================================================================
// END OF KR-335
//==================================================================



//==================================================================
// KR-340 : Review Readiness Engine
// Version : 1.0.0
// Status  : FROZEN
// Last Updated : 2026-07-10
//
// Validation Scope:
// - Intelligence core freeze validation on Copper, Gold, and Silver.
//
// Frozen Contract:
// - Owns review readiness, wait, and blocked states only.
// - Consumes prior public context and barrier outputs.
// - No direction decision, execution timing, alerts, or
//   trade-management logic.
//==================================================================
//
// Question
// --------
// Is the context ready for downstream review?
//
// Dependencies
// ------------
// KR-320 Barrier Interaction Engine
// KR-330 Context Foundation Engine
//
// NOTE
// ----
// KR-340 performs no rendering, alerts, signals or trading decisions.
//==================================================================

//==================================================================
// KR-340.10 READINESS STATE CONSTANTS
//==================================================================

const int KR340_REVIEW_BLOCKED = -1
const int KR340_REVIEW_WAIT = 0
const int KR340_REVIEW_READY = 1

//==================================================================
// KR-340.20 READINESS CLASSIFICATION
//==================================================================

bool reviewInputReady = outContextReady and outBarrierReady

bool reviewReady = reviewInputReady and not outNeutralContext and not outBarrierInteraction
bool reviewBlocked = reviewInputReady and outBarrierInteraction
bool reviewWait = reviewInputReady and not reviewReady and not reviewBlocked

int reviewState = KR340_REVIEW_WAIT

if reviewReady
    reviewState := KR340_REVIEW_READY
else if reviewBlocked
    reviewState := KR340_REVIEW_BLOCKED
else
    reviewState := KR340_REVIEW_WAIT

string reviewText = ""

switch reviewState
    KR340_REVIEW_READY => reviewText := "Review Ready"
    KR340_REVIEW_BLOCKED => reviewText := "Review Blocked"
    => reviewText := "Review Waiting"

//==================================================================
// KR-340.30 PUBLIC INTERFACE
//==================================================================

bool outReviewInputReady = reviewInputReady

int outReviewState = reviewState

string outReviewText = reviewText

bool outReviewReady = reviewReady
bool outReviewBlocked = reviewBlocked
bool outReviewWait = reviewWait

//==================================================================
// END OF KR-340
//==================================================================



//==================================================================
// KR-345 : Relative Intelligence Engine
// Version : 1.0.0
// Status  : FOUNDATION
// Category: Evidence Engine
// Last Updated : 2026-07-12
//
// Purpose
// -------
// Measures relative strength against the appropriate market
// benchmark and produces standardized evidence.
//
// Ownership
// ---------
// - Market Relative
// - Sector Relative
// - Relative evidence scoring
// - Relative state classification
//
// Boundaries
// ----------
// - No trend, trend-quality, compression, acceptance, momentum,
//   price-action, opportunity, confidence, decision, execution,
//   trade-management, alert, or presentation ownership.
// - No request.security() calls.
// - No routing, configuration, or symbol mapping.
//==================================================================

//==================================================================
// KR-345.10 STATE CONSTANTS
//==================================================================

const int KR345_RELATIVE_LAGGARD = -2
const int KR345_RELATIVE_WEAK = -1
const int KR345_RELATIVE_NEUTRAL = 0
const int KR345_RELATIVE_STRONG = 1
const int KR345_RELATIVE_LEADER = 2

const int KR345_TREND_FALLING = -1
const int KR345_TREND_FLAT = 0
const int KR345_TREND_RISING = 1

const int KR345_RELATIVE_LOOKBACK = 123

//==================================================================
// KR-345.20 RELATIVE FUNCTIONS
//==================================================================

relativeStrengthValue(series float instrumentClose, series float benchmarkClose, int lookback) =>
    bool relativeInputsReady = not na(instrumentClose) and not na(benchmarkClose) and not na(instrumentClose[lookback]) and not na(benchmarkClose[lookback]) and instrumentClose[lookback] != 0.0 and benchmarkClose[lookback] != 0.0
    float instrumentReturn = relativeInputsReady ? instrumentClose / instrumentClose[lookback] : na
    float benchmarkReturn = relativeInputsReady ? benchmarkClose / benchmarkClose[lookback] : na
    relativeInputsReady and benchmarkReturn != 0.0 ? (instrumentReturn / benchmarkReturn) - 1.0 : na

relativeStateFromValue(series float relativeValue) =>
    int state = KR345_RELATIVE_NEUTRAL
    if na(relativeValue)
        state := KR345_RELATIVE_NEUTRAL
    else if relativeValue >= 0.05
        state := KR345_RELATIVE_LEADER
    else if relativeValue >= 0.02
        state := KR345_RELATIVE_STRONG
    else if relativeValue <= -0.05
        state := KR345_RELATIVE_LAGGARD
    else if relativeValue <= -0.02
        state := KR345_RELATIVE_WEAK
    else
        state := KR345_RELATIVE_NEUTRAL
    state

relativeTrendFromValue(series float relativeValue) =>
    int trend = KR345_TREND_FLAT
    if not na(relativeValue) and not na(relativeValue[1])
        if relativeValue > relativeValue[1]
            trend := KR345_TREND_RISING
        else if relativeValue < relativeValue[1]
            trend := KR345_TREND_FALLING
        else
            trend := KR345_TREND_FLAT
    trend

relativeScoreFromState(int relativeState) =>
    relativeState == KR345_RELATIVE_LEADER ? 100 : relativeState == KR345_RELATIVE_STRONG ? 75 : relativeState == KR345_RELATIVE_NEUTRAL ? 50 : relativeState == KR345_RELATIVE_WEAK ? 25 : 0

relativeStateText(int relativeState) =>
    string stateText = "NEUTRAL"
    switch relativeState
        KR345_RELATIVE_LEADER => stateText := "LEADER"
        KR345_RELATIVE_STRONG => stateText := "STRONG"
        KR345_RELATIVE_WEAK => stateText := "WEAK"
        KR345_RELATIVE_LAGGARD => stateText := "LAGGARD"
        => stateText := "NEUTRAL"
    stateText

//==================================================================
// KR-345.30 INPUT READINESS
//==================================================================

bool relativeNSEEquityContext = outMarketDataUsesCashAnalysis
bool relativeNSEIndexContext = outMarketDataUsesIndexAnalysis
bool relativeMCXContext = outMarketDataUsesFuturesAnalysis
bool relativeNotApplicable = relativeNSEIndexContext or relativeMCXContext or not relativeNSEEquityContext

bool marketRelativeContextReady = relativeNSEEquityContext and outMarketDataHasParentIndexContext and outAnalysisDataReady and outParentDataReady
bool sectorRelativeContextReady = relativeNSEEquityContext and outRelationshipReady and outRelationshipHasSectorContext and outMarketDataHasSectorContext and outAnalysisDataReady and outSectorDataReady

//==================================================================
// KR-345.40 MARKET RELATIVE
//==================================================================

float marketRelativeValue = marketRelativeContextReady ? relativeStrengthValue(outAnalysisClose, outParentClose, KR345_RELATIVE_LOOKBACK) : na
bool marketRelativeReady = marketRelativeContextReady and not na(marketRelativeValue)
int marketRelativeState = relativeStateFromValue(marketRelativeValue)
int marketRelativeTrend = relativeTrendFromValue(marketRelativeValue)

//==================================================================
// KR-345.50 SECTOR RELATIVE
//==================================================================

float sectorRelativeValue = sectorRelativeContextReady ? relativeStrengthValue(outAnalysisClose, outSectorClose, KR345_RELATIVE_LOOKBACK) : na
bool sectorRelativeReady = sectorRelativeContextReady and not na(sectorRelativeValue)
int sectorRelativeState = relativeStateFromValue(sectorRelativeValue)
int sectorRelativeTrend = relativeTrendFromValue(sectorRelativeValue)

//==================================================================
// KR-345.60 SCORE AND CLASSIFICATION
//==================================================================

bool relativeReady = marketRelativeReady
int relativeScore = 0

if marketRelativeReady and sectorRelativeReady
    relativeScore := int(math.round((relativeScoreFromState(marketRelativeState) + relativeScoreFromState(sectorRelativeState)) / 2.0))
else if marketRelativeReady
    relativeScore := relativeScoreFromState(marketRelativeState)
else
    relativeScore := 0

float relativeCompositeValue = marketRelativeReady and sectorRelativeReady ? (marketRelativeValue + sectorRelativeValue) / 2.0 : marketRelativeReady ? marketRelativeValue : na
int relativeState = relativeStateFromValue(relativeCompositeValue)
string relativeStatus = relativeReady ? "READY" : relativeNotApplicable ? "NOT APPLICABLE" : "WAITING"
string relativeReason = relativeNotApplicable ? "Relative not applicable for this market model" : marketRelativeReady and sectorRelativeReady ? "Market and sector relative ready" : marketRelativeReady ? "Market relative ready; sector relative unavailable" : "Waiting for market relative data"
string relativeSummary = relativeReady ? "Market " + relativeStateText(marketRelativeState) + (sectorRelativeReady ? " / Sector " + relativeStateText(sectorRelativeState) : " / Sector Unavailable") : relativeStatus

//==================================================================
// KR-345.70 PUBLIC INTERFACE
//==================================================================

bool outRelativeReady = relativeReady
string outRelativeStatus = relativeStatus
string outRelativeReason = relativeReason
int outRelativeScore = relativeScore
int outRelativeState = relativeState
string outRelativeSummary = relativeSummary

bool outMarketRelativeReady = marketRelativeReady
float outMarketRelativeValue = marketRelativeValue
int outMarketRelativeState = marketRelativeState
int outMarketRelativeTrend = marketRelativeTrend

bool outSectorRelativeReady = sectorRelativeReady
float outSectorRelativeValue = sectorRelativeValue
int outSectorRelativeState = sectorRelativeState
int outSectorRelativeTrend = sectorRelativeTrend

string outRelativeBenchmarkSymbol = outMarketDataParentIndexSymbol
int outRelativeLookback = KR345_RELATIVE_LOOKBACK

//==================================================================
// KR-345.80 RESERVED PLACEHOLDERS
//==================================================================
// Sector vs NIFTY          : Not implemented.
// Leadership               : Not implemented.
// Multi-timeframe Relative : Not implemented.
// Acceleration             : Not implemented.

//==================================================================
// END OF KR-345
//==================================================================



//==================================================================
// KR-350 : Opportunity Foundation Engine
// Version : 1.0.0
// Status  : FROZEN
// Last Updated : 2026-07-10
//
// Validation Scope:
// - Intelligence core freeze validation on Copper, Gold, and Silver.
//
// Frozen Contract:
// - Owns bullish, bearish, or absent opportunity context only.
// - Consumes public context and review-readiness outputs.
// - No execution timing, alerts, entries, or trade-management logic.
//==================================================================
//
// Question
// --------
// Is there a directional opportunity context for downstream engines?
//
// Dependencies
// ------------
// KR-330 Context Foundation Engine
// KR-340 Review Readiness Engine
//
// NOTE
// ----
// KR-350 performs no rendering, alerts, signals or trading decisions.
//==================================================================

//==================================================================
// KR-350.10 OPPORTUNITY STATE CONSTANTS
//==================================================================

const int KR350_OPPORTUNITY_BEARISH = -1
const int KR350_OPPORTUNITY_NONE = 0
const int KR350_OPPORTUNITY_BULLISH = 1

//==================================================================
// KR-350.20 OPPORTUNITY CONTEXT
//==================================================================

bool opportunityInputReady = outContextReady and outReviewInputReady

bool opportunityBullish = opportunityInputReady and outReviewReady and outBullishContext
bool opportunityBearish = opportunityInputReady and outReviewReady and outBearishContext
bool opportunityNone = opportunityInputReady and not opportunityBullish and not opportunityBearish

int opportunityState = KR350_OPPORTUNITY_NONE

if opportunityBullish
    opportunityState := KR350_OPPORTUNITY_BULLISH
else if opportunityBearish
    opportunityState := KR350_OPPORTUNITY_BEARISH
else
    opportunityState := KR350_OPPORTUNITY_NONE

string opportunityText = ""

switch opportunityState
    KR350_OPPORTUNITY_BULLISH => opportunityText := "Bullish Opportunity Context"
    KR350_OPPORTUNITY_BEARISH => opportunityText := "Bearish Opportunity Context"
    => opportunityText := "No Opportunity Context"

//==================================================================
// KR-350.30 PUBLIC INTERFACE
//==================================================================

bool outOpportunityInputReady = opportunityInputReady

int outOpportunityState = opportunityState

string outOpportunityText = opportunityText

bool outBullishOpportunityContext = opportunityBullish
bool outBearishOpportunityContext = opportunityBearish
bool outNoOpportunityContext = opportunityNone

//==================================================================
// END OF KR-350
//==================================================================



//==================================================================
// KR-360 : Confidence Engine
// Version : 1.0.0
// Status  : FROZEN
// Last Updated : 2026-07-09
//
// Purpose:
// Synthesizes completed KRONOS engines into a single confidence
// assessment. Does not generate trading decisions.
//
// Validation Scope:
// - Confidence architecture and scoring freeze on Copper, Gold, and
//   Silver.
//
// Frozen Contract:
// - Uses ONLY public outputs from prior engines.
// - No direct market calculations.
// - No alerts.
// - No buy/sell decisions.
//==================================================================

//==================================================================
// KR-360.10 CONFIDENCE STATE CONSTANTS
//==================================================================

const int KR360_CONFIDENCE_AVOID = 0
const int KR360_CONFIDENCE_LOW = 1
const int KR360_CONFIDENCE_DEVELOPING = 2
const int KR360_CONFIDENCE_HIGH = 3
const int KR360_CONFIDENCE_EXCEPTIONAL = 4

//==================================================================
// KR-360.20 INPUT READINESS
//==================================================================

bool confidenceTrendReady = outTrendDataReady
bool confidenceQualityReady = outEvidenceReady
bool confidenceCompressionReady = outCompressionReady
bool confidenceAcceptanceReady = outBarrierReady
bool confidenceMomentumReady = outMomentumReady
bool confidenceReviewReady = outReviewInputReady
bool confidenceOpportunityReady = outOpportunityInputReady

bool confidenceReady = confidenceTrendReady and confidenceCompressionReady and confidenceAcceptanceReady and confidenceReviewReady and confidenceOpportunityReady

//==================================================================
// KR-360.30 PUBLIC CONDITION MAP
//==================================================================

bool confidenceDirectionalTrend = confidenceTrendReady and (outBullishTrend or outBearishTrend)
bool confidenceConfirmedTrend = confidenceTrendReady and (outConfirmedBullishTrend or outConfirmedBearishTrend)
bool confidenceDevelopingTrend = confidenceTrendReady and (outDevelopingBullishTrend or outDevelopingBearishTrend)
bool confidenceNeutralTrend = confidenceTrendReady and outNeutralTrend

bool confidenceHealthyQuality = confidenceQualityReady and (outTrendQualityHealthy or outTrendQualityExcellent)
bool confidenceWeakQuality = confidenceQualityReady and outTrendQualityWeak
bool confidenceExtendedQuality = confidenceQualityReady and outTrendQualityExtended

bool confidenceRejectedAcceptance = confidenceAcceptanceReady and outAcceptanceRejected
bool confidenceAccepted = confidenceAcceptanceReady and outAcceptanceAccepted
bool confidenceStrongAcceptance = confidenceAcceptanceReady and outAcceptanceStrong
bool confidenceTestingAcceptance = confidenceAcceptanceReady and outAcceptanceTesting

bool confidenceCompressionBuilding = confidenceCompressionReady and outCompressionBuilding and not outExpansionStarted
bool confidenceExpansionRelease = confidenceCompressionReady and outExpansionStarted

bool confidenceStrongMomentum = confidenceMomentumReady and (outMomentumStrong or outMomentumBuilding)
bool confidenceNormalMomentum = confidenceMomentumReady and outMomentumNormal
bool confidenceExhaustedMomentum = confidenceMomentumReady and outMomentumExhausted

bool confidenceHighOpportunity = confidenceOpportunityReady and (outBullishOpportunityContext or outBearishOpportunityContext)
bool confidenceLimitedOpportunity = confidenceOpportunityReady and outNoOpportunityContext

bool confidenceHighRisk = confidenceReviewReady and outReviewBlocked
bool confidenceLowRisk = confidenceReviewReady and outReviewReady

//==================================================================
// KR-360.40 BOOSTERS AND PENALTIES
//==================================================================

int confidenceTrendBoost = confidenceConfirmedTrend ? 18 : confidenceDevelopingTrend or confidenceDirectionalTrend ? 10 : 0
int confidenceQualityBoost = confidenceHealthyQuality ? 12 : 0
int confidenceAcceptanceBoost = confidenceStrongAcceptance ? 18 : confidenceAccepted ? 14 : confidenceTestingAcceptance ? 6 : 0
int confidenceCompressionBoost = confidenceExpansionRelease ? 12 : 0
int confidenceMomentumBoost = confidenceStrongMomentum ? 12 : confidenceNormalMomentum ? 5 : 0
int confidenceOpportunityBoost = confidenceHighOpportunity ? 12 : 0
int confidenceRiskBoost = confidenceLowRisk ? 8 : 0

int confidenceTrendPenalty = confidenceNeutralTrend ? -25 : 0
int confidenceQualityPenalty = confidenceWeakQuality ? -12 : confidenceExtendedQuality ? -8 : 0
int confidenceAcceptancePenalty = confidenceRejectedAcceptance ? -25 : 0
int confidenceCompressionPenalty = confidenceCompressionBuilding ? -10 : 0
int confidenceMomentumPenalty = confidenceExhaustedMomentum ? -18 : 0
int confidenceOpportunityPenalty = confidenceLimitedOpportunity ? -12 : 0
int confidenceRiskPenalty = confidenceHighRisk ? -25 : 0

int confidenceBoostScore = confidenceTrendBoost + confidenceQualityBoost + confidenceAcceptanceBoost + confidenceCompressionBoost + confidenceMomentumBoost + confidenceOpportunityBoost + confidenceRiskBoost
int confidencePenaltyScore = confidenceTrendPenalty + confidenceQualityPenalty + confidenceAcceptancePenalty + confidenceCompressionPenalty + confidenceMomentumPenalty + confidenceOpportunityPenalty + confidenceRiskPenalty

//==================================================================
// KR-360.50 CONFIDENCE GATES
//==================================================================

int confidenceRawScore = 30 + confidenceBoostScore + confidencePenaltyScore
int confidenceGatedScore = confidenceRawScore

if confidenceNeutralTrend
    confidenceGatedScore := math.min(confidenceGatedScore, 20)

if confidenceRejectedAcceptance
    confidenceGatedScore := math.min(confidenceGatedScore, 30)

if confidenceHighRisk
    confidenceGatedScore := math.min(confidenceGatedScore, 40)

if confidenceCompressionBuilding
    confidenceGatedScore := math.min(confidenceGatedScore, 60)

if confidenceWeakQuality
    confidenceGatedScore := math.min(confidenceGatedScore, 55)

if confidenceLimitedOpportunity
    confidenceGatedScore := math.min(confidenceGatedScore, 60)

int confidenceScore = math.max(0, math.min(100, confidenceGatedScore))

//==================================================================
// KR-360.60 CONFIDENCE STATE AND REASON
//==================================================================

int confidenceState = KR360_CONFIDENCE_AVOID

if confidenceScore <= 20
    confidenceState := KR360_CONFIDENCE_AVOID
else if confidenceScore <= 40
    confidenceState := KR360_CONFIDENCE_LOW
else if confidenceScore <= 60
    confidenceState := KR360_CONFIDENCE_DEVELOPING
else if confidenceScore <= 80
    confidenceState := KR360_CONFIDENCE_HIGH
else
    confidenceState := KR360_CONFIDENCE_EXCEPTIONAL

string confidenceStateText = ""

switch confidenceState
    KR360_CONFIDENCE_EXCEPTIONAL => confidenceStateText := "Exceptional"
    KR360_CONFIDENCE_HIGH => confidenceStateText := "High Confidence"
    KR360_CONFIDENCE_DEVELOPING => confidenceStateText := "Developing"
    KR360_CONFIDENCE_LOW => confidenceStateText := "Low Confidence"
    => confidenceStateText := "Avoid"

string confidenceReason = ""

if confidenceNeutralTrend
    confidenceReason := "Neutral Trend"
else if confidenceRejectedAcceptance
    confidenceReason := "Rejected CPR"
else if confidenceHighRisk
    confidenceReason := "High Risk"
else if confidenceCompressionBuilding
    confidenceReason := "Building Compression"
else if confidenceWeakQuality
    confidenceReason := "Weak Quality"
else if confidenceExhaustedMomentum
    confidenceReason := "Exhausted Momentum"
else if confidenceLimitedOpportunity
    confidenceReason := "Limited Opportunity"
else if confidenceExpansionRelease
    confidenceReason := "Expansion Released"
else if confidenceHighOpportunity and confidenceStrongMomentum and confidenceLowRisk
    confidenceReason := "Aligned Opportunity"
else
    confidenceReason := "Aligned"

//==================================================================
// KR-360.70 PUBLIC INTERFACE
//==================================================================

bool outConfidenceReady = confidenceReady

int outConfidenceScore = confidenceScore
int outConfidenceState = confidenceState

string outConfidenceReason = confidenceReason

// Compatibility outputs retained for KR-705 and downstream consumers.
string outConfidenceText = confidenceStateText
string outConfidenceReasonText = confidenceReason

bool outConfidenceVeryHigh = confidenceState == KR360_CONFIDENCE_EXCEPTIONAL
bool outConfidenceHigh = confidenceState == KR360_CONFIDENCE_HIGH
bool outConfidenceMedium = confidenceState == KR360_CONFIDENCE_DEVELOPING
bool outConfidenceLow = confidenceState == KR360_CONFIDENCE_LOW
bool outConfidenceVeryLow = confidenceState == KR360_CONFIDENCE_AVOID

//==================================================================
// END OF KR-360
//==================================================================



//==================================================================
// KR-370 : Decision Engine
// Version : 1.0.0
// Status  : FROZEN
// Last Updated : 2026-07-10
//
// Validation:
// - Copper
// - Silver
// - Gold
//
// Frozen Contract:
// - Uses only public outputs from prior KRONOS engines.
// - Produces explainable decision and checklist outputs.
// - No direct market calculations.
// - No alerts.
// - No entry triggers.
// - No trade-management logic.
//==================================================================

//==================================================================
// KR-370.10 DECISION STATE CONSTANTS
//==================================================================

const int KR370_DECISION_AVOID = 0
const int KR370_DECISION_WAIT = 1
const int KR370_DECISION_WATCH_LONG = 2
const int KR370_DECISION_WATCH_SHORT = 3
const int KR370_DECISION_BUY_READY = 4
const int KR370_DECISION_SELL_READY = 5

//==================================================================
// KR-370.20 INPUT READINESS
//==================================================================

bool decisionTrendReady = outTrendDataReady
bool decisionCompressionReady = outCompressionReady
bool decisionAcceptanceReady = outBarrierReady
bool decisionMomentumReadyInput = outMomentumReady
bool decisionReviewReadyInput = outReviewInputReady
bool decisionOpportunityReady = outOpportunityInputReady
bool decisionConfidenceReady = outConfidenceReady

bool decisionExecutionInputsReady = decisionCompressionReady and decisionAcceptanceReady and decisionMomentumReadyInput and decisionReviewReadyInput and decisionOpportunityReady and decisionConfidenceReady
bool decisionReady = decisionTrendReady and (decisionExecutionInputsReady or outBullishTrend or outBearishTrend)

//==================================================================
// KR-370.30 PUBLIC CONDITION MAP
//==================================================================

bool decisionBullishTrend = decisionTrendReady and outBullishTrend
bool decisionBearishTrend = decisionTrendReady and outBearishTrend
bool decisionNeutralTrend = decisionTrendReady and outNeutralTrend

bool decisionHigherTimeframeBullishBias = decisionBullishTrend
bool decisionHigherTimeframeBearishBias = decisionBearishTrend
bool decisionHigherTimeframeBiasAligned = decisionHigherTimeframeBullishBias or decisionHigherTimeframeBearishBias

bool decisionBullishContext = decisionHigherTimeframeBullishBias or outBullishContext or outBullishOpportunityContext
bool decisionBearishContext = decisionHigherTimeframeBearishBias or outBearishContext or outBearishOpportunityContext
bool decisionDirectionalContext = decisionBullishContext or decisionBearishContext

bool decisionCompressionBlocking = decisionCompressionReady and not outExpansionStarted and (outCompressionBuilding or outCompressionStrong or outCompressionCritical)
bool decisionCompressionClear = decisionCompressionReady and (outExpansionStarted or not decisionCompressionBlocking)

bool decisionAcceptanceConfirmed = decisionAcceptanceReady and (outAcceptanceAccepted or outAcceptanceStrong)
bool decisionAcceptanceTesting = decisionAcceptanceReady and outAcceptanceTesting
bool decisionAcceptanceRejected = decisionAcceptanceReady and outAcceptanceRejected

bool decisionConfidenceExtremelyLow = decisionConfidenceReady and outConfidenceScore <= 20
bool decisionConfidenceLowDeveloping = decisionConfidenceReady and outConfidenceScore > 20 and outConfidenceScore <= 40
bool decisionConfidenceDeveloping = decisionConfidenceReady and outConfidenceScore > 40 and outConfidenceScore <= 60
bool decisionConfidenceInvalidatesThesis = decisionConfidenceExtremelyLow and not decisionHigherTimeframeBiasAligned
bool decisionConfidenceBelowReady = decisionConfidenceLowDeveloping or decisionConfidenceDeveloping
bool decisionConfidenceReadyThreshold = decisionConfidenceReady and outConfidenceScore > 60

bool decisionMomentumReady = decisionMomentumReadyInput and (outMomentumNormal or outMomentumStrong or outMomentumBuilding)
bool decisionMomentumNotReady = decisionMomentumReadyInput and (outMomentumExhausted or outMomentumWeakening)

bool decisionReviewReady = decisionReviewReadyInput and outReviewReady
bool decisionReviewBlocked = decisionReviewReadyInput and outReviewBlocked

bool decisionBullishOpportunity = decisionOpportunityReady and outBullishOpportunityContext
bool decisionBearishOpportunity = decisionOpportunityReady and outBearishOpportunityContext
bool decisionOpportunityAbsent = decisionOpportunityReady and outNoOpportunityContext
bool decisionNoDirectionalOpportunity = decisionOpportunityAbsent and not decisionDirectionalContext

bool decisionBuyReadySetup = decisionBullishTrend and decisionBullishContext and decisionAcceptanceConfirmed and decisionConfidenceReadyThreshold and decisionMomentumReady and decisionCompressionClear and decisionReviewReady and decisionBullishOpportunity
bool decisionSellReadySetup = decisionBearishTrend and decisionBearishContext and decisionAcceptanceConfirmed and decisionConfidenceReadyThreshold and decisionMomentumReady and decisionCompressionClear and decisionReviewReady and decisionBearishOpportunity

//==================================================================
// KR-370.40 DECISION CLASSIFICATION
//==================================================================

int decisionState = KR370_DECISION_WAIT
string decisionReason = ""
string decisionPrimaryBlocker = ""
string decisionNextReview = ""

if not decisionReady
    decisionState := KR370_DECISION_AVOID
    decisionReason := "Required engine inputs unavailable"
    decisionPrimaryBlocker := "Engine Data Unavailable"
    decisionNextReview := "After Engine Data Loads"
else if decisionReviewBlocked
    decisionState := KR370_DECISION_AVOID
    decisionReason := "Review blocked"
    decisionPrimaryBlocker := "Review Blocked"
    decisionNextReview := "After Blocker Clears"
else if decisionConfidenceInvalidatesThesis
    decisionState := KR370_DECISION_AVOID
    decisionReason := "Confidence too low"
    decisionPrimaryBlocker := "Confidence Too Low"
    decisionNextReview := "After Conditions Improve"
else if decisionBuyReadySetup
    decisionState := KR370_DECISION_BUY_READY
    decisionReason := "Bullish conditions aligned"
    decisionPrimaryBlocker := "None"
    decisionNextReview := "Wait for KR-380 Trigger"
else if decisionSellReadySetup
    decisionState := KR370_DECISION_SELL_READY
    decisionReason := "Bearish conditions aligned"
    decisionPrimaryBlocker := "None"
    decisionNextReview := "Wait for KR-380 Trigger"
else if decisionBullishContext
    decisionState := KR370_DECISION_WATCH_LONG
    if not decisionExecutionInputsReady
        decisionReason := "Bullish higher-timeframe thesis; execution confirmation pending"
        decisionPrimaryBlocker := "Execution Confirmation Pending"
        decisionNextReview := "After Execution Confirmation"
    else if decisionCompressionBlocking
        decisionReason := "Bullish context; compression release pending"
        decisionPrimaryBlocker := "Compression Not Released"
        decisionNextReview := "After Compression Release"
    else if not decisionAcceptanceConfirmed
        decisionReason := "Bullish context; higher-timeframe confirmation pending"
        decisionPrimaryBlocker := decisionAcceptanceTesting ? "Acceptance Pending" : decisionAcceptanceRejected ? "Acceptance Not Confirmed" : "Higher-Timeframe Acceptance Pending"
        decisionNextReview := decisionAcceptanceRejected ? "Next Reference Candle Close" : "After Acceptance Confirmation"
    else if decisionConfidenceLowDeveloping
        decisionReason := "Bullish context; confidence developing"
        decisionPrimaryBlocker := "Developing Confidence"
        decisionNextReview := "After Confidence Exceeds 60"
    else if not decisionConfidenceReadyThreshold
        decisionReason := "Bullish context; confidence below ready threshold"
        decisionPrimaryBlocker := "Confidence Below Ready Threshold"
        decisionNextReview := "After Confidence Exceeds 60"
    else if not decisionMomentumReady
        decisionReason := "Bullish context; momentum not ready"
        decisionPrimaryBlocker := "Momentum Not Ready"
        decisionNextReview := "After Momentum Improves"
    else if not decisionBullishOpportunity
        decisionReason := "Bullish context; opportunity not confirmed"
        decisionPrimaryBlocker := "Opportunity Pending"
        decisionNextReview := "After Opportunity Improves"
    else if not decisionReviewReady
        decisionReason := "Bullish context; review not ready"
        decisionPrimaryBlocker := "Review Pending"
        decisionNextReview := "After Review Readiness"
    else
        decisionReason := "Bullish context; setup incomplete"
        decisionPrimaryBlocker := "Readiness Not Complete"
        decisionNextReview := "After Missing Conditions Confirm"
else if decisionBearishContext
    decisionState := KR370_DECISION_WATCH_SHORT
    if not decisionExecutionInputsReady
        decisionReason := "Bearish higher-timeframe thesis; execution confirmation pending"
        decisionPrimaryBlocker := "Execution Confirmation Pending"
        decisionNextReview := "After Execution Confirmation"
    else if decisionCompressionBlocking
        decisionReason := "Bearish context; compression release pending"
        decisionPrimaryBlocker := "Compression Not Released"
        decisionNextReview := "After Compression Release"
    else if not decisionAcceptanceConfirmed
        decisionReason := "Bearish context; acceptance pending"
        decisionPrimaryBlocker := decisionAcceptanceTesting ? "Acceptance Pending" : decisionAcceptanceRejected ? "Acceptance Not Confirmed" : "Higher-Timeframe Acceptance Pending"
        decisionNextReview := decisionAcceptanceRejected ? "Next Reference Candle Close" : "After Acceptance Confirmation"
    else if decisionConfidenceLowDeveloping
        decisionReason := "Bearish context; confidence developing"
        decisionPrimaryBlocker := "Developing Confidence"
        decisionNextReview := "After Confidence Exceeds 60"
    else if not decisionConfidenceReadyThreshold
        decisionReason := "Bearish context; confidence below ready threshold"
        decisionPrimaryBlocker := "Confidence Below Ready Threshold"
        decisionNextReview := "After Confidence Exceeds 60"
    else if not decisionMomentumReady
        decisionReason := "Bearish context; momentum not ready"
        decisionPrimaryBlocker := "Momentum Not Ready"
        decisionNextReview := "After Momentum Improves"
    else if not decisionBearishOpportunity
        decisionReason := "Bearish context; opportunity not confirmed"
        decisionPrimaryBlocker := "Opportunity Pending"
        decisionNextReview := "After Opportunity Improves"
    else if not decisionReviewReady
        decisionReason := "Bearish context; review not ready"
        decisionPrimaryBlocker := "Review Pending"
        decisionNextReview := "After Review Readiness"
    else
        decisionReason := "Bearish context; setup incomplete"
        decisionPrimaryBlocker := "Readiness Not Complete"
        decisionNextReview := "After Missing Conditions Confirm"
else if decisionNeutralTrend
    decisionState := KR370_DECISION_WAIT
    decisionReason := "Trend direction not established"
    decisionPrimaryBlocker := "Neutral Trend"
    decisionNextReview := "After Trend Confirmation"
else if decisionCompressionBlocking
    decisionState := KR370_DECISION_WAIT
    decisionReason := "Compression building; breakout not confirmed"
    decisionPrimaryBlocker := "Compression Not Released"
    decisionNextReview := "After Compression Release"
else if decisionNoDirectionalOpportunity
    decisionState := KR370_DECISION_AVOID
    decisionReason := "No directional opportunity context"
    decisionPrimaryBlocker := "No Opportunity"
    decisionNextReview := "After New Context Forms"
else if decisionConfidenceLowDeveloping
    decisionState := KR370_DECISION_WAIT
    decisionReason := "Developing setup; confidence still building"
    decisionPrimaryBlocker := "Developing Confidence"
    decisionNextReview := "After Confidence Exceeds 60"
else if decisionConfidenceBelowReady
    decisionState := KR370_DECISION_WAIT
    decisionReason := outConfidenceReason
    decisionPrimaryBlocker := "Confidence Below Ready Threshold"
    decisionNextReview := "After Confidence Exceeds 60"
else
    decisionState := KR370_DECISION_WAIT
    decisionReason := "Wait for Higher-Timeframe Confirmation"
    decisionPrimaryBlocker := "Readiness Not Complete"
    decisionNextReview := "After Missing Conditions Confirm"

string decisionText = ""

switch decisionState
    KR370_DECISION_AVOID => decisionText := "AVOID"
    KR370_DECISION_WAIT => decisionText := "WAIT"
    KR370_DECISION_WATCH_LONG => decisionText := "WATCH LONG"
    KR370_DECISION_WATCH_SHORT => decisionText := "WATCH SHORT"
    KR370_DECISION_BUY_READY => decisionText := "BUY READY"
    KR370_DECISION_SELL_READY => decisionText := "SELL READY"

//==================================================================
// KR-370.50 DYNAMIC NEED CHECKLIST
//==================================================================

string decisionNeed1 = ""
string decisionNeed2 = ""
string decisionNeed3 = ""
int decisionNeedCount = 0

if not decisionDirectionalContext and decisionNeedCount < 3
    decisionNeedCount += 1
    if decisionNeedCount == 1
        decisionNeed1 := "☐ Trend Confirmation"
    else if decisionNeedCount == 2
        decisionNeed2 := "☐ Trend Confirmation"
    else
        decisionNeed3 := "☐ Trend Confirmation"

if decisionCompressionBlocking and decisionNeedCount < 3
    decisionNeedCount += 1
    if decisionNeedCount == 1
        decisionNeed1 := "☐ Compression Release"
    else if decisionNeedCount == 2
        decisionNeed2 := "☐ Compression Release"
    else
        decisionNeed3 := "☐ Compression Release"

if not decisionAcceptanceConfirmed and decisionNeedCount < 3
    decisionNeedCount += 1
    if decisionNeedCount == 1
        decisionNeed1 := "☐ Higher-Timeframe Acceptance Pending"
    else if decisionNeedCount == 2
        decisionNeed2 := "☐ Higher-Timeframe Acceptance Pending"
    else
        decisionNeed3 := "☐ Higher-Timeframe Acceptance Pending"

if not decisionConfidenceReadyThreshold and decisionNeedCount < 3
    decisionNeedCount += 1
    if decisionNeedCount == 1
        decisionNeed1 := "☐ Confidence > 60"
    else if decisionNeedCount == 2
        decisionNeed2 := "☐ Confidence > 60"
    else
        decisionNeed3 := "☐ Confidence > 60"

if not decisionMomentumReady and decisionNeedCount < 3
    decisionNeedCount += 1
    if decisionNeedCount == 1
        decisionNeed1 := "☐ Momentum Improves"
    else if decisionNeedCount == 2
        decisionNeed2 := "☐ Momentum Improves"
    else
        decisionNeed3 := "☐ Momentum Improves"

if ((decisionBullishContext and not decisionBullishOpportunity) or (decisionBearishContext and not decisionBearishOpportunity)) and decisionNeedCount < 3
    decisionNeedCount += 1
    if decisionNeedCount == 1
        decisionNeed1 := "☐ Opportunity Improves"
    else if decisionNeedCount == 2
        decisionNeed2 := "☐ Opportunity Improves"
    else
        decisionNeed3 := "☐ Opportunity Improves"

if not decisionReviewReady and decisionNeedCount < 3
    decisionNeedCount += 1
    if decisionNeedCount == 1
        decisionNeed1 := "☐ Review Gate Clears"
    else if decisionNeedCount == 2
        decisionNeed2 := "☐ Review Gate Clears"
    else
        decisionNeed3 := "☐ Review Gate Clears"

if (decisionState == KR370_DECISION_BUY_READY or decisionState == KR370_DECISION_SELL_READY) and decisionNeedCount < 3
    decisionNeedCount += 1
    if decisionNeedCount == 1
        decisionNeed1 := "✓ Trend Aligned"
    else if decisionNeedCount == 2
        decisionNeed2 := "✓ Trend Aligned"
    else
        decisionNeed3 := "✓ Trend Aligned"

if (decisionState == KR370_DECISION_BUY_READY or decisionState == KR370_DECISION_SELL_READY) and decisionNeedCount < 3
    decisionNeedCount += 1
    if decisionNeedCount == 1
        decisionNeed1 := "✓ Acceptance Confirmed"
    else if decisionNeedCount == 2
        decisionNeed2 := "✓ Acceptance Confirmed"
    else
        decisionNeed3 := "✓ Acceptance Confirmed"

if (decisionState == KR370_DECISION_BUY_READY or decisionState == KR370_DECISION_SELL_READY) and decisionNeedCount < 3
    decisionNeedCount += 1
    if decisionNeedCount == 1
        decisionNeed1 := "✓ Confidence > 60"
    else if decisionNeedCount == 2
        decisionNeed2 := "✓ Confidence > 60"
    else
        decisionNeed3 := "✓ Confidence > 60"

//==================================================================
// KR-370.60 PUBLIC INTERFACE
//==================================================================

bool outDecisionReady = decisionReady

int outDecisionState = decisionState

string outDecisionText = decisionText
string outDecisionReason = decisionReason
string outPrimaryBlocker = decisionPrimaryBlocker
string outNextReview = decisionNextReview
string outNeed1 = decisionNeed1
string outNeed2 = decisionNeed2
string outNeed3 = decisionNeed3

bool outDecisionAvoid = decisionState == KR370_DECISION_AVOID
bool outDecisionWait = decisionState == KR370_DECISION_WAIT
bool outDecisionWatchLong = decisionState == KR370_DECISION_WATCH_LONG
bool outDecisionWatchShort = decisionState == KR370_DECISION_WATCH_SHORT
bool outDecisionBuyReady = decisionState == KR370_DECISION_BUY_READY
bool outDecisionSellReady = decisionState == KR370_DECISION_SELL_READY

//==================================================================
// END OF KR-370
//==================================================================



//==================================================================
// KR-380A : Execution Context Adapter
// Version : 1.0.0
// Status  : FROZEN
// Last Updated : 2026-07-10
//
// Purpose:
// Provides the formal execution-context interface consumed by KR-380.
// This adapter is the approved exception that may read KR-260/KR-270
// reference datasets for timing context. KR-380 classification must
// consume these public adapter outputs instead of scattered raw
// reference variables.
//
// Validation Scope:
// - MCX self-contained execution support validated on Copper, Gold,
//   and Silver as part of the KR-380 timing freeze.
//
// Frozen Contract:
// - Approved narrow adapter exception for KR-380 timing.
// - Does not duplicate KR-300 through KR-370 intelligence.
// - Exposes only the minimum facts required by KR-380 timing.
// - Produces no alerts, orders, stops, targets, plots or labels.
//==================================================================

bool execContextMCXChart = assetMarket == "MCX"
bool execContextMCX1HChart = execContextMCXChart and timeframe.isintraday and timeframe.multiplier == 60
bool execContextLongIntent = outDecisionBuyReady or outDecisionWatchLong
bool execContextShortIntent = outDecisionSellReady or outDecisionWatchShort
bool execContextDirectionalIntent = execContextLongIntent or execContextShortIntent

float execContextRef4HRange = mdReferenceStructureH - mdReferenceStructureL
float execContextRef4HPrevRange = mdReferenceStructureH[1] - mdReferenceStructureL[1]

bool execContextRefDailyDataReady = not na(mdReferenceTrendC) and not na(indReferenceTrendSMA50)
bool execContextRef4HDataReady = not na(mdReferenceStructureC) and not na(mdReferenceStructureH[1]) and not na(mdReferenceStructureL[1]) and not na(execContextRef4HRange) and not na(execContextRef4HPrevRange)
bool execContextRef1HDataReady = not na(mdReferenceExecutionC) and not na(mdReferenceExecutionC[1])

bool execContextRefDailyBullishPermission = execContextRefDailyDataReady and mdReferenceTrendC > indReferenceTrendSMA50
bool execContextRefDailyBearishPermission = execContextRefDailyDataReady and mdReferenceTrendC < indReferenceTrendSMA50

bool execContextRef4HCompressionReady = execContextRef4HDataReady and execContextRef4HRange > execContextRef4HPrevRange * 0.80
bool execContextRef4HBullishPermission = execContextRef4HDataReady and mdReferenceStructureC > mdReferenceStructureH[1]
bool execContextRef4HBearishPermission = execContextRef4HDataReady and mdReferenceStructureC < mdReferenceStructureL[1]
bool execContextRef4HAcceptanceReady = execContextRef4HCompressionReady and ((execContextLongIntent and execContextRef4HBullishPermission) or (execContextShortIntent and execContextRef4HBearishPermission))

bool execContextRef1HBullishSupport = execContextRef1HDataReady and mdReferenceExecutionC >= mdReferenceExecutionC[1]
bool execContextRef1HBearishSupport = execContextRef1HDataReady and mdReferenceExecutionC <= mdReferenceExecutionC[1]
bool execContextRef1HMomentumReady = (execContextLongIntent and execContextRef1HBullishSupport) or (execContextShortIntent and execContextRef1HBearishSupport)

string execContextRefDailyBlockerText = ""

if not execContextDirectionalIntent
    execContextRefDailyBlockerText := "KR-370 Direction Pending"
else if not execContextRefDailyDataReady
    execContextRefDailyBlockerText := "COMEX D Data Pending"
else if execContextLongIntent and not execContextRefDailyBullishPermission
    execContextRefDailyBlockerText := "COMEX D Opposes Long"
else if execContextShortIntent and not execContextRefDailyBearishPermission
    execContextRefDailyBlockerText := "COMEX D Opposes Short"

string execContextRef4HBlockerText = ""

if not execContextRef4HDataReady
    execContextRef4HBlockerText := "COMEX 4H Data Pending"
else if not execContextRef4HCompressionReady
    execContextRef4HBlockerText := "COMEX 4H Compression"
else if execContextLongIntent and not execContextRef4HBullishPermission
    execContextRef4HBlockerText := "COMEX 4H Acceptance"
else if execContextShortIntent and not execContextRef4HBearishPermission
    execContextRef4HBlockerText := "COMEX 4H Acceptance"

string execContextRef1HBlockerText = ""

if not execContextRef1HDataReady
    execContextRef1HBlockerText := "COMEX 1H Data Pending"
else if execContextLongIntent and not execContextRef1HBullishSupport
    execContextRef1HBlockerText := "COMEX 1H Momentum"
else if execContextShortIntent and not execContextRef1HBearishSupport
    execContextRef1HBlockerText := "COMEX 1H Momentum"

string execContextMCX1HBlockerText = execContextMCX1HChart ? "" : "MCX 1H Chart Required"

bool outExecRefDailyBullishPermission = execContextRefDailyBullishPermission
bool outExecRefDailyBearishPermission = execContextRefDailyBearishPermission
string outExecRefDailyBlockerText = execContextRefDailyBlockerText

bool outExecRef4HBullishPermission = execContextRef4HBullishPermission
bool outExecRef4HBearishPermission = execContextRef4HBearishPermission
bool outExecRef4HAcceptanceReady = execContextRef4HAcceptanceReady
bool outExecRef4HCompressionReady = execContextRef4HCompressionReady
string outExecRef4HBlockerText = execContextRef4HBlockerText

bool outExecRef1HBullishSupport = execContextRef1HBullishSupport
bool outExecRef1HBearishSupport = execContextRef1HBearishSupport
bool outExecRef1HMomentumReady = execContextRef1HMomentumReady
string outExecRef1HBlockerText = execContextRef1HBlockerText

bool outExecMCX1HContextReady = execContextMCX1HChart
string outExecMCX1HBlockerText = execContextMCX1HBlockerText

bool outExecContextReady = outExecMCX1HContextReady and (outExecRefDailyBlockerText == "") and (outExecRef4HBlockerText == "") and (outExecRef1HBlockerText == "")



//==================================================================
// KR-380 : Execution Trigger Engine
// Version : 1.0.0
// Status  : FROZEN
// Last Updated : 2026-07-10
//
// Purpose:
// Transforms KR-370 BUY READY / SELL READY decisions into executable
// timing states.
//
// Validation Scope:
// - Execution timing validation on Copper, Gold, and Silver.
// - Confirmed MCX 1H finality for BUY NOW, SELL NOW, FAILED, and
//   EXTENDED.
//
// Frozen Contract:
// - KR-370 owns direction and readiness.
// - KR-380 owns execution timing only.
// - KR-380 depends on the formal Execution Context Adapter.
// - Intrabar state may be FORMING.
// - BUY NOW, SELL NOW, FAILED and EXTENDED require a confirmed
//   MCX 1H bar.
// - No alerts.
// - No trade management.
// - No stops, targets, labels, plots or orders.
//==================================================================

//==================================================================
// KR-380.10 TRIGGER STATE CONSTANTS
//==================================================================

const int KR380_TRIGGER_NONE = 0
const int KR380_TRIGGER_FORMING_LONG = 1
const int KR380_TRIGGER_FORMING_SHORT = 2
const int KR380_TRIGGER_BUY = 3
const int KR380_TRIGGER_SELL = 4
const int KR380_TRIGGER_FAILED = 5
const int KR380_TRIGGER_EXTENDED = 6

//==================================================================
// KR-380.20 INPUT READINESS
//==================================================================

bool triggerDecisionReady = outDecisionReady
bool triggerAcceptanceReady = outBarrierReady
bool triggerConfidenceReady = outConfidenceReady
bool triggerCompressionReady = outCompressionReady
bool triggerMomentumReady = outMomentumReady
bool triggerOpportunityReady = outOpportunityInputReady
bool triggerQualityReady = outEvidenceReady

bool triggerBaseReady = triggerDecisionReady and triggerAcceptanceReady and triggerConfidenceReady and triggerCompressionReady and triggerMomentumReady and triggerOpportunityReady and triggerQualityReady

//==================================================================
// KR-380.25 EXECUTION CONTEXT INPUT MAP
//==================================================================

bool triggerMCX1HChart = outExecMCX1HContextReady
bool triggerLongIntent = outDecisionBuyReady or outDecisionWatchLong
bool triggerShortIntent = outDecisionSellReady or outDecisionWatchShort
bool triggerDirectionalIntent = triggerLongIntent or triggerShortIntent
bool triggerBarConfirmed = triggerMCX1HChart and barstate.isconfirmed

bool triggerRefDailyReady = (triggerLongIntent and outExecRefDailyBullishPermission) or (triggerShortIntent and outExecRefDailyBearishPermission)
bool triggerRef4HReady = outExecRef4HAcceptanceReady
bool triggerRef1HReady = outExecRef1HMomentumReady

string triggerRefDailyBlocker = outExecRefDailyBlockerText
string triggerRef4HBlocker = outExecRef4HBlockerText
string triggerRef1HBlocker = outExecRef1HBlockerText

//==================================================================
// KR-380.30 PUBLIC CONDITION MAP
//==================================================================

bool triggerBuyReady = triggerBaseReady and triggerMCX1HChart and outDecisionBuyReady
bool triggerSellReady = triggerBaseReady and triggerMCX1HChart and outDecisionSellReady
bool triggerReadySetup = triggerBuyReady or triggerSellReady

bool triggerAcceptanceConfirmed = triggerAcceptanceReady and (outAcceptanceAccepted or outAcceptanceStrong)
bool triggerAcceptanceRejected = triggerAcceptanceReady and outAcceptanceRejected

bool triggerConfidenceConfirmed = triggerConfidenceReady and outConfidenceScore > 60
bool triggerConfidenceFell = triggerConfidenceReady and outConfidenceScore <= 40

bool triggerCompressionBlocking = triggerCompressionReady and not outExpansionStarted and (outCompressionBuilding or outCompressionStrong or outCompressionCritical)
bool triggerCompressionClear = triggerCompressionReady and (outExpansionStarted or not triggerCompressionBlocking)

bool triggerMomentumConfirmed = triggerMomentumReady and (outMomentumNormal or outMomentumStrong or outMomentumBuilding)

bool triggerOpportunityPresent = triggerOpportunityReady and not outNoOpportunityContext
bool triggerOpportunityMissing = triggerOpportunityReady and outNoOpportunityContext

bool triggerExtended = triggerBaseReady and triggerReadySetup and outTrendQualityExtended
bool triggerFailed = triggerBaseReady and triggerReadySetup and (triggerAcceptanceRejected or triggerConfidenceFell or triggerOpportunityMissing)
bool triggerFinalStateAllowed = triggerBarConfirmed
bool triggerExtendedFinal = triggerExtended and triggerFinalStateAllowed
bool triggerFailedFinal = triggerFailed and triggerFinalStateAllowed
bool triggerMCXExecutionReady = triggerMCX1HChart and triggerAcceptanceConfirmed and triggerConfidenceConfirmed and triggerCompressionClear and triggerMomentumConfirmed and triggerOpportunityPresent

string triggerMCXExecutionBlocker = ""

if triggerFailed
    triggerMCXExecutionBlocker := "MCX 1H Trigger Failed"
else if triggerExtended
    triggerMCXExecutionBlocker := "MCX 1H Extended"
else if outExecMCX1HBlockerText != ""
    triggerMCXExecutionBlocker := outExecMCX1HBlockerText
else if not triggerAcceptanceConfirmed
    triggerMCXExecutionBlocker := "MCX 1H Acceptance"
else if not triggerConfidenceConfirmed
    triggerMCXExecutionBlocker := "MCX 1H Confidence > 60"
else if not triggerCompressionClear
    triggerMCXExecutionBlocker := "MCX 1H Compression"
else if not triggerMomentumConfirmed
    triggerMCXExecutionBlocker := "MCX 1H Momentum"
else if not triggerOpportunityPresent
    triggerMCXExecutionBlocker := "MCX 1H Opportunity"
else if not triggerMCXExecutionReady
    triggerMCXExecutionBlocker := "MCX 1H Breakout"

bool triggerExecutionContextReady = triggerRefDailyReady and triggerRef4HReady and triggerRef1HReady and triggerMCXExecutionReady

bool triggerBuyNow = triggerBuyReady and triggerFinalStateAllowed and triggerRefDailyReady and triggerRef4HReady and triggerRef1HReady and triggerMCXExecutionReady and not triggerExtended and not triggerFailed
bool triggerSellNow = triggerSellReady and triggerFinalStateAllowed and triggerRefDailyReady and triggerRef4HReady and triggerRef1HReady and triggerMCXExecutionReady and not triggerExtended and not triggerFailed

bool triggerLongForming = triggerBuyReady and not triggerBuyNow and not triggerExtendedFinal and not triggerFailedFinal
bool triggerShortForming = triggerSellReady and not triggerSellNow and not triggerExtendedFinal and not triggerFailedFinal

//==================================================================
// KR-380.35 EXECUTION NEEDS
//==================================================================

translateExecutionNeed(string blocker) =>
    string translated = blocker

    switch blocker
        "KR Data Pending" => translated := "Waiting for market data"
        "KR Review Blocked" => translated := "Review gate blocked"
        "KR-370 Not Ready" => translated := "Waiting for setup readiness"
        "KR-370 Direction Pending" => translated := "Waiting for trend confirmation"
        "COMEX D Data Pending" => translated := "Waiting for COMEX Daily data"
        "COMEX D Opposes Long" => translated := "Waiting for COMEX Daily trend alignment"
        "COMEX D Opposes Short" => translated := "Waiting for COMEX Daily trend alignment"
        "COMEX 4H Data Pending" => translated := "Waiting for COMEX 4H data"
        "COMEX 4H Compression" => translated := "Waiting for COMEX 4H breakout"
        "COMEX 4H Acceptance" => translated := "Waiting for COMEX 4H price acceptance"
        "COMEX 1H Data Pending" => translated := "Waiting for COMEX 1H data"
        "COMEX 1H Momentum" => translated := "Waiting for COMEX 1H momentum"
        "MCX 1H Trigger Failed" => translated := "Execution setup failed"
        "MCX 1H Extended" => translated := "Price is extended"
        "MCX 1H Chart Required" => translated := "Switch to MCX 1H chart"
        "MCX 1H Acceptance" => translated := "Waiting for MCX 1H price acceptance"
        "MCX 1H Confidence > 60" => translated := "Waiting for MCX 1H confidence"
        "MCX 1H Compression" => translated := "Waiting for MCX 1H breakout"
        "MCX 1H Momentum" => translated := "Waiting for MCX 1H momentum"
        "MCX 1H Opportunity" => translated := "Waiting for opportunity"
        "MCX 1H Breakout" => translated := "Waiting for MCX 1H confirmation"

    translated

string triggerExecutionNeed1 = ""
string triggerExecutionNeed2 = ""
string triggerExecutionNeed3 = ""
int triggerExecutionNeedCount = 0
bool triggerExecutionQueueActive = not triggerBuyNow and not triggerSellNow
string triggerExecutionNeedCandidate = ""

if triggerExecutionQueueActive and not triggerBaseReady and triggerExecutionNeedCount < 3
    triggerExecutionNeedCandidate := translateExecutionNeed("KR Data Pending")
    if triggerExecutionNeedCandidate != "" and triggerExecutionNeedCandidate != triggerExecutionNeed1 and triggerExecutionNeedCandidate != triggerExecutionNeed2 and triggerExecutionNeedCandidate != triggerExecutionNeed3
        triggerExecutionNeedCount += 1
        if triggerExecutionNeedCount == 1
            triggerExecutionNeed1 := triggerExecutionNeedCandidate
        else if triggerExecutionNeedCount == 2
            triggerExecutionNeed2 := triggerExecutionNeedCandidate
        else
            triggerExecutionNeed3 := triggerExecutionNeedCandidate

if triggerExecutionQueueActive and triggerBaseReady and outDecisionAvoid and outPrimaryBlocker == "Review Blocked" and triggerExecutionNeedCount < 3
    triggerExecutionNeedCandidate := translateExecutionNeed("KR Review Blocked")
    if triggerExecutionNeedCandidate != "" and triggerExecutionNeedCandidate != triggerExecutionNeed1 and triggerExecutionNeedCandidate != triggerExecutionNeed2 and triggerExecutionNeedCandidate != triggerExecutionNeed3
        triggerExecutionNeedCount += 1
        if triggerExecutionNeedCount == 1
            triggerExecutionNeed1 := triggerExecutionNeedCandidate
        else if triggerExecutionNeedCount == 2
            triggerExecutionNeed2 := triggerExecutionNeedCandidate
        else
            triggerExecutionNeed3 := triggerExecutionNeedCandidate

if triggerExecutionQueueActive and triggerBaseReady and not triggerDirectionalIntent and triggerExecutionNeedCount < 3
    triggerExecutionNeedCandidate := translateExecutionNeed("KR-370 Not Ready")
    if triggerExecutionNeedCandidate != "" and triggerExecutionNeedCandidate != triggerExecutionNeed1 and triggerExecutionNeedCandidate != triggerExecutionNeed2 and triggerExecutionNeedCandidate != triggerExecutionNeed3
        triggerExecutionNeedCount += 1
        if triggerExecutionNeedCount == 1
            triggerExecutionNeed1 := triggerExecutionNeedCandidate
        else if triggerExecutionNeedCount == 2
            triggerExecutionNeed2 := triggerExecutionNeedCandidate
        else
            triggerExecutionNeed3 := triggerExecutionNeedCandidate

if triggerExecutionQueueActive and (triggerFailedFinal or triggerExtendedFinal) and triggerMCXExecutionBlocker != "" and triggerExecutionNeedCount < 3
    triggerExecutionNeedCandidate := translateExecutionNeed(triggerMCXExecutionBlocker)
    if triggerExecutionNeedCandidate != "" and triggerExecutionNeedCandidate != triggerExecutionNeed1 and triggerExecutionNeedCandidate != triggerExecutionNeed2 and triggerExecutionNeedCandidate != triggerExecutionNeed3
        triggerExecutionNeedCount += 1
        if triggerExecutionNeedCount == 1
            triggerExecutionNeed1 := triggerExecutionNeedCandidate
        else if triggerExecutionNeedCount == 2
            triggerExecutionNeed2 := triggerExecutionNeedCandidate
        else
            triggerExecutionNeed3 := triggerExecutionNeedCandidate

if triggerExecutionQueueActive and triggerRefDailyBlocker != "" and triggerExecutionNeedCount < 3
    triggerExecutionNeedCandidate := translateExecutionNeed(triggerRefDailyBlocker)
    if triggerExecutionNeedCandidate != "" and triggerExecutionNeedCandidate != triggerExecutionNeed1 and triggerExecutionNeedCandidate != triggerExecutionNeed2 and triggerExecutionNeedCandidate != triggerExecutionNeed3
        triggerExecutionNeedCount += 1
        if triggerExecutionNeedCount == 1
            triggerExecutionNeed1 := triggerExecutionNeedCandidate
        else if triggerExecutionNeedCount == 2
            triggerExecutionNeed2 := triggerExecutionNeedCandidate
        else
            triggerExecutionNeed3 := triggerExecutionNeedCandidate

if triggerExecutionQueueActive and triggerRef4HBlocker != "" and triggerExecutionNeedCount < 3
    triggerExecutionNeedCandidate := translateExecutionNeed(triggerRef4HBlocker)
    if triggerExecutionNeedCandidate != "" and triggerExecutionNeedCandidate != triggerExecutionNeed1 and triggerExecutionNeedCandidate != triggerExecutionNeed2 and triggerExecutionNeedCandidate != triggerExecutionNeed3
        triggerExecutionNeedCount += 1
        if triggerExecutionNeedCount == 1
            triggerExecutionNeed1 := triggerExecutionNeedCandidate
        else if triggerExecutionNeedCount == 2
            triggerExecutionNeed2 := triggerExecutionNeedCandidate
        else
            triggerExecutionNeed3 := triggerExecutionNeedCandidate

if triggerExecutionQueueActive and triggerRef1HBlocker != "" and triggerExecutionNeedCount < 3
    triggerExecutionNeedCandidate := translateExecutionNeed(triggerRef1HBlocker)
    if triggerExecutionNeedCandidate != "" and triggerExecutionNeedCandidate != triggerExecutionNeed1 and triggerExecutionNeedCandidate != triggerExecutionNeed2 and triggerExecutionNeedCandidate != triggerExecutionNeed3
        triggerExecutionNeedCount += 1
        if triggerExecutionNeedCount == 1
            triggerExecutionNeed1 := triggerExecutionNeedCandidate
        else if triggerExecutionNeedCount == 2
            triggerExecutionNeed2 := triggerExecutionNeedCandidate
        else
            triggerExecutionNeed3 := triggerExecutionNeedCandidate

if triggerExecutionQueueActive and not triggerFailedFinal and not triggerExtendedFinal and triggerMCXExecutionBlocker != "" and triggerExecutionNeedCount < 3
    triggerExecutionNeedCandidate := translateExecutionNeed(triggerMCXExecutionBlocker)
    if triggerExecutionNeedCandidate != "" and triggerExecutionNeedCandidate != triggerExecutionNeed1 and triggerExecutionNeedCandidate != triggerExecutionNeed2 and triggerExecutionNeedCandidate != triggerExecutionNeed3
        triggerExecutionNeedCount += 1
        if triggerExecutionNeedCount == 1
            triggerExecutionNeed1 := triggerExecutionNeedCandidate
        else if triggerExecutionNeedCount == 2
            triggerExecutionNeed2 := triggerExecutionNeedCandidate
        else
            triggerExecutionNeed3 := triggerExecutionNeedCandidate

string triggerExecutionPrimaryBlocker = triggerExecutionNeed1
string triggerExecutionReason = triggerExecutionPrimaryBlocker == "" ? "Execution timing complete" : triggerExecutionPrimaryBlocker

//==================================================================
// KR-380.40 TRIGGER CLASSIFICATION
//==================================================================

int triggerState = KR380_TRIGGER_NONE
string triggerReason = ""

if not triggerBaseReady
    triggerState := KR380_TRIGGER_NONE
    triggerReason := "Waiting for market data"
else if not triggerReadySetup
    triggerState := KR380_TRIGGER_NONE
    triggerReason := triggerExecutionReason
else if triggerFailedFinal
    triggerState := KR380_TRIGGER_FAILED
    triggerReason := triggerExecutionReason
else if triggerExtendedFinal
    triggerState := KR380_TRIGGER_EXTENDED
    triggerReason := triggerExecutionReason
else if triggerBuyNow
    triggerState := KR380_TRIGGER_BUY
    triggerReason := "Entry timing confirmed"
else if triggerSellNow
    triggerState := KR380_TRIGGER_SELL
    triggerReason := "Entry timing confirmed"
else if triggerLongForming
    triggerState := KR380_TRIGGER_FORMING_LONG
    triggerReason := triggerExecutionReason
else if triggerShortForming
    triggerState := KR380_TRIGGER_FORMING_SHORT
    triggerReason := triggerExecutionReason
else
    triggerState := KR380_TRIGGER_NONE
    triggerReason := triggerExecutionReason

string triggerText = ""

switch triggerState
    KR380_TRIGGER_FORMING_LONG => triggerText := "FORMING"
    KR380_TRIGGER_FORMING_SHORT => triggerText := "FORMING"
    KR380_TRIGGER_BUY => triggerText := "BUY NOW"
    KR380_TRIGGER_SELL => triggerText := "SELL NOW"
    KR380_TRIGGER_FAILED => triggerText := "FAILED"
    KR380_TRIGGER_EXTENDED => triggerText := "EXTENDED"
    => triggerText := "NO TRIGGER"

//==================================================================
// KR-380.50 PUBLIC INTERFACE
//==================================================================

bool outTriggerReady = triggerBaseReady
bool outTriggerBarConfirmed = triggerBarConfirmed

int outTriggerState = triggerState

string outTriggerText = triggerText
string outTriggerReason = triggerReason

bool outTriggerNone = triggerState == KR380_TRIGGER_NONE
bool outTriggerFormingLong = triggerState == KR380_TRIGGER_FORMING_LONG
bool outTriggerFormingShort = triggerState == KR380_TRIGGER_FORMING_SHORT
bool outTriggerBuy = triggerState == KR380_TRIGGER_BUY
bool outTriggerSell = triggerState == KR380_TRIGGER_SELL
bool outTriggerFailed = triggerState == KR380_TRIGGER_FAILED
bool outTriggerExtended = triggerState == KR380_TRIGGER_EXTENDED

bool outExecutionContextReady = triggerExecutionContextReady

bool outRefDailyReady = triggerRefDailyReady
string outRefDailyBlocker = triggerRefDailyBlocker

bool outRef4HReady = triggerRef4HReady
string outRef4HBlocker = triggerRef4HBlocker

bool outRef1HReady = triggerRef1HReady
string outRef1HBlocker = triggerRef1HBlocker

bool outMCXExecutionReady = triggerMCXExecutionReady
string outMCXExecutionBlocker = triggerMCXExecutionBlocker

string outExecutionNeed1 = triggerExecutionNeed1
string outExecutionNeed2 = triggerExecutionNeed2
string outExecutionNeed3 = triggerExecutionNeed3
string outExecutionPrimaryBlocker = triggerExecutionPrimaryBlocker
string outExecutionReason = triggerExecutionReason

//==================================================================
// END OF KR-380
//==================================================================



//==================================================================
// KR-390A : Trade Management Execution Adapter
// Version : 0.1.0
// Status  : FOUNDATION
// Last Updated : 2026-07-10
//
// Purpose:
// Provides the narrow confirmed execution-timeframe structure facts
// required by KR-390. This adapter is intentionally small and does
// not duplicate KR-275 or create a new structure engine.
//
// Stop Source:
// - Long stop uses the lowest completed MCX 1H low from the prior
//   five execution bars.
// - Short stop uses the highest completed MCX 1H high from the prior
//   five execution bars.
// - These are model stop references, not broker instructions.
//==================================================================

const int KR390_EXECUTION_SWING_LOOKBACK = 5

float tradeExecutionConfirmedSwingLow = ta.lowest(mdPrimaryExecutionL[1], KR390_EXECUTION_SWING_LOOKBACK)
float tradeExecutionConfirmedSwingHigh = ta.highest(mdPrimaryExecutionH[1], KR390_EXECUTION_SWING_LOOKBACK)

bool outTradeExecutionContextReady = outExecMCX1HContextReady and not na(mdPrimaryExecutionC)
bool outTradeExecutionStopReady = outTradeExecutionContextReady and not na(tradeExecutionConfirmedSwingLow) and not na(tradeExecutionConfirmedSwingHigh)

float outTradeExecutionClose = mdPrimaryExecutionC
float outTradeExecutionSwingLow = tradeExecutionConfirmedSwingLow
float outTradeExecutionSwingHigh = tradeExecutionConfirmedSwingHigh



//==================================================================
// KR-390 : Trade Management Engine
// Version : 0.1.0
// Status  : FOUNDATION
// Last Updated : 2026-07-10
//
// Purpose:
// Manages a persistent model trade after a confirmed KR-380 BUY NOW
// or SELL NOW trigger.
//
// Contract:
// - KR-370 owns direction/readiness.
// - KR-380 owns entry timing.
// - KR-390 owns post-trigger model trade state and protection.
// - No alerts, broker orders, position sizing, partial exits, stops
//   sent to broker, targets sent to broker, plots or labels.
// - Model entry price is the confirmed MCX 1H trigger-bar close and
//   is not the user's broker fill.
//==================================================================

//==================================================================
// KR-390.10 TRADE STATE CONSTANTS
//==================================================================

const int KR390_TRADE_NONE = 0
const int KR390_TRADE_ACTIVE = 1
const int KR390_TRADE_HOLD = 2
const int KR390_TRADE_PROTECT = 3
const int KR390_TRADE_TRAIL = 4
const int KR390_TRADE_EXIT = 5
const int KR390_TRADE_INVALIDATED = 6

const int KR390_DIRECTION_SHORT = -1
const int KR390_DIRECTION_NONE = 0
const int KR390_DIRECTION_LONG = 1

//==================================================================
// KR-390.20 PERSISTENT MODEL TRADE MEMORY
//==================================================================

var bool tradeModelActive = false
var int tradeModelDirection = KR390_DIRECTION_NONE
var int tradeModelState = KR390_TRADE_NONE
var int tradeModelEntryBarIndex = na

var float tradeModelEntryPrice = na
var float tradeInitialStopPrice = na
var float tradeManagedStopPrice = na
var float tradeTarget1Price = na
var float tradeTarget2Price = na
var float tradeInitialRisk = na

var string tradeModelReason = "No confirmed trigger"

//==================================================================
// KR-390.30 START CONDITIONS
//==================================================================

bool tradeStartLongSignal = outTriggerBuy and outTriggerBarConfirmed and outExecMCX1HContextReady
bool tradeStartShortSignal = outTriggerSell and outTriggerBarConfirmed and outExecMCX1HContextReady
bool tradeStartSignal = tradeStartLongSignal or tradeStartShortSignal

float tradeCandidateEntryPrice = outTradeExecutionClose
float tradeCandidateInitialStop = tradeStartLongSignal ? outTradeExecutionSwingLow : tradeStartShortSignal ? outTradeExecutionSwingHigh : na
float tradeCandidateRisk = math.abs(tradeCandidateEntryPrice - tradeCandidateInitialStop)

bool tradeCandidateDataReady = outTradeExecutionContextReady and outTradeExecutionStopReady and not na(tradeCandidateEntryPrice) and not na(tradeCandidateInitialStop)
bool tradeCandidateLongValid = tradeStartLongSignal and tradeCandidateDataReady and tradeCandidateInitialStop < tradeCandidateEntryPrice and tradeCandidateRisk > 0.0
bool tradeCandidateShortValid = tradeStartShortSignal and tradeCandidateDataReady and tradeCandidateInitialStop > tradeCandidateEntryPrice and tradeCandidateRisk > 0.0
bool tradeCandidateValid = tradeCandidateLongValid or tradeCandidateShortValid

//==================================================================
// KR-390.40 ACTIVE TRADE MANAGEMENT
//==================================================================

bool tradeConfirmedManagementBar = outExecMCX1HContextReady and barstate.isconfirmed
bool tradeLongActive = tradeModelActive and tradeModelDirection == KR390_DIRECTION_LONG
bool tradeShortActive = tradeModelActive and tradeModelDirection == KR390_DIRECTION_SHORT

if tradeModelActive and tradeConfirmedManagementBar
    bool tradeLongStopBreached = tradeLongActive and outTradeExecutionClose <= tradeManagedStopPrice
    bool tradeShortStopBreached = tradeShortActive and outTradeExecutionClose >= tradeManagedStopPrice

    if tradeLongStopBreached or tradeShortStopBreached
        tradeModelActive := false
        tradeModelState := KR390_TRADE_EXIT
        tradeModelReason := "Managed stop breached on confirmed MCX 1H close"
    else
        float tradeProgress = tradeLongActive ? outTradeExecutionClose - tradeModelEntryPrice : tradeShortActive ? tradeModelEntryPrice - outTradeExecutionClose : 0.0
        float tradeRMultiple = tradeInitialRisk > 0.0 ? tradeProgress / tradeInitialRisk : 0.0

        if tradeRMultiple >= 2.0 and outTradeExecutionStopReady
            if tradeLongActive
                tradeManagedStopPrice := math.max(tradeManagedStopPrice, math.max(tradeModelEntryPrice, outTradeExecutionSwingLow))
            else if tradeShortActive
                tradeManagedStopPrice := math.min(tradeManagedStopPrice, math.min(tradeModelEntryPrice, outTradeExecutionSwingHigh))

            tradeModelState := KR390_TRADE_TRAIL
            tradeModelReason := "Trailing stop from confirmed execution structure"
        else if tradeRMultiple >= 1.0
            if tradeLongActive
                tradeManagedStopPrice := math.max(tradeManagedStopPrice, tradeModelEntryPrice)
            else if tradeShortActive
                tradeManagedStopPrice := math.min(tradeManagedStopPrice, tradeModelEntryPrice)

            tradeModelState := KR390_TRADE_PROTECT
            tradeModelReason := "Initial risk protected at 1R progress"
        else
            tradeModelState := KR390_TRADE_HOLD
            tradeModelReason := "Model trade active"

//==================================================================
// KR-390.50 TRADE START / INVALIDATION
//==================================================================

if not tradeModelActive and tradeStartSignal
    if tradeCandidateValid
        tradeModelActive := true
        tradeModelDirection := tradeStartLongSignal ? KR390_DIRECTION_LONG : KR390_DIRECTION_SHORT
        tradeModelEntryPrice := tradeCandidateEntryPrice
        tradeInitialStopPrice := tradeCandidateInitialStop
        tradeManagedStopPrice := tradeCandidateInitialStop
        tradeInitialRisk := tradeCandidateRisk
        tradeModelEntryBarIndex := bar_index

        if tradeStartLongSignal
            tradeTarget1Price := tradeModelEntryPrice + tradeInitialRisk
            tradeTarget2Price := tradeModelEntryPrice + tradeInitialRisk * 2.0
        else
            tradeTarget1Price := tradeModelEntryPrice - tradeInitialRisk
            tradeTarget2Price := tradeModelEntryPrice - tradeInitialRisk * 2.0

        tradeModelState := KR390_TRADE_ACTIVE
        tradeModelReason := "Confirmed KR-380 trigger started model trade"
    else
        tradeModelActive := false
        tradeModelState := KR390_TRADE_INVALIDATED
        tradeModelReason := "Entry or initial stop unavailable"

else if tradeModelActive and tradeStartSignal
    tradeModelReason := "Active model trade; new trigger ignored"

else if not tradeModelActive and tradeModelState != KR390_TRADE_EXIT and tradeModelState != KR390_TRADE_INVALIDATED
    tradeModelState := KR390_TRADE_NONE
    tradeModelReason := "No confirmed trigger"

//==================================================================
// KR-390.60 PUBLIC CLASSIFICATION
//==================================================================

string tradeModelText = ""

switch tradeModelState
    KR390_TRADE_ACTIVE => tradeModelText := "HOLD"
    KR390_TRADE_HOLD => tradeModelText := "HOLD"
    KR390_TRADE_PROTECT => tradeModelText := "PROTECT"
    KR390_TRADE_TRAIL => tradeModelText := "TRAIL"
    KR390_TRADE_EXIT => tradeModelText := "EXIT"
    KR390_TRADE_INVALIDATED => tradeModelText := "INVALIDATED"
    => tradeModelText := "NO TRADE"

//==================================================================
// KR-390.70 PUBLIC INTERFACE
//==================================================================

bool outTradeManagementReady = outTradeExecutionContextReady

bool outTradeActive = tradeModelActive
int outTradeDirection = tradeModelDirection
int outTradeState = tradeModelState

string outTradeText = tradeModelText
string outTradeReason = tradeModelReason

float outModelEntryPrice = tradeModelEntryPrice
float outInitialStopPrice = tradeInitialStopPrice
float outManagedStopPrice = tradeManagedStopPrice
float outTarget1Price = tradeTarget1Price
float outTarget2Price = tradeTarget2Price

bool outTradeHold = tradeModelState == KR390_TRADE_ACTIVE or tradeModelState == KR390_TRADE_HOLD
bool outTradeProtect = tradeModelState == KR390_TRADE_PROTECT
bool outTradeTrail = tradeModelState == KR390_TRADE_TRAIL
bool outTradeExit = tradeModelState == KR390_TRADE_EXIT
bool outTradeInvalidated = tradeModelState == KR390_TRADE_INVALIDATED

//==================================================================
// END OF KR-390
//==================================================================



//==================================================================
// KR-400 : Execution Alert Engine
// Version : 0.1.0
// Status  : FOUNDATION
// Last Updated : 2026-07-10
//
// Purpose:
// Creates TradingView alerts only when a new confirmed KR-380 BUY NOW
// or SELL NOW event occurs.
//
// Contract:
// - KR-380 owns execution timing.
// - KR-400 consumes KR-380 public outputs only.
// - Alerts fire only for new confirmed BUY NOW / SELL NOW events.
// - Alerts are TradingView alerts.
// - Mobile delivery depends on the user enabling push notifications
//   in TradingView.
// - No broker order is placed.
// - No automated trade execution occurs.
//==================================================================

//==================================================================
// KR-400.10 ALERT CONTEXT
//==================================================================

bool alertContextValid = outTriggerReady and outTriggerBarConfirmed and barstate.isconfirmed
bool alertBuyEvent = alertContextValid and outTriggerBuy and not (outTriggerBuy[1] == true)
bool alertSellEvent = alertContextValid and outTriggerSell and not (outTriggerSell[1] == true)

//==================================================================
// KR-400.20 TRADINGVIEW ALERT CONDITIONS
//==================================================================

alertcondition(alertBuyEvent, title="KRONOS BUY NOW", message="KRONOS BUY NOW | {{ticker}} | {{interval}} | Price: {{close}}")

alertcondition(alertSellEvent, title="KRONOS SELL NOW", message="KRONOS SELL NOW | {{ticker}} | {{interval}} | Price: {{close}}")

//==================================================================
// KR-400.30 PUBLIC INTERFACE
//==================================================================

bool outAlertBuyEvent = alertBuyEvent
bool outAlertSellEvent = alertSellEvent
bool outAlertReady = outTriggerReady

string outAlertStatusText = outAlertBuyEvent ? "BUY ALERT FIRED" : outAlertSellEvent ? "SELL ALERT FIRED" : outAlertReady ? "READY" : "INVALID CONTEXT"

//==================================================================
// END OF KR-400
//==================================================================



//==================================================================
// KR-705 : Engine Status Panel
// Version : 0.1.2
// Status  : FROZEN
// Last Updated : 2026-07-10
//
// Frozen Contract:
// - Core behavior is validated and should not be changed casually.
// - Future changes must be additive, compatibility-safe, or bug fixes.
// - No trading decisions/signals should be added inside this engine
//   unless that is the engine's explicit responsibility.
// - Trader-facing intelligence/display layer only.
// - Displays public engine outputs and concise trader-readable status.
// - Should not expose internal diagnostic variables unless temporarily
//   debugging.
//==================================================================
//
// Purpose
// -------
// Display current KRONOS engine states for trader review.
//
// Dependencies
// ------------
// KR-300 Trend Foundation Engine
// KR-310 Trend Quality Engine
// KR-315 Compression Intelligence Engine
// KR-320 Market Acceptance Engine
// KR-330 Momentum Confirmation Engine
// KR-335 Price Action Evidence Engine
// KR-345 Relative Intelligence Engine
// KR-350 Opportunity Foundation Engine
// KR-360 Confidence Engine
// KR-370 Decision Engine
// KR-380 Execution Trigger Engine
// KR-390 Trade Management Engine
// KR-400 Execution Alert Engine, where alert status is applicable
//
// NOTE
// ----
// KR-705 performs no calculations, alerts, signals or trading
// decisions. Decision, entry, trade-management, and alert ownership
// remain with KR-370, KR-380, KR-390, and KR-400 respectively.
//==================================================================

//==================================================================
// KR-705.10 CONFIGURATION
//==================================================================

showDeveloperDebugPanel = input.bool(false, "Show Developer Debug Panel", group="KR-700 Developer Tools")

//==================================================================
// KR-705.20 DISPLAY VALUES
//==================================================================

bool kr705TrendAvailable = outTrendDataReady
bool kr705TrendQualityAvailable = outEvidenceReady
bool kr705AcceptanceAvailable = outBarrierReady
bool kr705MomentumAvailable = outMomentumReady
bool kr705CompressionAvailable = outCompressionReady
bool kr705OpportunityAvailable = outOpportunityInputReady
bool kr705PriceActionAvailable = outPriceActionReady
bool kr705RelativeAvailable = outRelativeReady
bool kr705ConfidenceAvailable = outConfidenceReady
bool kr705CoreDataReady = kr705TrendAvailable and kr705TrendQualityAvailable and kr705AcceptanceAvailable and kr705MomentumAvailable

string kr705UnavailableText = "—"
string kr705NotAvailableText = "N/A"
string kr705TrendText = kr705TrendAvailable ? outBullishTrend ? "Bullish" : outBearishTrend ? "Bearish" : "Neutral" : kr705UnavailableText
string kr705TrendQualityText = kr705TrendQualityAvailable ? outTrendQualityExcellent ? "Excellent" : outTrendQualityHealthy ? "Healthy" : outTrendQualityWeak ? "Weak" : outTrendQualityExtended ? "Extended" : "Neutral" : kr705UnavailableText
string kr705AcceptanceText = kr705AcceptanceAvailable ? outAcceptanceStrong ? "Strong Acceptance" : outAcceptanceAccepted ? "Accepted" : outAcceptanceTesting ? "Testing" : outAcceptanceRejected ? "Rejected" : "Neutral" : kr705UnavailableText
string kr705MomentumText = kr705MomentumAvailable ? outMomentumBuilding ? "Building" : outMomentumStrong ? "Strong" : outMomentumNormal ? "Normal" : outMomentumWeakening ? "Weakening" : outMomentumExhausted ? "Exhausted" : kr705UnavailableText : kr705UnavailableText
string kr705CompressionText = kr705CompressionAvailable ? outExpansionStarted ? "Expansion Started" : str.tostring(outCompressionScore) + " - " + outCompressionText : kr705UnavailableText
string kr705OpportunityText = kr705OpportunityAvailable ? outBullishOpportunityContext or outBearishOpportunityContext ? "Good" : "Limited" : kr705UnavailableText
string kr705PriceActionStateText = outPriceActionState == KR335_PRICE_ACTION_HIGH_QUALITY ? "High Quality" : outPriceActionState == KR335_PRICE_ACTION_EXPANSION ? "Expansion" : outPriceActionState == KR335_PRICE_ACTION_CONTRACTION ? "Contraction" : outPriceActionState == KR335_PRICE_ACTION_NORMAL ? "Normal" : "Unavailable"
string kr705PriceActionText = kr705PriceActionAvailable ? kr705PriceActionStateText : outPriceActionStatus
string kr705PriceActionScoreText = kr705PriceActionAvailable ? str.tostring(outPriceActionScore) : kr705UnavailableText
string kr705PriceActionPressureText = kr705PriceActionAvailable ? outPriceActionClosingPressureText : kr705UnavailableText
string kr705PriceActionRangeText = kr705PriceActionAvailable ? outPriceActionExpansionText : kr705UnavailableText
string kr705RelativeStateText = outRelativeState == KR345_RELATIVE_LEADER ? "LEADER" : outRelativeState == KR345_RELATIVE_STRONG ? "STRONG" : outRelativeState == KR345_RELATIVE_WEAK ? "WEAK" : outRelativeState == KR345_RELATIVE_LAGGARD ? "LAGGARD" : "NEUTRAL"
string kr705MarketRelativeStateText = outMarketRelativeState == KR345_RELATIVE_LEADER ? "LEADER" : outMarketRelativeState == KR345_RELATIVE_STRONG ? "STRONG" : outMarketRelativeState == KR345_RELATIVE_WEAK ? "WEAK" : outMarketRelativeState == KR345_RELATIVE_LAGGARD ? "LAGGARD" : "NEUTRAL"
string kr705SectorRelativeStateText = outSectorRelativeState == KR345_RELATIVE_LEADER ? "LEADER" : outSectorRelativeState == KR345_RELATIVE_STRONG ? "STRONG" : outSectorRelativeState == KR345_RELATIVE_WEAK ? "WEAK" : outSectorRelativeState == KR345_RELATIVE_LAGGARD ? "LAGGARD" : "NEUTRAL"
string kr705RelativeText = kr705RelativeAvailable ? kr705RelativeStateText : outRelativeStatus
string kr705RelativeScoreText = kr705RelativeAvailable ? str.tostring(outRelativeScore) : kr705UnavailableText
string kr705MarketRelativeText = outMarketRelativeReady ? kr705MarketRelativeStateText : kr705UnavailableText
string kr705SectorRelativeText = outSectorRelativeReady ? kr705SectorRelativeStateText : kr705NotAvailableText
string kr705RelativeBenchmarkText = outRelativeBenchmarkSymbol == "" ? kr705NotAvailableText : outRelativeBenchmarkSymbol
string kr705ConfidenceText = kr705ConfidenceAvailable ? str.tostring(outConfidenceScore) + " - " + outConfidenceText : kr705UnavailableText
string kr705RiskText = outTradeManagementReady ? outTradeText : kr705UnavailableText
bool kr705MCXExecutionPanel = outExecMCX1HContextReady
string kr705EntryText = outTriggerReady ? outTriggerText : kr705UnavailableText
string kr705DecisionText = outDecisionText
string kr705Need1Source = kr705MCXExecutionPanel ? outExecutionNeed1 : outNeed1
string kr705Need2Source = kr705MCXExecutionPanel ? outExecutionNeed2 : outNeed2
string kr705Need3Source = kr705MCXExecutionPanel ? outExecutionNeed3 : outNeed3
string kr705Need1Text = kr705Need1Source == "" ? kr705UnavailableText : kr705Need1Source
string kr705Need2Text = kr705Need2Source == "" ? kr705UnavailableText : kr705Need2Source
string kr705Need3Text = kr705Need3Source == "" ? kr705UnavailableText : kr705Need3Source
string kr705StatusText = kr705CoreDataReady ? "DATA OK" : "WAITING"

//==================================================================
// KR-705.30 DISPLAY COLOURS
//==================================================================

color kr705PanelBG = color.rgb(10, 10, 10)
color kr705HeaderBG = color.rgb(20, 20, 20)
color kr705BorderColor = color.rgb(230, 230, 230)
color kr705LabelText = color.rgb(220, 220, 220)
color kr705TitleText = color.rgb(0, 229, 255)
color kr705MutedText = color.rgb(180, 180, 180)
color kr705BrightGreen = color.lime
color kr705Green = color.rgb(0, 200, 83)
color kr705White = color.white
color kr705Yellow = color.yellow
color kr705Orange = color.orange
color kr705Red = color.red

color kr705TrendColor = not kr705TrendAvailable ? kr705MutedText : outBullishTrend ? kr705Green : outBearishTrend ? kr705Red : kr705White
color kr705TrendQualityColor = not kr705TrendQualityAvailable ? kr705MutedText : outTrendQualityExcellent ? kr705BrightGreen : outTrendQualityHealthy ? kr705Green : outTrendQualityWeak ? kr705Yellow : outTrendQualityExtended ? kr705Orange : kr705White
color kr705AcceptanceColor = not kr705AcceptanceAvailable ? kr705MutedText : outAcceptanceStrong ? kr705BrightGreen : outAcceptanceAccepted ? kr705Green : outAcceptanceTesting ? kr705Yellow : outAcceptanceRejected ? kr705Red : kr705White
color kr705MomentumColor = not kr705MomentumAvailable ? kr705MutedText : outMomentumBuilding ? kr705BrightGreen : outMomentumStrong ? kr705Green : outMomentumNormal ? kr705White : outMomentumWeakening ? kr705Yellow : outMomentumExhausted ? kr705Red : kr705MutedText
color kr705CompressionColor = not kr705CompressionAvailable ? kr705MutedText : outExpansionStarted ? kr705BrightGreen : outCompressionCritical ? kr705Orange : outCompressionStrong ? kr705Yellow : outCompressionBuilding ? kr705White : kr705MutedText
color kr705OpportunityColor = not kr705OpportunityAvailable ? kr705MutedText : outBullishOpportunityContext or outBearishOpportunityContext ? kr705Green : kr705Yellow
color kr705PriceActionColor = not kr705PriceActionAvailable ? kr705MutedText : outPriceActionScore >= 75 ? kr705BrightGreen : outPriceActionScore >= 50 ? kr705Green : outPriceActionScore >= 25 ? kr705Yellow : kr705Red
color kr705RelativeColor = not kr705RelativeAvailable ? kr705MutedText : outRelativeState == KR345_RELATIVE_LEADER ? kr705BrightGreen : outRelativeState == KR345_RELATIVE_STRONG ? kr705Green : outRelativeState == KR345_RELATIVE_NEUTRAL ? kr705White : outRelativeState == KR345_RELATIVE_WEAK ? kr705Yellow : kr705Red
color kr705MarketRelativeColor = not outMarketRelativeReady ? kr705MutedText : outMarketRelativeState == KR345_RELATIVE_LEADER ? kr705BrightGreen : outMarketRelativeState == KR345_RELATIVE_STRONG ? kr705Green : outMarketRelativeState == KR345_RELATIVE_NEUTRAL ? kr705White : outMarketRelativeState == KR345_RELATIVE_WEAK ? kr705Yellow : kr705Red
color kr705SectorRelativeColor = not outSectorRelativeReady ? kr705MutedText : outSectorRelativeState == KR345_RELATIVE_LEADER ? kr705BrightGreen : outSectorRelativeState == KR345_RELATIVE_STRONG ? kr705Green : outSectorRelativeState == KR345_RELATIVE_NEUTRAL ? kr705White : outSectorRelativeState == KR345_RELATIVE_WEAK ? kr705Yellow : kr705Red
color kr705ConfidenceColor = not kr705ConfidenceAvailable ? kr705MutedText : outConfidenceVeryHigh ? kr705BrightGreen : outConfidenceHigh ? kr705Green : outConfidenceMedium ? kr705White : outConfidenceLow ? kr705Yellow : kr705Red
color kr705PlaceholderColor = kr705MutedText
bool kr705Need1Unchecked = str.startswith(kr705Need1Source, "☐") or (kr705MCXExecutionPanel and kr705Need1Source != "")
bool kr705Need2Unchecked = str.startswith(kr705Need2Source, "☐") or (kr705MCXExecutionPanel and kr705Need2Source != "")
bool kr705Need3Unchecked = str.startswith(kr705Need3Source, "☐") or (kr705MCXExecutionPanel and kr705Need3Source != "")
bool kr705Need1Checked = str.startswith(kr705Need1Source, "✓") or str.startswith(kr705Need1Source, "☑")
bool kr705Need2Checked = str.startswith(kr705Need2Source, "✓") or str.startswith(kr705Need2Source, "☑")
bool kr705Need3Checked = str.startswith(kr705Need3Source, "✓") or str.startswith(kr705Need3Source, "☑")
color kr705Need1Color = kr705Need1Source == "" ? kr705MutedText : kr705Need1Checked ? kr705Green : kr705Need1Unchecked ? kr705Yellow : kr705MutedText
color kr705Need2Color = kr705Need2Source == "" ? kr705MutedText : kr705Need2Checked ? kr705Green : kr705Need2Unchecked ? kr705Yellow : kr705MutedText
color kr705Need3Color = kr705Need3Source == "" ? kr705MutedText : kr705Need3Checked ? kr705Green : kr705Need3Unchecked ? kr705Yellow : kr705MutedText
color kr705StatusColor = kr705CoreDataReady ? kr705BrightGreen : kr705Yellow

