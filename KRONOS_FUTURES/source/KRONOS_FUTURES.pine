//==================================================
// KR-100 CONFIGURATION ENGINE
//==================================================

//------------------------------
// Product Information
//------------------------------

const string KR_PRODUCT   = "KRONOS FUTURES"
const string KR_VERSION   = "0.5.0"
const string KR_BUILD     = "0004"
const string KR_CODENAME  = "FOUNDATION"
// Product release metadata above is intentionally unchanged pending
// formal version/build reconciliation.

//------------------------------
// Moving Average Settings
//------------------------------

const int KR_SMA_FAST = 20
const int KR_SMA_MID  = 50
const int KR_SMA_SLOW = 200

//------------------------------
// Input Groups
//------------------------------

const string GRP_MA = "Moving Averages"

//------------------------------
// User Inputs
//------------------------------

inpShowFastSMA = input.bool(true, "Show 20 SMA", group=GRP_MA)
inpShowMidSMA  = input.bool(true, "Show 50 SMA", group=GRP_MA)
inpShowSlowSMA = input.bool(true, "Show 200 SMA", group=GRP_MA)



//==================================================
// KR-150 INDICATOR ENGINE
//==================================================

//------------------------------
// Simple Moving Averages
//------------------------------

maFast = ta.sma(close, KR_SMA_FAST)
maMid  = ta.sma(close, KR_SMA_MID)
maSlow = ta.sma(close, KR_SMA_SLOW)

//------------------------------
// Plot
//------------------------------

plot(inpShowFastSMA ? maFast : na, title="20 SMA", color=color.lime, linewidth=2)
plot(inpShowMidSMA  ? maMid  : na, title="50 SMA", color=color.red, linewidth=2)
plot(inpShowSlowSMA ? maSlow : na, title="200 SMA", color=color.white, linewidth=2)



//==================================================
// KR-200 MARKET IDENTIFICATION ENGINE
//==================================================

//------------------------------
// Exchange Detection
//------------------------------

string krExchange = syminfo.prefix

//------------------------------
// Symbol Detection
//------------------------------

string krTicker = syminfo.ticker
string krRoot = syminfo.root

//------------------------------
// Instrument Name
//------------------------------

string krDescription = syminfo.description
string krTickerUpper = str.upper(krTicker)
string krRootUpper = str.upper(krRoot)
string krDescriptionUpper = str.upper(krDescription)

//------------------------------
// Market Identification
//------------------------------

bool isMCX      = krExchange == "MCX"
bool isNSE      = krExchange == "NSE"
bool isCOMEX    = krExchange == "COMEX"
bool isNYMEX    = krExchange == "NYMEX"
bool isFOREX    = krExchange == "OANDA"

//------------------------------
// Current Market
//------------------------------

string krMarket = "UNKNOWN"

if isMCX
    krMarket := "MCX"

else if isNSE
    krMarket := "NSE"

else if isCOMEX
    krMarket := "COMEX"

else if isNYMEX
    krMarket := "NYMEX"

else if isFOREX
    krMarket := "FOREX"

//==================================================
// END OF KR-200
//==================================================

//==================================================
// KR-250 ASSET INTELLIGENCE ENGINE
//==================================================
//
// Purpose
// --------
// Identify the current asset and map it to its
// corresponding global benchmark.
//
//==================================================

//------------------------------
// Asset Variables
//------------------------------

string krAssetName    = "UNKNOWN"
string krGlobalSymbol = "UNKNOWN"
string krAssetClass   = "UNKNOWN"

//==================================================
// KRONOS Asset Interface v2
//==================================================

// These variables are the public interface exposed
// by KR-250 to all downstream engines.

string assetName              = ""
string assetType              = ""

string assetMarket            = krMarket
string assetExchange          = krExchange

string assetPrimarySymbol     = syminfo.tickerid
string assetReferenceSymbol   = ""

string assetDependencyProfile = "Unknown"
string assetTradingProfile    = "Unknown"

//------------------------------
// Asset Identification
//------------------------------

bool krRootGold = isCOMEX and krRootUpper == "GC"
bool krRootSilver = isCOMEX and krRootUpper == "SI"
bool krRootCopper = isCOMEX and krRootUpper == "HG"
bool krRootCrudeOil = (isNYMEX and krRootUpper == "CL") or (isMCX and str.contains(krRootUpper, "CRUDE"))
bool krRootNaturalGas = (isNYMEX and krRootUpper == "NG") or (isMCX and (krRootUpper == "NG" or str.contains(krRootUpper, "NATGAS") or str.contains(krRootUpper, "NATURALGAS") or str.contains(krRootUpper, "NATURAL_GAS")))
bool krTickerCrudeOil = str.contains(krTickerUpper, "CRUDE") or str.contains(krTickerUpper, "CRUDEOIL")
bool krTickerNaturalGas = str.contains(krTickerUpper, "NATGAS") or str.contains(krTickerUpper, "NATURALGAS") or str.contains(krTickerUpper, "NATURAL_GAS")
bool krDescriptionCrudeOil = str.contains(krDescriptionUpper, "CRUDE") or str.contains(krDescriptionUpper, "CRUDE OIL")
bool krDescriptionNaturalGas = str.contains(krDescriptionUpper, "NATGAS") or str.contains(krDescriptionUpper, "NATURAL GAS") or str.contains(krDescriptionUpper, "NATURALGAS") or str.contains(krDescriptionUpper, "NATURAL_GAS")

bool krIsGold = krRootGold or str.contains(krTickerUpper, "GOLD") or str.contains(krDescriptionUpper, "GOLD")
bool krIsSilver = krRootSilver or str.contains(krTickerUpper, "SILVER") or str.contains(krDescriptionUpper, "SILVER")
bool krIsCopper = krRootCopper or str.contains(krTickerUpper, "COPPER") or str.contains(krDescriptionUpper, "COPPER")
bool krIsCrudeOil = krRootCrudeOil or krTickerCrudeOil or krDescriptionCrudeOil
bool krIsNaturalGas = krRootNaturalGas or krTickerNaturalGas or krDescriptionNaturalGas

if krIsGold
    krAssetName    := "Gold"
    krGlobalSymbol := "COMEX:GC1!"
    krAssetClass   := "Precious Metal"

else if krIsSilver
    krAssetName    := "Silver"
    krGlobalSymbol := "COMEX:SI1!"
    krAssetClass   := "Precious Metal"

else if krIsCopper
    krAssetName    := "Copper"
    krGlobalSymbol := "COMEX:HG1!"
    krAssetClass   := "Base Metal"

else if krIsCrudeOil
    krAssetName    := "Crude Oil"
    krGlobalSymbol := "NYMEX:CL1!"
    krAssetClass   := "Energy"

else if krIsNaturalGas
    krAssetName    := "Natural Gas"
    krGlobalSymbol := "NYMEX:NG1!"
    krAssetClass   := "Energy"

//==================================================
// KRONOS Asset Interface Mapping
//==================================================

// Copy legacy KR-250 values into the new interface.

assetName            := krAssetName
assetType            := krAssetClass
assetReferenceSymbol := krGlobalSymbol

//------------------------------
// Dependency Profiles
//------------------------------

if krMarket == "MCX"
    assetDependencyProfile := "GlobalDominant"
    assetTradingProfile    := "MCX Swing"

else if krTicker == "NIFTY" or str.contains(krTicker, "NIFTY")
    assetDependencyProfile := "LocalDominant"
    assetTradingProfile    := "NSE Swing"

else if str.contains(krTicker, "BANKNIFTY")
    assetDependencyProfile := "LocalDominant"
    assetTradingProfile    := "NSE Swing"

else if krMarket == "NSE"
    assetDependencyProfile := "LocalDominant"
    assetTradingProfile    := "NSE Swing"


//==================================================================
// KR-251 : Market Model Configuration Engine
// Version : 0.1.0
// Status  : FOUNDATION
//
// Purpose:
// Identifies the active market model and exposes standardized
// configuration outputs for future downstream integration. KR-251
// performs no trading intelligence and is not consumed by KR-260 yet.
//
// Scope:
// - MCX Metals
// - MCX Energy
// - NSE Equity Swing
// - NSE Index Swing
//
// Contract:
// - Configuration layer only.
// - No request.security calls.
// - No trading decisions, alerts, entries, exits, stops or targets.
// - Unsupported instruments expose empty reference fields and
//   outSupportedInstrument = false.
//==================================================================


//==================================================================
// KR-251.10 MARKET MODEL DETECTION
//==================================================================

const string KR251_NSE_EQUITY_SYMBOLS = "|IOC|HINDPETRO|BPCL|BEL|SHRIRAMFIN|BHEL|BDL|COALINDIA|POWERINDIA|SBICARD|SAIL|RVNL|MAZDOCK|YESBANK|TATAPOWER|MAXHEALTH|JUBLFOOD|LUPIN|CONCOR|INFY|DRREDDY|TRENT|DIXON|NAUKRI|ALKEM|LICI|HAL|INDHOTEL|HDFCAMC|POWERGRID|BHARTIARTL|NTPC|TCS|ICICIBANK|MUTHOOTFIN|FEDERALBNK|MARUTI|WIPRO|ASIANPAINT|PERSISTENT|INDIANB|MCX|ETERNAL|SUNPHARMA|MOTHERSON|AXISBANK|TMPV|CANBK|SRF|PNB|BAJAJFINSV|DIVISLAB|HCLTECH|HDFCLIFE|CDSL|RBLBANK|ADANIGREEN|TECHM|M&M|ADANIENT|CIPLA|COFORGE|HINDUNILVR|CUMMINSIND|RELIANCE|BSE|TITAN|KOTAKBANK|RECLTD|APOLLOHOSP|JIOFIN|EICHERMOT|LT|ADANIPORTS|VEDL|BHARATFORG|ITC|POLICYBZR|SBIN|BAJFINANCE|HDFCBANK|TATASTEEL|PAYTM|HEROMOTOCO|INDIGO|KAYNES|UPL|BAJAJ_AUTO|HINDALCO|IDEA|VBL|"

modelSymbolInApprovedNSEUniverse(string symbol) =>
    symbol != "" and str.contains(KR251_NSE_EQUITY_SYMBOLS, "|" + symbol + "|")

bool modelMCXMetals = assetMarket == "MCX" and (assetName == "Gold" or assetName == "Silver" or assetName == "Copper")
bool modelMCXEnergy = assetMarket == "MCX" and (assetName == "Crude Oil" or assetName == "Natural Gas")
bool modelNSEIndexNifty = assetMarket == "NSE" and (krRootUpper == "NIFTY" or krTickerUpper == "NIFTY")
bool modelNSEIndexBankNifty = assetMarket == "NSE" and (krRootUpper == "BANKNIFTY" or krTickerUpper == "BANKNIFTY")
bool modelNSEIndexSwing = modelNSEIndexNifty or modelNSEIndexBankNifty
bool modelNSEEquityRootSupported = assetMarket == "NSE" and modelSymbolInApprovedNSEUniverse(krRootUpper)
bool modelNSEEquityTickerSupported = assetMarket == "NSE" and modelSymbolInApprovedNSEUniverse(krTickerUpper)
bool modelNSEEquitySwing = not modelNSEIndexSwing and (modelNSEEquityRootSupported or modelNSEEquityTickerSupported)
string modelDetectedNSESymbol = modelNSEEquityRootSupported ? krRootUpper : modelNSEEquityTickerSupported ? krTickerUpper : ""
string modelDetectedNSEIndexSymbol = modelNSEIndexBankNifty ? "BANKNIFTY" : modelNSEIndexNifty ? "NIFTY" : ""

string modelName = "Unsupported"
string modelAssetName = assetName
string modelExecutionVenue = assetMarket
string modelAnalysisSymbol = syminfo.tickerid
string modelExecutionInstrumentText = ""
string modelExecutionInstrumentType = "Unsupported"
string modelCashSymbol = ""
string modelFuturesSymbol = syminfo.tickerid
string modelPrimaryReferenceSymbol = ""
string modelSecondaryReferenceSymbol = ""
string modelParentIndex = ""
string modelExecutionProfile = "UNKNOWN"
bool modelSupportedInstrument = false

if modelMCXMetals
    modelName := "MCX Metals Swing"
    modelExecutionVenue := "MCX"
    modelAnalysisSymbol := syminfo.tickerid
    modelExecutionInstrumentText := assetName + " FUT"
    modelExecutionInstrumentType := "Commodity Futures"
    modelPrimaryReferenceSymbol := assetReferenceSymbol
    modelExecutionProfile := "SWING"
    modelSupportedInstrument := assetReferenceSymbol != "" and assetReferenceSymbol != "UNKNOWN"
else if modelMCXEnergy
    modelName := "MCX Energy Swing"
    modelExecutionVenue := "MCX"
    modelAnalysisSymbol := syminfo.tickerid
    modelExecutionInstrumentText := assetName + " FUT"
    modelExecutionInstrumentType := "Commodity Futures"
    modelPrimaryReferenceSymbol := assetReferenceSymbol
    modelExecutionProfile := "SWING"
    modelSupportedInstrument := assetReferenceSymbol != "" and assetReferenceSymbol != "UNKNOWN"
else if modelNSEEquitySwing
    modelName := "NSE Equity Swing"
    modelAssetName := modelDetectedNSESymbol
    modelExecutionVenue := "NSE"
    modelCashSymbol := "NSE:" + modelDetectedNSESymbol
    modelAnalysisSymbol := modelCashSymbol
    modelFuturesSymbol := ""
    modelExecutionInstrumentText := modelDetectedNSESymbol + " FUT"
    modelExecutionInstrumentType := "Stock Futures"
    modelExecutionProfile := "SWING"
    modelSupportedInstrument := true
else if modelNSEIndexSwing
    modelName := "NSE Index Swing"
    modelAssetName := modelDetectedNSEIndexSymbol
    modelExecutionVenue := "NSE"
    modelAnalysisSymbol := "NSE:" + modelDetectedNSEIndexSymbol
    modelFuturesSymbol := ""
    modelExecutionInstrumentText := modelDetectedNSEIndexSymbol + " FUT"
    modelExecutionInstrumentType := "Index Futures"
    modelExecutionProfile := "SWING"
    modelSupportedInstrument := true

// KRONOS_NSE_RELATIONSHIPS.csv is the source of truth for NSE
// equity cash, sector-index and parent-index mappings. Pine cannot
// read local CSV files directly, so the generated KR-252 map exposes
// those relationships while KR-251 owns model and execution semantics.

//==================================================================
// KR-251.20 PUBLIC INTERFACE
//==================================================================

string outModelName = modelName
string outAssetName = modelAssetName
string outExecutionVenue = modelExecutionVenue
string outAnalysisSymbol = modelAnalysisSymbol
string outExecutionInstrumentText = modelExecutionInstrumentText
string outExecutionInstrumentType = modelExecutionInstrumentType
string outCashSymbol = modelCashSymbol
string outFuturesSymbol = modelFuturesSymbol
string outPrimaryReferenceSymbol = modelPrimaryReferenceSymbol
string outSecondaryReferenceSymbol = modelSecondaryReferenceSymbol
string outParentIndex = modelParentIndex
string outExecutionProfile = modelExecutionProfile
bool outSupportedInstrument = modelSupportedInstrument

//==================================================================
// END OF KR-251
//==================================================================


//==================================================================
// KR-252 : Market Relationship Engine
// Version : 0.1.0
// Status  : FOUNDATION
//
// Purpose:
// Exposes the cash, sector, parent-index and global-reference
// relationships required by supported instruments. KR-252 performs
// relationship configuration only and is not consumed by KR-260 yet.
//
// Contract:
// - Relationship configuration only.
// - Consumes KR-251 support/model classification.
// - No request.security calls.
// - No trend, relative-strength, decision, alert, entry, exit, stop
//   or target logic.
//==================================================================

//==================================================================
// KR-252.10 RELATIONSHIP CONSTANTS
//==================================================================

const string KR252_STATUS_READY = "READY"
const string KR252_STATUS_REVIEW = "REVIEW"
const string KR252_STATUS_UNSUPPORTED = "UNSUPPORTED"

//==================================================================
// KR-252.20 RELATIONSHIP CONFIGURATION
//==================================================================

bool relationshipIsMCXMetals = outModelName == "MCX Metals Swing"
bool relationshipIsMCXEnergy = outModelName == "MCX Energy Swing"
bool relationshipIsNSEEquity = outModelName == "NSE Equity Swing"
bool relationshipIsNSEIndex = outModelName == "NSE Index Swing"

string relationshipCashSymbol = ""
string relationshipPrimaryReferenceSymbol = ""
string relationshipSecondaryReferenceSymbol = ""
string relationshipSectorIndexSymbol = ""
string relationshipParentIndexSymbol = ""
string relationshipSymbolRoot = str.upper(syminfo.root)
string relationshipSymbolTicker = str.upper(syminfo.ticker)
string relationshipSymbolDescription = str.upper(syminfo.description)
string relationshipNormalizedNSESymbol = ""
string relationshipDatasetStatus = ""
string relationshipDatasetReason = ""
bool relationshipNSEMapped = false

relationshipSymbolMatches(string expectedSymbol, string expectedDescription, string currentRoot, string currentTicker, string currentDescription) =>
    currentRoot == expectedSymbol or currentTicker == expectedSymbol or currentDescription == expectedDescription

if relationshipIsMCXMetals
    relationshipPrimaryReferenceSymbol := outAssetName == "Gold" ? "COMEX:GC1!" : outAssetName == "Silver" ? "COMEX:SI1!" : outAssetName == "Copper" ? "COMEX:HG1!" : ""
else if relationshipIsMCXEnergy
    relationshipPrimaryReferenceSymbol := outAssetName == "Crude Oil" ? "NYMEX:CL1!" : outAssetName == "Natural Gas" ? "NYMEX:NG1!" : ""
else if relationshipIsNSEIndex
    relationshipDatasetStatus := KR252_STATUS_READY
    relationshipDatasetReason := "NSE Index Relationship Ready"

// BEGIN GENERATED NSE RELATIONSHIP MAPPING
// Source: data/nse/KRONOS_NSE_RELATIONSHIPS.csv
// Dataset version/date: Curated 2026-07-11
// Generated row count: 91
// READY count: 90
// REVIEW count: 1
// Generation method: scripts/generate_nse_relationship_mapping.py
// This block is generated configuration only. Do not add trading logic here.
if relationshipIsNSEEquity
    if relationshipSymbolMatches("IOC", "INDIAN OIL CORP. LTD.", relationshipSymbolRoot, relationshipSymbolTicker, relationshipSymbolDescription)
        relationshipNormalizedNSESymbol := "IOC"
        relationshipNSEMapped := true
        relationshipCashSymbol := "NSE:IOC"
        relationshipPrimaryReferenceSymbol := "NSE:CNXENERGY"
        relationshipSecondaryReferenceSymbol := "NSE:NIFTY"
        relationshipSectorIndexSymbol := "NSE:CNXENERGY"
        relationshipParentIndexSymbol := "NSE:NIFTY"
        relationshipDatasetStatus := KR252_STATUS_READY
        relationshipDatasetReason := "Primary listed sector membership is Nifty Energy."
    else if relationshipSymbolMatches("HINDPETRO", "HINDUSTAN PETROLEUM CORPORATION LIMITED", relationshipSymbolRoot, relationshipSymbolTicker, relationshipSymbolDescription)
        relationshipNormalizedNSESymbol := "HINDPETRO"
        relationshipNSEMapped := true
        relationshipCashSymbol := "NSE:HINDPETRO"
        relationshipPrimaryReferenceSymbol := "NSE:CNXENERGY"
        relationshipSecondaryReferenceSymbol := "NSE:NIFTY"
        relationshipSectorIndexSymbol := "NSE:CNXENERGY"
        relationshipParentIndexSymbol := "NSE:NIFTY"
        relationshipDatasetStatus := KR252_STATUS_READY
        relationshipDatasetReason := "Primary listed sector membership is Nifty Energy."
    else if relationshipSymbolMatches("BPCL", "BHARAT PETROLEUM CORPORATION LIMITED", relationshipSymbolRoot, relationshipSymbolTicker, relationshipSymbolDescription)
        relationshipNormalizedNSESymbol := "BPCL"
        relationshipNSEMapped := true
        relationshipCashSymbol := "NSE:BPCL"
        relationshipPrimaryReferenceSymbol := "NSE:CNXENERGY"
        relationshipSecondaryReferenceSymbol := "NSE:NIFTY"
        relationshipSectorIndexSymbol := "NSE:CNXENERGY"
        relationshipParentIndexSymbol := "NSE:NIFTY"
        relationshipDatasetStatus := KR252_STATUS_READY
        relationshipDatasetReason := "Primary listed sector membership is Nifty Energy."
    else if relationshipSymbolMatches("BEL", "BHARAT ELECTRONICS LIMITED", relationshipSymbolRoot, relationshipSymbolTicker, relationshipSymbolDescription)
        relationshipNormalizedNSESymbol := "BEL"
        relationshipNSEMapped := true
        relationshipCashSymbol := "NSE:BEL"
        relationshipPrimaryReferenceSymbol := "NSE:CNXPSE"
        relationshipSecondaryReferenceSymbol := "NSE:NIFTY"
        relationshipSectorIndexSymbol := "NSE:CNXPSE"
        relationshipParentIndexSymbol := "NSE:NIFTY"
        relationshipDatasetStatus := KR252_STATUS_READY
        relationshipDatasetReason := "Defence PSU; CNXPSE is the closest verified benchmark."
