bool relationshipPrimaryReferenceValid = relationshipPrimaryReferenceSymbol != "" and relationshipPrimaryReferenceSymbol != "UNKNOWN"
bool relationshipCashRequired = relationshipIsNSEEquity
bool relationshipSectorRequired = relationshipIsNSEEquity and relationshipDatasetStatus != KR252_STATUS_REVIEW
bool relationshipParentRequired = relationshipIsNSEEquity
bool relationshipCashReady = not relationshipCashRequired or relationshipCashSymbol != ""
bool relationshipSectorReady = not relationshipSectorRequired or relationshipSectorIndexSymbol != ""
bool relationshipParentReady = not relationshipParentRequired or relationshipParentIndexSymbol != ""
bool relationshipHasGlobalReference = (relationshipIsMCXMetals or relationshipIsMCXEnergy) and relationshipPrimaryReferenceValid
bool relationshipHasSectorContext = relationshipSectorIndexSymbol != ""
bool relationshipHasParentIndexContext = relationshipParentIndexSymbol != ""

string relationshipStatus = KR252_STATUS_UNSUPPORTED
string relationshipReason = "Symbol Not In KRONOS Universe"
bool relationshipReady = false

if outSupportedInstrument
    if relationshipIsMCXMetals or relationshipIsMCXEnergy
        relationshipReady := relationshipPrimaryReferenceValid
        relationshipStatus := relationshipReady ? KR252_STATUS_READY : KR252_STATUS_REVIEW
        relationshipReason := relationshipReady ? "Global Reference Ready" : "Missing Global Reference"
    else if relationshipIsNSEEquity
        if relationshipNSEMapped
            relationshipReady := relationshipDatasetStatus == KR252_STATUS_READY and relationshipCashReady and relationshipSectorReady and relationshipParentReady
            relationshipStatus := relationshipDatasetStatus
            relationshipReason := relationshipReady ? "NSE Relationship Ready" : relationshipDatasetReason
        else
            relationshipReady := false
            relationshipStatus := KR252_STATUS_UNSUPPORTED
            relationshipReason := "Symbol Not In KRONOS Universe"
    else if relationshipIsNSEIndex
        relationshipReady := true
        relationshipStatus := KR252_STATUS_READY
        relationshipReason := "NSE Index Relationship Ready"

